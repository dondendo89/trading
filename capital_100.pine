bbPresetM1 = bbPreset == "Bilanciato" ? 50 : bbPreset == "Veloce" ? 30 : bbPreset == "Conservativo" ? 80 : na
bbPresetM15 = bbPreset == "Bilanciato" ? 50 : bbPreset == "Veloce" ? 35 : bbPreset == "Conservativo" ? 70 : na
bbPresetH1 = bbPreset == "Bilanciato" ? 50 : bbPreset == "Veloce" ? 40 : bbPreset == "Conservativo" ? 60 : na
bbPresetH4 = bbPreset == "Bilanciato" ? 50 : bbPreset == "Veloce" ? 50 : bbPreset == "Conservativo" ? 70 : na

onlyMainMode = onlyQmMode or onlyBelugaMode
onlyAllowDailyHL = (not onlyMainMode) or (onlyQmMode and onlyQmShowDailyHL)
onlyAllowSessions = (not onlyMainMode) or (onlyQmMode and onlyQmShowSessions)

