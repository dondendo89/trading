//@version=6
indicator("CISD + Hammer/Shooting + VP Filters (MT5 parity)", "CISD+HS+VP", overlay=true, max_lines_count=500, max_labels_count=500)

bullishBreakColor = input.color(color.black, "Bull CISD", inline="bup")
bearishBreakColor = input.color(color.black, "Bear CISD", inline="bep")
bullStr = input.string("+CISD", " ", inline="bup")
bearStr = input.string("-CISD", " ", inline="bep")
lineWidth = input.int(1, "Line Width", minval=1, maxval=5)
lookAheadBars = input.int(5, "Line Extension Bars", minval=1, maxval=50)
styleOption = input.string("Solid", "Line Style", options=["Solid", "Dotted", "Dashed"])
keepLevels = input.bool(false, "Keep old CISD levels")

sendAlerts = input.bool(true, "Enable alerts", group="Alerts")
plotHistory = input.bool(true, "Plot history", group="Alerts")

enableHs = input.bool(true, "Enable Hammer/Shooting", group="Hammer/Shooting")
fibLevel = input.float(0.382, "Fibonacci Level", options=[0.236, 0.382, 0.5], group="Hammer/Shooting")
confirmByNext = input.bool(false, "Confirm by next candle", group="Hammer/Shooting")
confirmWithDxy = input.bool(true, "Confirm with DXY", group="Hammer/Shooting")
dxySymbol = input.symbol("TVC:DXY", "DXY Symbol", group="Hammer/Shooting")
wyckSpikeFilterEnabled = input.bool(true, "Wyck spike filter", group="Hammer/Shooting")
wyckSpikeMinPoints = input.int(600, "Wyck min points (default)", minval=1, group="Hammer/Shooting")
wyckSpikeMinPointsCur = input.int(0, "Wyck min points (Current TF, 0=default)", minval=0, group="Hammer/Shooting")
wyckSpikeMinPointsM15 = input.int(0, "Wyck min points (M15, 0=default)", minval=0, group="Hammer/Shooting")
wyckSpikeMinPointsM30 = input.int(0, "Wyck min points (M30, 0=default)", minval=0, group="Hammer/Shooting")
wyckSpikeMinPointsH1 = input.int(0, "Wyck min points (H1, 0=default)", minval=0, group="Hammer/Shooting")
wyckSpikeMinPointsH4 = input.int(0, "Wyck min points (H4, 0=default)", minval=0, group="Hammer/Shooting")

hsEnableM15 = input.bool(true, "M15", inline="tf", group="Hammer/Shooting TF")
hsEnableM30 = input.bool(true, "M30", inline="tf", group="Hammer/Shooting TF")
hsEnableH1  = input.bool(true, "H1", inline="tf", group="Hammer/Shooting TF")
hsEnableH4  = input.bool(true, "H4", inline="tf", group="Hammer/Shooting TF")

hsTrendFilterEnabled = input.bool(true, "Strong trend filter", group="Trend Filter")
hsTrendEmaFast = input.int(50, "EMA fast", minval=1, group="Trend Filter")
hsTrendEmaSlow = input.int(200, "EMA slow", minval=2, group="Trend Filter")
hsTrendAtrPeriod = input.int(14, "ATR period", minval=1, group="Trend Filter")
hsTrendAtrMult = input.float(0.5, "ATR mult", minval=0.0, step=0.1, group="Trend Filter")

vpFilterEnabled = input.bool(true, "VP filter", group="Volume Profile")
vpBodyZoneFilter = input.bool(true, "Body zone filter (VAL-POC / POC-VAH)", group="Volume Profile")
vpRows = input.int(30, "VP rows", minval=10, maxval=200, group="Volume Profile")
vpValueAreaPercent = input.int(70, "Value Area %", minval=50, maxval=95, group="Volume Profile")
vpAnchorAsia = input.bool(true, "Anchor from Asia open", group="Volume Profile")
vpAsiaOpenHour = input.int(0, "Asia open hour", minval=0, maxval=23, group="Volume Profile")
vpTz = input.string("Etc/UTC", "Timezone", group="Volume Profile")
vpMaxBars = input.int(600, "Max bars since Asia", minval=50, maxval=2000, group="Volume Profile")
vpFixedLookback = input.int(100, "Fixed lookback (if not Asia)", minval=10, maxval=2000, group="Volume Profile")
vpShowLines = input.bool(true, "Show POC/VAH/VAL", group="Volume Profile")

lineStyle = styleOption == "Dotted" ? line.style_dotted : styleOption == "Dashed" ? line.style_dashed : line.style_solid

type MarketStructure
    float topPrice
    float bottomPrice
    bool isBullish

type cisd
    line level
    label txt
    bool completed

var MarketStructure currentStructure = MarketStructure.new(0, 0, false)
var cisdLevelsBu = array.new<cisd>()
var cisdLevelsBe = array.new<cisd>()
var bool isBullishPullback = false
var bool isBearishPullback = false
var float potentialTopPrice = na
var float potentialBottomPrice = na
var int bullishBreakIndex = na
var int bearishBreakIndex = na
var bool currentState = false

bearishPullbackDetected = close[1] > open[1]
bullishPullbackDetected = close[1] < open[1]

if bearishPullbackDetected and not isBearishPullback
    isBearishPullback := true
    potentialTopPrice := open[1]
    bullishBreakIndex := bar_index[1]

if bullishPullbackDetected and not isBullishPullback
    isBullishPullback := true
    potentialBottomPrice := open[1]
    bearishBreakIndex := bar_index[1]

if isBullishPullback
    if open < potentialBottomPrice
        potentialBottomPrice := open
        bearishBreakIndex := bar_index
    if (close < open) and (open > potentialBottomPrice)
        potentialBottomPrice := open
        bearishBreakIndex := bar_index

if isBearishPullback
    if open > potentialTopPrice
        potentialTopPrice := open
        bullishBreakIndex := bar_index
    if (close > open) and open < potentialTopPrice
        potentialTopPrice := open
        bullishBreakIndex := bar_index

if low < currentStructure.bottomPrice
    currentStructure.bottomPrice := low
    currentStructure.isBullish := false
    if isBearishPullback and (bar_index - bullishBreakIndex != 0)
        currentStructure.topPrice := math.max(high[bar_index - bullishBreakIndex], high[bar_index - bullishBreakIndex + 1])
        isBearishPullback := false
        bearishLine = line.new(bullishBreakIndex, potentialTopPrice, bar_index + lookAheadBars, potentialTopPrice, color=bullishBreakColor, width=lineWidth, style=lineStyle)
        bearishLabel = label.new(bar_index + lookAheadBars, potentialTopPrice, bullStr, color=color.new(color.white, 100), textcolor=bullishBreakColor, style=label.style_label_left, size=size.small)
        b = cisd.new(bearishLine, bearishLabel, false)
        cisdLevelsBe.push(b)
    else if close[1] > open[1] and close < open
        currentStructure.topPrice := high[1]
        isBearishPullback := false
        bearishLine = line.new(bullishBreakIndex, potentialTopPrice, bar_index + lookAheadBars, potentialTopPrice, color=bullishBreakColor, width=lineWidth, style=lineStyle)
        bearishLabel = label.new(bar_index + lookAheadBars, potentialTopPrice, bullStr, color=color.new(color.white, 100), textcolor=bullishBreakColor, style=label.style_label_left, size=size.small)
        b = cisd.new(bearishLine, bearishLabel, false)
        cisdLevelsBe.push(b)

if high > currentStructure.topPrice
    currentStructure.isBullish := true
    currentStructure.topPrice := high
    if isBullishPullback and (bar_index - bearishBreakIndex != 0)
        currentStructure.bottomPrice := math.min(low[bar_index - bearishBreakIndex], low[bar_index - bearishBreakIndex + 1])
        isBullishPullback := false
        bullishLine = line.new(bearishBreakIndex, potentialBottomPrice, bar_index + lookAheadBars, potentialBottomPrice, color=bearishBreakColor, width=lineWidth, style=lineStyle)
        bullishLabel = label.new(bar_index + lookAheadBars, potentialBottomPrice, bearStr, color=color.new(color.white, 100), textcolor=bearishBreakColor, style=label.style_label_left, size=size.small)
        bu = cisd.new(bullishLine, bullishLabel, false)
        cisdLevelsBu.push(bu)
    else if close[1] < open[1] and close > open
        currentStructure.bottomPrice := low[1]
        isBullishPullback := false
        bullishLine = line.new(bearishBreakIndex, potentialBottomPrice, bar_index + lookAheadBars, potentialBottomPrice, color=bearishBreakColor, width=lineWidth, style=lineStyle)
        bullishLabel = label.new(bar_index + lookAheadBars, potentialBottomPrice, bearStr, color=color.new(color.white, 100), textcolor=bearishBreakColor, style=label.style_label_left, size=size.small)
        bu = cisd.new(bullishLine, bullishLabel, false)
        cisdLevelsBu.push(bu)

if array.size(cisdLevelsBu) > 1 and not keepLevels
    latest = array.shift(cisdLevelsBu)
    line.delete(latest.level)
    label.delete(latest.txt)

if array.size(cisdLevelsBe) > 1 and not keepLevels
    latest = array.shift(cisdLevelsBe)
    line.delete(latest.level)
    label.delete(latest.txt)

var bool bearCisdFormed = false
var bool bullCisdFormed = false
bearCisdFormed := false
bullCisdFormed := false

if array.size(cisdLevelsBu) >= 1
    latest = array.get(cisdLevelsBu, 0)
    if not (close < latest.level.get_y2()) and not latest.completed
        line.set_x2(latest.level, bar_index + lookAheadBars)
        label.set_x(latest.txt, bar_index + lookAheadBars)
    if close < latest.level.get_y2() and not latest.completed
        latest.completed := true
        bearCisdFormed := true
        currentState := false

if array.size(cisdLevelsBe) >= 1 and not keepLevels
    latest = array.get(cisdLevelsBe, 0)
    if not (close > latest.level.get_y2()) and not latest.completed
        line.set_x2(latest.level, bar_index + lookAheadBars)
        label.set_x(latest.txt, bar_index + lookAheadBars)
    if close > latest.level.get_y2() and not latest.completed
        latest.completed := true
        bullCisdFormed := true
        currentState := true

alertcondition(sendAlerts and bearCisdFormed, "Bearish CISD Formed", "Bearish CISD Formed on {{ticker}} {{interval}}")
alertcondition(sendAlerts and bullCisdFormed, "Bullish CISD Formed", "Bullish CISD Formed on {{ticker}} {{interval}}")

f_is_hammer(_o, _h, _l, _c) =>
    cs = math.abs(_h - _l)
    cs > 0 and _h - fibLevel * cs < math.min(_o, _c)

f_is_shoot(_o, _h, _l, _c) =>
    cs = math.abs(_h - _l)
    cs > 0 and _l + fibLevel * cs > math.max(_o, _c)

f_trend_flags(_c) =>
    ef = ta.ema(_c, hsTrendEmaFast)
    es = ta.ema(_c, hsTrendEmaSlow)
    a = ta.atr(hsTrendAtrPeriod)
    diff = ef - es
    thr = a * hsTrendAtrMult
    up = diff >= thr and _c > ef
    dn = (-diff) >= thr and _c < ef
    [up, dn]

f_asia_start() =>
    tz = str.length(vpTz) > 0 ? vpTz : syminfo.timezone
    h = hour(time, tz)
    m = minute(time, tz)
    h == vpAsiaOpenHour and m == 0

f_vp_len() =>
    if vpAnchorAsia
        bs = ta.barssince(f_asia_start())
        base = na(bs) ? (bar_index + 1) : (bs + 1)
        math.min(base, vpMaxBars)
    else
        vpFixedLookback

f_vp_levels(_len) =>
    bins = vpRows
    ln = int(math.max(1, _len))
    hi = ta.highest(high, ln)
    lo = ta.lowest(low, ln)
    rng = hi - lo
    float poc = na
    float vah = na
    float val = na
    if rng > 0 and ln >= 10
        rowH = rng / bins
        vols = array.new_float(bins, 0.0)
        for i = 0 to ln - 1
            bh = high[i]
            bl = low[i]
            bv = volume[i]
            sv = bv <= 0 ? 1 : bv
            s = int(math.floor((bl - lo) / rowH))
            e = int(math.floor((bh - lo) / rowH))
            s := math.max(0, s)
            e := math.min(bins - 1, e)
            cnt = e - s + 1
            if cnt > 0
                vpl = sv / cnt
                for j = s to e
                    array.set(vols, j, array.get(vols, j) + vpl)
        tot = 0.0
        maxV = array.get(vols, 0)
        pocI = 0
        for i = 0 to bins - 1
            v = array.get(vols, i)
            tot += v
            if v > maxV
                maxV := v
                pocI := i
        if tot > 0
            target = tot * (vpValueAreaPercent / 100.0)
            acc = array.get(vols, pocI)
            vahI = pocI
            valI = pocI
            while acc < target
                canUp = vahI < bins - 1
                canDn = valI > 0
                upV = canUp ? array.get(vols, vahI + 1) : 0.0
                dnV = canDn ? array.get(vols, valI - 1) : 0.0
                if canUp and (not canDn or upV >= dnV)
                    acc += upV
                    vahI += 1
                else
                    if canDn
                        acc += dnV
                        valI -= 1
                    else
                        break
            poc := lo + (pocI + 0.5) * rowH
            vah := lo + (vahI + 1.0) * rowH
            val := lo + (valI + 0.0) * rowH
    [poc, vah, val]

f_hs_calc(_wyckMinPoints) =>
    if not enableHs
        [0, na, na, na, na, na]
    else
        _len = f_vp_len()
        [poc, vah, val] = f_vp_levels(_len)
        [up, dn] = f_trend_flags(close)
        sigIdx = confirmByNext ? 1 : 0
        confOkHammer = confirmByNext ? (close > math.max(open[1], close[1])) : true
        confOkShoot = confirmByNext ? (close < math.min(open[1], close[1])) : true
        hammer = f_is_hammer(open[sigIdx], high[sigIdx], low[sigIdx], close[sigIdx]) and (not confirmByNext or (close > open and confOkHammer))
        shoot = f_is_shoot(open[sigIdx], high[sigIdx], low[sigIdx], close[sigIdx]) and (not confirmByNext or (close < open and confOkShoot))
        if wyckSpikeFilterEnabled
            minPts = _wyckMinPoints > 0 ? _wyckMinPoints : wyckSpikeMinPoints
            rangePts = (high[sigIdx] - low[sigIdx]) / syminfo.mintick
            hammer := hammer and rangePts >= minPts
            shoot := shoot and rangePts >= minPts
        if hsTrendFilterEnabled
            hammer := hammer and dn
            shoot := shoot and up
        if vpFilterEnabled and not na(poc) and not na(vah) and not na(val)
            if hammer
                hammer := (low[sigIdx] < val) and (close[sigIdx] > val) and (close[sigIdx] < vah)
                if vpBodyZoneFilter
                    bmin = math.min(open[sigIdx], close[sigIdx])
                    bmax = math.max(open[sigIdx], close[sigIdx])
                    hammer := hammer and (bmin >= val) and (bmax <= poc)
            if shoot
                shoot := (high[sigIdx] > vah) and (close[sigIdx] < vah) and (close[sigIdx] > val)
                if vpBodyZoneFilter
                    bmin = math.min(open[sigIdx], close[sigIdx])
                    bmax = math.max(open[sigIdx], close[sigIdx])
                    shoot := shoot and (bmin >= poc) and (bmax <= vah)
        sig = barstate.isconfirmed ? (hammer ? 1 : shoot ? -1 : 0) : 0
        price = sig == 1 ? low[sigIdx] : sig == -1 ? high[sigIdx] : na
        sigTime = time_close
        [sig, price, poc, vah, val, sigTime]

f_hs_raw(tf, _wyckMinPoints) =>
    request.security(syminfo.tickerid, tf, f_hs_calc(_wyckMinPoints), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

isXau = str.contains(syminfo.ticker, "XAU")

f_confirm_sig(rawSig, tf) =>
    if not confirmWithDxy or not isXau
        rawSig
    else
        dxyBull = request.security(dxySymbol, tf, close > open, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
        dxyBear = request.security(dxySymbol, tf, close < open, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
        rawSig == 1 and dxyBear ? 1 : rawSig == -1 and dxyBull ? -1 : 0

show = plotHistory or barstate.isrealtime

f_plot_sig(_cond, _x, _price, _txt, _clr, _isUp) =>
    if _cond and not na(_price)
        label.new(x=_x, y=_price, text=_txt, xloc=xloc.bar_time, yloc=yloc.price, style=_isUp ? label.style_label_up : label.style_label_down, textcolor=_clr, color=color.new(color.white, 100), size=size.tiny)

wyckCur = wyckSpikeMinPointsCur > 0 ? wyckSpikeMinPointsCur : wyckSpikeMinPoints
wyckM15 = wyckSpikeMinPointsM15 > 0 ? wyckSpikeMinPointsM15 : wyckSpikeMinPoints
wyckM30 = wyckSpikeMinPointsM30 > 0 ? wyckSpikeMinPointsM30 : wyckSpikeMinPoints
wyckH1 = wyckSpikeMinPointsH1 > 0 ? wyckSpikeMinPointsH1 : wyckSpikeMinPoints
wyckH4 = wyckSpikeMinPointsH4 > 0 ? wyckSpikeMinPointsH4 : wyckSpikeMinPoints

[raw15, p15, _, _, _, x15] = f_hs_raw("15", wyckM15)
sig15 = hsEnableM15 ? f_confirm_sig(raw15, "15") : 0
new15 = sig15 != 0 and x15 != x15[1]
f_plot_sig(show and new15 and sig15 == 1, x15, p15, "Hammer M15", color.lime, true)
f_plot_sig(show and new15 and sig15 == -1, x15, p15, "Shooting M15", color.red, false)

[raw30, p30, _, _, _, x30] = f_hs_raw("30", wyckM30)
sig30 = hsEnableM30 ? f_confirm_sig(raw30, "30") : 0
new30 = sig30 != 0 and x30 != x30[1]
f_plot_sig(show and new30 and sig30 == 1, x30, p30, "Hammer M30", color.lime, true)
f_plot_sig(show and new30 and sig30 == -1, x30, p30, "Shooting M30", color.red, false)

[raw60, p60, _, _, _, x60] = f_hs_raw("60", wyckH1)
sig60 = hsEnableH1 ? f_confirm_sig(raw60, "60") : 0
new60 = sig60 != 0 and x60 != x60[1]
f_plot_sig(show and new60 and sig60 == 1, x60, p60, "Hammer H1", color.lime, true)
f_plot_sig(show and new60 and sig60 == -1, x60, p60, "Shooting H1", color.red, false)

[raw240, p240, _, _, _, x240] = f_hs_raw("240", wyckH4)
sig240 = hsEnableH4 ? f_confirm_sig(raw240, "240") : 0
new240 = sig240 != 0 and x240 != x240[1]
f_plot_sig(show and new240 and sig240 == 1, x240, p240, "Hammer H4", color.lime, true)
f_plot_sig(show and new240 and sig240 == -1, x240, p240, "Shooting H4", color.red, false)

[sigCur, pCurSig, pocCur, vahCur, valCur, xCur] = f_hs_calc(wyckCur)
newCur = sigCur != 0 and xCur != xCur[1]
f_plot_sig(show and newCur and sigCur == 1, xCur, pCurSig, "Hammer " + timeframe.period, color.lime, true)
f_plot_sig(show and newCur and sigCur == -1, xCur, pCurSig, "Shooting " + timeframe.period, color.red, false)

[rawCur, _, pocCurSec, vahCurSec, valCurSec, _] = f_hs_raw(timeframe.period, wyckCur)
pocStable = barstate.isconfirmed ? pocCurSec : pocCurSec[1]
vahStable = barstate.isconfirmed ? vahCurSec : vahCurSec[1]
valStable = barstate.isconfirmed ? valCurSec : valCurSec[1]
plot(vpShowLines and vpFilterEnabled ? pocStable : na, "POC", color=color.new(color.aqua, 0), linewidth=2)
plot(vpShowLines and vpFilterEnabled ? vahStable : na, "VAH", color=color.new(color.purple, 0), linewidth=1)
plot(vpShowLines and vpFilterEnabled ? valStable : na, "VAL", color=color.new(color.orange, 0), linewidth=1)

alertcondition(sendAlerts and new15 and sig15 == 1, "Hammer M15", "Hammer M15 on {{ticker}}")
alertcondition(sendAlerts and new15 and sig15 == -1, "Shooting M15", "Shooting M15 on {{ticker}}")
alertcondition(sendAlerts and new30 and sig30 == 1, "Hammer M30", "Hammer M30 on {{ticker}}")
alertcondition(sendAlerts and new30 and sig30 == -1, "Shooting M30", "Shooting M30 on {{ticker}}")
alertcondition(sendAlerts and new60 and sig60 == 1, "Hammer H1", "Hammer H1 on {{ticker}}")
alertcondition(sendAlerts and new60 and sig60 == -1, "Shooting H1", "Shooting H1 on {{ticker}}")
alertcondition(sendAlerts and new240 and sig240 == 1, "Hammer H4", "Hammer H4 on {{ticker}}")
alertcondition(sendAlerts and new240 and sig240 == -1, "Shooting H4", "Shooting H4 on {{ticker}}")
alertcondition(sendAlerts and newCur and sigCur == 1, "Hammer Current TF", "Hammer on {{ticker}} {{interval}}")
alertcondition(sendAlerts and newCur and sigCur == -1, "Shooting Current TF", "Shooting on {{ticker}} {{interval}}")
