                line s = line.new(array.get(qIndex, sz - 2), array.get(qValue, sz - 2) - ATR / 2, array.get(qIndex, sz - 1) + mv, array.get(qValue, sz - 2) - ATR / 2, xloc=xloc.bar_index, color=color.rgb(170, 29, 29), width=1, style=line.style_dotted)
                line t1 = line.new(array.get(qIndex, sz - 3), array.get(qValue, sz - 3), array.get(qIndex, sz - 1) + mv, array.get(qValue, sz - 3), xloc=xloc.bar_index, color=color.rgb(91, 172, 74), width=1, style=line.style_dotted)
                line t2 = line.new(array.get(qIndex, sz - 1), array.get(qValue, sz - 1), array.get(qIndex, sz - 1) + mv, array.get(qValue, sz - 1), xloc=xloc.bar_index, color=color.rgb(91, 172, 74), width=1, style=line.style_dotted)
                array.push(qmLines, e)
