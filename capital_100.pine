//@version=5
indicator("Matteo Capital - Box Session & Signals Final FIXED V3", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=500, max_polylines_count=100, max_bars_back=5000)

// --- INPUT ---
showSessions = input.bool(false, "Mostra Box Sessioni (Asia, London, NY)")
showSessionNames = input.bool(true, "Mostra Nomi Sessioni (Asia, London, NY)")
showDailyHL  = input.bool(true, "Mostra Daily High/Low")
showDailyOpen = input.bool(false, "Mostra Daily Open (line viola)")
showNYOpen   = input.bool(true, "Mostra NY Open (14:30)")
showA2NRange = input.bool(true, "Mostra Range 00:00→NY (Max/Min)")
showMidnightLines = input.bool(true, "Mostra Linee 00:00 (High/Low)")
show02CandleLines = input.bool(true, "Mostra Linee 02:00 (High/Low)")
showAsiaBiasArrow = input.bool(true, "Freccia Asia @09:00")
useAsiaLondonSell13 = input.bool(true, "Sell @13 se Asia+02 sopra London")
hsEnabled = input.bool(true, "Hammer & Shooting")
hsFibLevel = input.float(defval=0.382, title="Hammer Fib Level", options=[0.236, 0.382, 0.5])
hsConfirm = input.bool(defval=true, title="Hammer Confirm next candle")
hsShowLabels = input.bool(defval=true, title="Hammer Show labels")
hsFibRetraceEnabled = input.bool(true, "Hammer Fib Retrace (0.5/0.382)")
hsFibUse05 = input.bool(true, "Fib 0.5")
hsFibUse0382 = input.bool(true, "Fib 0.382")

useDailyOpenFilter     = input.bool(true, "Filtro Daily Open (Midnight)")
useIbMidFilter         = input.bool(true, "Filtro IB Mid")
requireManipulation    = input.bool(false, "Richiedi Manipolazione (Sweep)")
sweepBufferTicks       = input.int(0, "Sweep buffer (ticks)", minval=0)
reclaimMaxBars         = input.int(6, "Reclaim max bars", minval=1)
midnightSignalsEnabled = input.bool(true, "Segnali Midnight (Sweep & Reclaim)")

retestToleranceTicks = input.int(5, "Tolleranza Bacio (Ticks)", minval=0, group="Logica Matteo Capital")
requireSweepBeforeKiss = input.bool(true, "Richiedi Sweep prima del Bacio", group="Logica Matteo Capital")
sweepOutsideKillzone = input.bool(false, "Sweep fuori Killzone", group="Logica Matteo Capital")
kissOutsideKillzone = input.bool(false, "KISS fuori Killzone", group="Logica Matteo Capital")
kissSignalsEnabled = input.bool(true, "Segnali KISS (BUY/SELL)", group="Logica Matteo Capital")
buySellSignalsEnabled = input.bool(true, "Segnali BUY/SELL", group="Logica Matteo Capital")

luxEnabled = input.bool(true, "Swing Patterns Lux", group="Lux Swing")
luxLen = input.int(21, "Length", minval=1, group="Lux Swing")
luxShowLabels = input.bool(true, "Show Labels", group="Lux Swing")
luxSwingHColor = input.color(color.red, "Swing High", group="Lux Swing")
luxSwingLColor = input.color(color.teal, "Swing Low", group="Lux Swing")
luxNotifyEnabled = input.bool(true, "Notifiche Lux (alert)", group="Lux Swing")
luxNotifySwings = input.bool(true, "Notifica Swing HH/HL", group="Lux Swing")
luxNotifyPatterns = input.bool(true, "Notifica Candle Patterns", group="Lux Swing")
luxNotifyHammer = input.bool(true, "Hammer", group="Lux Swing")
luxNotifyInvertedHammer = input.bool(true, "Inverted Hammer", group="Lux Swing")
luxNotifyBullishEngulfing = input.bool(true, "Bullish Engulfing", group="Lux Swing")
luxNotifyHangingMan = input.bool(true, "Hanging Man", group="Lux Swing")
luxNotifyShootingStar = input.bool(true, "Shooting Star", group="Lux Swing")
luxNotifyBearishEngulfing = input.bool(true, "Bearish Engulfing", group="Lux Swing")
luxNotifyNone = input.bool(true, "None", group="Lux Swing")

instEnabled = input.bool(true, "Sweep institutional", group="Sweep institutional")
instCooldownPeriod = input.int(10, title="Cooldown Period", minval=0, group="Sweep institutional")
instShowSwing = input.bool(true, title="Show Swings?", inline="s_1", group="Sweep institutional")
instSwingClr = input.color(color.new(color.black, 0), title="", inline="s_1", group="Sweep institutional")
instBullWidth = input.int(1, title="Line Width:", group="Sweep institutional Bullish")
instBullStyle = input.string("Dashed", title="Line Style:", options=["Solid", "Dotted", "Dashed"], group="Sweep institutional Bullish")
instBullColor = input.color(color.new(color.teal, 0), title="Bullish Color:", group="Sweep institutional Bullish")
instBearWidth = input.int(1, title="Line Width:", group="Sweep institutional Bearish")
instBearStyle = input.string("Dashed", title="Line Style:", options=["Solid", "Dotted", "Dashed"], group="Sweep institutional Bearish")
instBearColor = input.color(color.new(color.maroon, 0), title="Bearish Color:", group="Sweep institutional Bearish")

SmtEnabled = input.bool(false, "SMT", group="SMT")
SmtSymbol1 = input.symbol("TVC:DXY", "SMT Symbol 1", group="SMT")
SmtUseSymbol2 = input.bool(false, "Usa Symbol 2", group="SMT")
SmtSymbol2 = input.symbol("OANDA:EURUSD", "SMT Symbol 2", group="SMT")
SmtInverseOn = input.string("Nessuno", "Inversione", options=["Nessuno", "Symbol 1", "Symbol 2"], group="SMT")
SmtUseTfPivots = input.bool(true, "Usa pivot per TF (M1/M15/H1/H4)", group="SMT")
SmtPivotLen_M1 = input.int(1, "M1 - Pivot candele", minval=1, group="SMT")
SmtPivotLen_M15 = input.int(1, "M15 - Pivot candele", minval=1, group="SMT")
SmtPivotLen_H1 = input.int(1, "H1 - Pivot candele", minval=1, group="SMT")
SmtPivotLen_H4 = input.int(1, "H4 - Pivot candele", minval=1, group="SMT")
SmtPivotLen = input.int(1, "Pivot candele (fallback)", minval=1, group="SMT")
SmtShowLabels = input.bool(true, "Mostra etichette", group="SMT")
SmtShowDailyExtreme = input.bool(false, "Mostra SMT vicino a Daily High/Low", group="SMT")
SmtDailyExtremeBufferTicks = input.int(0, "Distanza max SMT da Daily High/Low (ticks)", minval=0, group="SMT")

dashEnabled = input.bool(true, "Dashboard SH/SL (H1/H4)", group="Dashboard")
dashPos = input.string("Top Right", "Posizione", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group="Dashboard")
dashTextSize = input.string("Small", "Testo", options=["Tiny", "Small", "Normal"], group="Dashboard")

alertsEnabled = input.bool(true, "Alert (Any alert() function call)", group="Alert")

labelAutoStack = input.bool(true, "Evita sovrapposizioni (auto)", group="Layout")
labelStackTicks = input.int(10, "Spaziatura segnali (ticks)", minval=0, group="Layout")

vpEnabled = input.bool(false, "Volume Profile (Asia→NY)", group="Volume Profile")
vpBinTicks = input.int(10, "Bin size (ticks)", minval=1, group="Volume Profile")
vpMaxBinsDraw = input.int(80, "Max bins disegnati", minval=10, maxval=300, group="Volume Profile")
vpWidthBars = input.int(30, "Larghezza max (barre)", minval=5, maxval=200, group="Volume Profile")
vpValueAreaPct = input.int(70, "Value Area %", minval=50, maxval=95, group="Volume Profile")
vpShowPoc = input.bool(true, "Mostra POC", group="Volume Profile")
vpShowVa = input.bool(true, "Mostra Value Area", group="Volume Profile")
vpColor = input.color(color.new(color.blue, 70), "Colore", group="Volume Profile")
vpVaColor = input.color(color.new(color.orange, 70), "Colore Value Area", group="Volume Profile")
vpPocColor = input.color(color.new(color.white, 0), "Colore POC", group="Volume Profile")

rsiCrossEnabled = input.bool(false, "Incrocio RSI vs RSI-MA", group="RSI Cross")
rsiCrossShowLabels = input.bool(true, "Mostra etichette", group="RSI Cross")
rsiCrossMaType = input.string("SMA", "Tipo MA", options=["SMA", "EMA"], group="RSI Cross")
