alertcondition((not onlyDoubleSMT) and not na(ph) and sym3 != "" and (inv3 ? (ph>lastPH3)==(sH3>slastPH3) : (ph>lastPH3)!=(sH3>slastPH3)), "Bearish SMT - Sym 3", "Bearish SMT Divergence detected!")
alertcondition((not onlyDoubleSMT) and not na(pl) and sym3 != "" and (inv3 ? (pl<lastPL3)==(sL3<slastPL3) : (pl<lastPL3)!=(sL3<slastPL3)), "Bullish SMT - Sym 3", "Bullish SMT Divergence detected!")

