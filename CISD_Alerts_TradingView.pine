//@version=6
indicator("CISD + Hammer/Shooting + VP Filters (MT5 parity)", "CISD+HS+VP", overlay=true, max_lines_count=500, max_labels_count=500)

bullishBreakColor = input.color(color.rgb(50, 205, 50), "Bull CISD", inline="bup")
bearishBreakColor = input.color(color.rgb(255, 0, 0), "Bear CISD", inline="bep")
bullStr = input.string("+CISD", " ", inline="bup")
bearStr = input.string("-CISD", " ", inline="bep")
lineWidth = input.int(1, "Line Width", minval=1, maxval=5)
lookAheadBars = input.int(5, "Line Extension Bars", minval=1, maxval=50)
styleOption = input.string("Solid", "Line Style", options=["Solid", "Dotted", "Dashed"])
keepLevels = input.bool(false, "Keep old CISD levels")

sendAlerts = input.bool(true, "Enable alerts", group="Alerts")
plotHistory = input.bool(true, "Plot history", group="Alerts")

enableHs = input.bool(true, "Enable Hammer/Shooting", group="Hammer/Shooting")
fibLevel = input.float(0.382, "Fibonacci Level", options=[0.236, 0.382, 0.5], group="Hammer/Shooting")
proCandleFilterEnabled = input.bool(true, "Pro Candle filter", group="Hammer/Shooting")
proWickBodyMinRatio = input.float(2.0, "Min wick/body ratio", minval=1.0, step=0.1, group="Hammer/Shooting")
proOppWickMaxBodyRatio = input.float(0.3, "Max opposite wick/body ratio", minval=0.0, step=0.1, group="Hammer/Shooting")
confirmByNext = input.bool(true, "Confirm by next candle", group="Hammer/Shooting")
confirmWithDxy = input.bool(false, "Confirm with DXY", group="Hammer/Shooting")
dxySymbol = input.string("DXY.cash", "DXY Symbol", group="Hammer/Shooting")
wyckSpikeFilterEnabled = input.bool(false, "Wyck spike filter", group="Hammer/Shooting")
wyckSpikeMinPoints = input.int(600, "Wyck min points (default)", minval=1, group="Hammer/Shooting")
wyckSpikeMinPointsCur = input.int(0, "Wyck min points (Current TF, 0=default)", minval=0, group="Hammer/Shooting")
wyckSpikeMinPointsM15 = input.int(0, "Wyck min points (M15, 0=default)", minval=0, group="Hammer/Shooting")
wyckSpikeMinPointsM30 = input.int(0, "Wyck min points (M30, 0=default)", minval=0, group="Hammer/Shooting")
wyckSpikeMinPointsH1 = input.int(0, "Wyck min points (H1, 0=default)", minval=0, group="Hammer/Shooting")
wyckSpikeMinPointsH4 = input.int(0, "Wyck min points (H4, 0=default)", minval=0, group="Hammer/Shooting")
smtVolFilterEnabled = input.bool(false, "Volume filter (VL)", group="Hammer/Shooting")
smtVolMaLen = input.int(20, "VL MA len", minval=1, group="Hammer/Shooting")
smtVolMult = input.float(1.5, "VL mult", minval=0.1, step=0.1, group="Hammer/Shooting")
smtFilterEnabled = input.bool(false, "SMT filter (DXY inverse + XAG direct)", group="Hammer/Shooting")
smtXagSymbol = input.string("XAGUSD", "XAGUSD Symbol", group="Hammer/Shooting")
smtPivotLeft = input.int(3, "SMT pivot left", minval=1, group="Hammer/Shooting")
smtPivotRight = input.int(3, "SMT pivot right", minval=1, group="Hammer/Shooting")
smtPlotDxyInv = input.bool(true, "Plot DXY inverted", group="Hammer/Shooting")
smtNormLen = input.int(200, "DXY inv normalize len", minval=20, group="Hammer/Shooting")
hsMultiTimeframe = input.bool(false, "Multi-timeframe", group="Hammer/Shooting TF")

hsEnableM15 = input.bool(false, "M15", inline="tf", group="Hammer/Shooting TF")
hsEnableM30 = input.bool(false, "M30", inline="tf", group="Hammer/Shooting TF")
hsEnableH1  = input.bool(false, "H1", inline="tf", group="Hammer/Shooting TF")
hsEnableH4  = input.bool(true, "H4", inline="tf", group="Hammer/Shooting TF")

hsTrendFilterEnabled = input.bool(false, "Strong trend filter", group="Trend Filter")
hsTrendEmaFast = input.int(10, "EMA fast", minval=1, group="Trend Filter")
hsTrendEmaSlow = input.int(60, "EMA slow", minval=2, group="Trend Filter")
hsTrendAtrPeriod = input.int(14, "ATR period", minval=1, group="Trend Filter")
hsTrendAtrMult = input.float(0.5, "ATR mult", minval=0.0, step=0.1, group="Trend Filter")
showEma = input.bool(true, "Show EMA", group="Trend Filter")
emaFastColor = input.color(color.new(color.lime, 0), "EMA fast color", group="Trend Filter")
emaSlowColor = input.color(color.new(color.orange, 0), "EMA slow color", group="Trend Filter")
emaTouchTagEnabled = input.bool(true, "EMA touch tag", group="Trend Filter")
emaTouchTolTicks = input.int(0, "EMA touch tolerance (ticks)", minval=0, group="Trend Filter")

vpFilterEnabled = input.bool(false, "VP filter", group="Volume Profile")
vpBodyZoneFilter = input.bool(false, "Body zone filter (VAL-POC / POC-VAH)", group="Volume Profile")
vpRows = input.int(30, "VP rows", minval=10, maxval=200, group="Volume Profile")
vpValueAreaPercent = input.int(70, "Value Area %", minval=50, maxval=95, group="Volume Profile")
vpAnchorAsia = input.bool(false, "Anchor from Asia open", group="Volume Profile")
vpAsiaOpenHour = input.int(0, "Asia open hour", minval=0, maxval=23, group="Volume Profile")
vpTz = input.string("Etc/UTC", "Timezone", group="Volume Profile")
vpMaxBars = input.int(600, "Max bars since Asia", minval=50, maxval=2000, group="Volume Profile")
vpFixedLookback = input.int(100, "Fixed lookback (if not Asia)", minval=10, maxval=2000, group="Volume Profile")
vpShowLines = input.bool(false, "Show POC/VAH/VAL", group="Volume Profile")

lineStyle = styleOption == "Dotted" ? line.style_dotted : styleOption == "Dashed" ? line.style_dashed : line.style_solid

emaFastPlot = ta.ema(close, hsTrendEmaFast)
emaSlowPlot = ta.ema(close, hsTrendEmaSlow)
plot(showEma ? emaFastPlot : na, "EMA Fast", color=emaFastColor, linewidth=2)
plot(showEma ? emaSlowPlot : na, "EMA Slow", color=emaSlowColor, linewidth=2)

f_body_touches_ema(_o, _c, _ema1, _ema2) =>
    tol = emaTouchTolTicks * syminfo.mintick
    lo = math.min(_o, _c) - tol
    hi = math.max(_o, _c) + tol
    (_ema1 >= lo and _ema1 <= hi) or (_ema2 >= lo and _ema2 <= hi)

type MarketStructure
    float topPrice
    float bottomPrice
    bool isBullish

type cisd
    line level
    label txt
    bool completed

var MarketStructure currentStructure = MarketStructure.new(0, 0, false)
var cisdLevelsBu = array.new<cisd>()
var cisdLevelsBe = array.new<cisd>()
var bool isBullishPullback = false
var bool isBearishPullback = false
var float potentialTopPrice = na
var float potentialBottomPrice = na
var int bullishBreakIndex = na
var int bearishBreakIndex = na
var bool currentState = false

bearishPullbackDetected = close[1] > open[1]
bullishPullbackDetected = close[1] < open[1]

if bearishPullbackDetected and not isBearishPullback
    isBearishPullback := true
    potentialTopPrice := open[1]
    bullishBreakIndex := bar_index[1]

if bullishPullbackDetected and not isBullishPullback
    isBullishPullback := true
    potentialBottomPrice := open[1]
    bearishBreakIndex := bar_index[1]

if isBullishPullback
    if open < potentialBottomPrice
        potentialBottomPrice := open
        bearishBreakIndex := bar_index
    if (close < open) and (open > potentialBottomPrice)
        potentialBottomPrice := open
        bearishBreakIndex := bar_index

if isBearishPullback
    if open > potentialTopPrice
        potentialTopPrice := open
        bullishBreakIndex := bar_index
    if (close > open) and open < potentialTopPrice
        potentialTopPrice := open
        bullishBreakIndex := bar_index

if low < currentStructure.bottomPrice
    currentStructure.bottomPrice := low
    currentStructure.isBullish := false
    if isBearishPullback and (bar_index - bullishBreakIndex != 0)
        currentStructure.topPrice := math.max(high[bar_index - bullishBreakIndex], high[bar_index - bullishBreakIndex + 1])
        isBearishPullback := false
        bearishLine = line.new(bullishBreakIndex, potentialTopPrice, bar_index + lookAheadBars, potentialTopPrice, color=bullishBreakColor, width=lineWidth, style=lineStyle)
        bearishLabel = label.new(bar_index + lookAheadBars, potentialTopPrice, bullStr, color=color.new(color.white, 100), textcolor=bullishBreakColor, style=label.style_label_left, size=size.small)
        b = cisd.new(bearishLine, bearishLabel, false)
        cisdLevelsBe.push(b)
    else if close[1] > open[1] and close < open
        currentStructure.topPrice := high[1]
        isBearishPullback := false
        bearishLine = line.new(bullishBreakIndex, potentialTopPrice, bar_index + lookAheadBars, potentialTopPrice, color=bullishBreakColor, width=lineWidth, style=lineStyle)
        bearishLabel = label.new(bar_index + lookAheadBars, potentialTopPrice, bullStr, color=color.new(color.white, 100), textcolor=bullishBreakColor, style=label.style_label_left, size=size.small)
        b = cisd.new(bearishLine, bearishLabel, false)
        cisdLevelsBe.push(b)

if high > currentStructure.topPrice
    currentStructure.isBullish := true
    currentStructure.topPrice := high
    if isBullishPullback and (bar_index - bearishBreakIndex != 0)
        currentStructure.bottomPrice := math.min(low[bar_index - bearishBreakIndex], low[bar_index - bearishBreakIndex + 1])
        isBullishPullback := false
        bullishLine = line.new(bearishBreakIndex, potentialBottomPrice, bar_index + lookAheadBars, potentialBottomPrice, color=bearishBreakColor, width=lineWidth, style=lineStyle)
        bullishLabel = label.new(bar_index + lookAheadBars, potentialBottomPrice, bearStr, color=color.new(color.white, 100), textcolor=bearishBreakColor, style=label.style_label_left, size=size.small)
        bu = cisd.new(bullishLine, bullishLabel, false)
        cisdLevelsBu.push(bu)
    else if close[1] < open[1] and close > open
        currentStructure.bottomPrice := low[1]
        isBullishPullback := false
        bullishLine = line.new(bearishBreakIndex, potentialBottomPrice, bar_index + lookAheadBars, potentialBottomPrice, color=bearishBreakColor, width=lineWidth, style=lineStyle)
        bullishLabel = label.new(bar_index + lookAheadBars, potentialBottomPrice, bearStr, color=color.new(color.white, 100), textcolor=bearishBreakColor, style=label.style_label_left, size=size.small)
        bu = cisd.new(bullishLine, bullishLabel, false)
        cisdLevelsBu.push(bu)

if array.size(cisdLevelsBu) > 1 and not keepLevels
    latest = array.shift(cisdLevelsBu)
    line.delete(latest.level)
    label.delete(latest.txt)

if array.size(cisdLevelsBe) > 1 and not keepLevels
    latest = array.shift(cisdLevelsBe)
    line.delete(latest.level)
    label.delete(latest.txt)

var bool bearCisdFormed = false
var bool bullCisdFormed = false
bearCisdFormed := false
bullCisdFormed := false

if array.size(cisdLevelsBu) >= 1
    latest = array.get(cisdLevelsBu, 0)
    if not (close < latest.level.get_y2()) and not latest.completed
        line.set_x2(latest.level, bar_index + lookAheadBars)
        label.set_x(latest.txt, bar_index + lookAheadBars)
    if close < latest.level.get_y2() and not latest.completed
        latest.completed := true
        bearCisdFormed := true
        currentState := false

if array.size(cisdLevelsBe) >= 1 and not keepLevels
    latest = array.get(cisdLevelsBe, 0)
    if not (close > latest.level.get_y2()) and not latest.completed
        line.set_x2(latest.level, bar_index + lookAheadBars)
        label.set_x(latest.txt, bar_index + lookAheadBars)
    if close > latest.level.get_y2() and not latest.completed
        latest.completed := true
        bullCisdFormed := true
        currentState := true

alertcondition(sendAlerts and bearCisdFormed, "Bearish CISD Formed", "Bearish CISD Formed on {{ticker}} {{interval}}")
alertcondition(sendAlerts and bullCisdFormed, "Bullish CISD Formed", "Bullish CISD Formed on {{ticker}} {{interval}}")

f_is_hammer(_o, _h, _l, _c) =>
    cs = math.abs(_h - _l)
    body = math.abs(_c - _o)
    bodyMin = math.min(_o, _c)
    bodyMax = math.max(_o, _c)
    lowerW = bodyMin - _l
    upperW = _h - bodyMax
    baseOk = cs > 0 and _h - fibLevel * cs < bodyMin
    proOk = (not proCandleFilterEnabled) or (body > 0 and lowerW >= body * proWickBodyMinRatio and upperW <= body * proOppWickMaxBodyRatio)
    baseOk and proOk

f_is_shoot(_o, _h, _l, _c) =>
    cs = math.abs(_h - _l)
    body = math.abs(_c - _o)
    bodyMin = math.min(_o, _c)
    bodyMax = math.max(_o, _c)
    lowerW = bodyMin - _l
    upperW = _h - bodyMax
    baseOk = cs > 0 and _l + fibLevel * cs > bodyMax
    proOk = (not proCandleFilterEnabled) or (body > 0 and upperW >= body * proWickBodyMinRatio and lowerW <= body * proOppWickMaxBodyRatio)
    baseOk and proOk

f_pl(_l, _r, _occ) =>
    p = ta.pivotlow(low, _l, _r)
    ta.valuewhen(not na(p), p, _occ)

f_ph(_l, _r, _occ) =>
    p = ta.pivothigh(high, _l, _r)
    ta.valuewhen(not na(p), p, _occ)

f_pl_dxy_inv(_l, _r, _occ) =>
    p = ta.pivotlow(-high, _l, _r)
    ta.valuewhen(not na(p), p, _occ)

f_ph_dxy_inv(_l, _r, _occ) =>
    p = ta.pivothigh(-low, _l, _r)
    ta.valuewhen(not na(p), p, _occ)

f_pivots_pack(_low, _high, _l, _r) =>
    pl = ta.pivotlow(_low, _l, _r)
    ph = ta.pivothigh(_high, _l, _r)
    pl0 = ta.valuewhen(not na(pl), pl, 0)
    pl1 = ta.valuewhen(not na(pl), pl, 1)
    ph0 = ta.valuewhen(not na(ph), ph, 0)
    ph1 = ta.valuewhen(not na(ph), ph, 1)
    [pl0, pl1, ph0, ph1]

f_dir_ll_hh(_low, _high, _l, _r) =>
    [pl0, pl1, ph0, ph1] = f_pivots_pack(_low, _high, _l, _r)
    ll = not na(pl0) and not na(pl1) and pl0 < pl1
    hh = not na(ph0) and not na(ph1) and ph0 > ph1
    ll ? 1 : hh ? -1 : 0

f_dir_no_ll_hh(_low, _high, _l, _r) =>
    [pl0, pl1, ph0, ph1] = f_pivots_pack(_low, _high, _l, _r)
    noLL = not na(pl0) and not na(pl1) and pl0 >= pl1
    noHH = not na(ph0) and not na(ph1) and ph0 <= ph1
    noLL ? 1 : noHH ? -1 : 0

f_xag_dir() =>
    f_dir_no_ll_hh(low, high, smtPivotLeft, smtPivotRight)

f_dxy_pack() =>
    delta = close - open
    dxyDir = f_dir_no_ll_hh(-high, -low, smtPivotLeft, smtPivotRight)
    [delta, dxyDir]

f_trend_flags(_c) =>
    ef = ta.ema(_c, hsTrendEmaFast)
    es = ta.ema(_c, hsTrendEmaSlow)
    a = ta.atr(hsTrendAtrPeriod)
    diff = ef - es
    thr = a * hsTrendAtrMult
    up = diff >= thr and _c > ef
    dn = (-diff) >= thr and _c < ef
    [up, dn]

f_asia_start() =>
    tz = str.length(vpTz) > 0 ? vpTz : syminfo.timezone
    h = hour(time, tz)
    m = minute(time, tz)
    h == vpAsiaOpenHour and m == 0

f_vp_len() =>
    if vpAnchorAsia
        bs = ta.barssince(f_asia_start())
        base = na(bs) ? (bar_index + 1) : (bs + 1)
        math.min(base, vpMaxBars)
    else
        vpFixedLookback

f_vp_levels(_len) =>
    bins = vpRows
    ln = int(math.max(1, _len))
    hi = ta.highest(high, ln)
    lo = ta.lowest(low, ln)
    rng = hi - lo
    float poc = na
    float vah = na
    float val = na
    if rng > 0 and ln >= 10
        rowH = rng / bins
        vols = array.new_float(bins, 0.0)
        for i = 0 to ln - 1
            bh = high[i]
            bl = low[i]
            bv = volume[i]
            sv = bv <= 0 ? 1 : bv
            s = int(math.floor((bl - lo) / rowH))
            e = int(math.floor((bh - lo) / rowH))
            s := math.max(0, s)
            e := math.min(bins - 1, e)
            cnt = e - s + 1
            if cnt > 0
                vpl = sv / cnt
                for j = s to e
                    array.set(vols, j, array.get(vols, j) + vpl)
        tot = 0.0
        maxV = array.get(vols, 0)
        pocI = 0
        for i = 0 to bins - 1
            v = array.get(vols, i)
            tot += v
            if v > maxV
                maxV := v
                pocI := i
        if tot > 0
            target = tot * (vpValueAreaPercent / 100.0)
            acc = array.get(vols, pocI)
            vahI = pocI
            valI = pocI
            while acc < target
                canUp = vahI < bins - 1
                canDn = valI > 0
                upV = canUp ? array.get(vols, vahI + 1) : 0.0
                dnV = canDn ? array.get(vols, valI - 1) : 0.0
                if canUp and (not canDn or upV >= dnV)
                    acc += upV
                    vahI += 1
                else
                    if canDn
                        acc += dnV
                        valI -= 1
                    else
                        break
            poc := lo + (pocI + 0.5) * rowH
            vah := lo + (vahI + 1.0) * rowH
            val := lo + (valI + 0.0) * rowH
    [poc, vah, val]

f_hs_calc(_wyckMinPoints) =>
    if not enableHs
        [0, na, na, na, na, na, false]
    else
        _len = f_vp_len()
        [poc, vah, val] = f_vp_levels(_len)
        [up, dn] = f_trend_flags(close)
        sigIdx = confirmByNext ? 1 : 0
        confOkHammer = confirmByNext ? (close > math.max(open[1], close[1])) : true
        confOkShoot = confirmByNext ? (close < math.min(open[1], close[1])) : true
        hammer = f_is_hammer(open[sigIdx], high[sigIdx], low[sigIdx], close[sigIdx]) and (not confirmByNext or (close > open and confOkHammer))
        shoot = f_is_shoot(open[sigIdx], high[sigIdx], low[sigIdx], close[sigIdx]) and (not confirmByNext or (close < open and confOkShoot))
        volMa = ta.sma(volume, smtVolMaLen)
        volOk = not na(volMa[sigIdx]) and volume[sigIdx] >= volMa[sigIdx] * smtVolMult
        if smtVolFilterEnabled
            hammer := hammer and volOk
            shoot := shoot and volOk and close[sigIdx] > open[sigIdx]
        if wyckSpikeFilterEnabled
            minPts = _wyckMinPoints > 0 ? _wyckMinPoints : wyckSpikeMinPoints
            rangePts = (high[sigIdx] - low[sigIdx]) / syminfo.mintick
            hammer := hammer and rangePts >= minPts
            shoot := shoot and rangePts >= minPts
        if hsTrendFilterEnabled
            hammer := hammer and dn
            shoot := shoot and up
        if vpFilterEnabled and not na(poc) and not na(vah) and not na(val)
            if hammer
                hammer := (low[sigIdx] < val) and (close[sigIdx] > val) and (close[sigIdx] < vah)
                if vpBodyZoneFilter
                    bmin = math.min(open[sigIdx], close[sigIdx])
                    bmax = math.max(open[sigIdx], close[sigIdx])
                    hammer := hammer and (bmin >= val) and (bmax <= poc)
            if shoot
                shoot := (high[sigIdx] > vah) and (close[sigIdx] < vah) and (close[sigIdx] > val)
                if vpBodyZoneFilter
                    bmin = math.min(open[sigIdx], close[sigIdx])
                    bmax = math.max(open[sigIdx], close[sigIdx])
                    shoot := shoot and (bmin >= poc) and (bmax <= vah)
        sig = barstate.isconfirmed ? (hammer ? 1 : shoot ? -1 : 0) : 0
        price = sig == 1 ? low[sigIdx] : sig == -1 ? high[sigIdx] : na
        sigTime = time_close
        emaTouch = emaTouchTagEnabled and f_body_touches_ema(open[sigIdx], close[sigIdx], emaFastPlot[sigIdx], emaSlowPlot[sigIdx])
        [sig, price, poc, vah, val, sigTime, emaTouch]

f_hs_sig(_wyckMinPoints) =>
    if not enableHs
        0
    else
        _len = f_vp_len()
        [poc, vah, val] = f_vp_levels(_len)
        [up, dn] = f_trend_flags(close)
        sigIdx = confirmByNext ? 1 : 0
        confOkHammer = confirmByNext ? (close > math.max(open[1], close[1])) : true
        confOkShoot = confirmByNext ? (close < math.min(open[1], close[1])) : true
        hammer = f_is_hammer(open[sigIdx], high[sigIdx], low[sigIdx], close[sigIdx]) and (not confirmByNext or (close > open and confOkHammer))
        shoot = f_is_shoot(open[sigIdx], high[sigIdx], low[sigIdx], close[sigIdx]) and (not confirmByNext or (close < open and confOkShoot))
        volMa = ta.sma(volume, smtVolMaLen)
        volOk = not na(volMa[sigIdx]) and volume[sigIdx] >= volMa[sigIdx] * smtVolMult
        if smtVolFilterEnabled
            hammer := hammer and volOk
            shoot := shoot and volOk and close[sigIdx] > open[sigIdx]
        if wyckSpikeFilterEnabled
            minPts = _wyckMinPoints > 0 ? _wyckMinPoints : wyckSpikeMinPoints
            rangePts = (high[sigIdx] - low[sigIdx]) / syminfo.mintick
            hammer := hammer and rangePts >= minPts
            shoot := shoot and rangePts >= minPts
        if hsTrendFilterEnabled
            hammer := hammer and dn
            shoot := shoot and up
        if vpFilterEnabled and not na(poc) and not na(vah) and not na(val)
            if hammer
                hammer := (low[sigIdx] < val) and (close[sigIdx] > val) and (close[sigIdx] < vah)
                if vpBodyZoneFilter
                    bmin = math.min(open[sigIdx], close[sigIdx])
                    bmax = math.max(open[sigIdx], close[sigIdx])
                    hammer := hammer and (bmin >= val) and (bmax <= poc)
            if shoot
                shoot := (high[sigIdx] > vah) and (close[sigIdx] < vah) and (close[sigIdx] > val)
                if vpBodyZoneFilter
                    bmin = math.min(open[sigIdx], close[sigIdx])
                    bmax = math.max(open[sigIdx], close[sigIdx])
                    shoot := shoot and (bmin >= poc) and (bmax <= vah)
        emaF = ta.ema(close, hsTrendEmaFast)
        emaS = ta.ema(close, hsTrendEmaSlow)
        emaTouch = emaTouchTagEnabled and f_body_touches_ema(open[sigIdx], close[sigIdx], emaF[sigIdx], emaS[sigIdx])
        barstate.isconfirmed ? (hammer ? (emaTouch ? 2 : 1) : shoot ? (emaTouch ? -2 : -1) : 0) : 0

isXau = str.contains(syminfo.ticker, "XAU")

show = plotHistory or barstate.isrealtime
vlSuffix = smtVolFilterEnabled ? " VL" : ""
smtSuffix = smtFilterEnabled and isXau ? " +SMT" : ""

f_plot_sig(_cond, _x, _price, _txt, _clr, _isUp) =>
    if _cond and not na(_price)
        label.new(x=_x, y=_price, text=_txt, xloc=xloc.bar_time, yloc=yloc.price, style=_isUp ? label.style_label_up : label.style_label_down, textcolor=_clr, color=color.new(color.white, 100), size=size.tiny)

f_smt_ok(_sig, _xauDir, _xagDir, _dxyDir) =>
    if not smtFilterEnabled or not isXau or _sig == 0
        true
    else
        _sig == 1 ? (_xauDir == 1 and _xagDir == 1 and _dxyDir == 1) : (_xauDir == -1 and _xagDir == -1 and _dxyDir == -1)

wyckCur = wyckSpikeMinPointsCur > 0 ? wyckSpikeMinPointsCur : wyckSpikeMinPoints
wyckM15 = wyckSpikeMinPointsM15 > 0 ? wyckSpikeMinPointsM15 : wyckSpikeMinPoints
wyckM30 = wyckSpikeMinPointsM30 > 0 ? wyckSpikeMinPointsM30 : wyckSpikeMinPoints
wyckH1 = wyckSpikeMinPointsH1 > 0 ? wyckSpikeMinPointsH1 : wyckSpikeMinPoints
wyckH4 = wyckSpikeMinPointsH4 > 0 ? wyckSpikeMinPointsH4 : wyckSpikeMinPoints

sig15 = 0
sig30 = 0
sig60 = 0
sig240 = 0
new15 = false
new30 = false
new60 = false
new240 = false
if hsMultiTimeframe
    if hsEnableM15
        sig15 := request.security(syminfo.tickerid, "15", f_hs_sig(wyckM15), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
        t15 = request.security(syminfo.tickerid, "15", time_close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
        new15 := t15 != t15[1]
    if hsEnableM30
        sig30 := request.security(syminfo.tickerid, "30", f_hs_sig(wyckM30), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
        t30 = request.security(syminfo.tickerid, "30", time_close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
        new30 := t30 != t30[1]
    if hsEnableH1
        sig60 := request.security(syminfo.tickerid, "60", f_hs_sig(wyckH1), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
        t60 = request.security(syminfo.tickerid, "60", time_close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
        new60 := t60 != t60[1]
    if hsEnableH4
        sig240 := request.security(syminfo.tickerid, "240", f_hs_sig(wyckH4), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
        t240 = request.security(syminfo.tickerid, "240", time_close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
        new240 := t240 != t240[1]

plotshape(show and new15 and sig15 == 2, title="Hammer M15 EMA", style=shape.arrowup, location=location.belowbar, color=color.lime, size=size.tiny, text="Hammer EMA")
plotshape(show and new15 and sig15 == 1, title="Hammer M15", style=shape.arrowup, location=location.belowbar, color=color.lime, size=size.tiny, text="Hammer")
plotshape(show and new15 and sig15 == -2, title="Shooting M15 EMA", style=shape.arrowdown, location=location.abovebar, color=color.red, size=size.tiny, text="Shooting EMA")
plotshape(show and new15 and sig15 == -1, title="Shooting M15", style=shape.arrowdown, location=location.abovebar, color=color.red, size=size.tiny, text="Shooting")

plotshape(show and new30 and sig30 == 2, title="Hammer M30 EMA", style=shape.arrowup, location=location.belowbar, color=color.lime, size=size.tiny, text="Hammer EMA")
plotshape(show and new30 and sig30 == 1, title="Hammer M30", style=shape.arrowup, location=location.belowbar, color=color.lime, size=size.tiny, text="Hammer")
plotshape(show and new30 and sig30 == -2, title="Shooting M30 EMA", style=shape.arrowdown, location=location.abovebar, color=color.red, size=size.tiny, text="Shooting EMA")
plotshape(show and new30 and sig30 == -1, title="Shooting M30", style=shape.arrowdown, location=location.abovebar, color=color.red, size=size.tiny, text="Shooting")

plotshape(show and new60 and sig60 == 2, title="Hammer H1 EMA", style=shape.arrowup, location=location.belowbar, color=color.lime, size=size.tiny, text="Hammer EMA")
plotshape(show and new60 and sig60 == 1, title="Hammer H1", style=shape.arrowup, location=location.belowbar, color=color.lime, size=size.tiny, text="Hammer")
plotshape(show and new60 and sig60 == -2, title="Shooting H1 EMA", style=shape.arrowdown, location=location.abovebar, color=color.red, size=size.tiny, text="Shooting EMA")
plotshape(show and new60 and sig60 == -1, title="Shooting H1", style=shape.arrowdown, location=location.abovebar, color=color.red, size=size.tiny, text="Shooting")

plotshape(show and new240 and sig240 == 2, title="Hammer H4 EMA", style=shape.arrowup, location=location.belowbar, color=color.lime, size=size.tiny, text="Hammer EMA")
plotshape(show and new240 and sig240 == 1, title="Hammer H4", style=shape.arrowup, location=location.belowbar, color=color.lime, size=size.tiny, text="Hammer")
plotshape(show and new240 and sig240 == -2, title="Shooting H4 EMA", style=shape.arrowdown, location=location.abovebar, color=color.red, size=size.tiny, text="Shooting EMA")
plotshape(show and new240 and sig240 == -1, title="Shooting H4", style=shape.arrowdown, location=location.abovebar, color=color.red, size=size.tiny, text="Shooting")

[sigCur, pCurSig, pocCur, vahCur, valCur, xCur, emaTouchCur] = f_hs_calc(wyckCur)
xauDirCur = f_dir_ll_hh(low, high, smtPivotLeft, smtPivotRight)
xagDirCur = 0
dxyDirCur = 0
if smtFilterEnabled and isXau
    xagDirCur := request.security(smtXagSymbol, "", f_xag_dir(), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
    dxyDirCur := request.security(dxySymbol, "", f_dir_no_ll_hh(-high, -low, smtPivotLeft, smtPivotRight), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
smtOkCur = f_smt_ok(sigCur, xauDirCur, xagDirCur, dxyDirCur)
sigCurF = smtOkCur ? sigCur : 0
newCur = sigCurF != 0 and xCur != xCur[1]
plotshape(show and newCur and sigCurF == 1 and emaTouchCur, title="Hammer Current TF EMA", style=shape.arrowup, location=location.belowbar, color=color.lime, size=size.small, text="Hammer EMA")
plotshape(show and newCur and sigCurF == 1 and not emaTouchCur, title="Hammer Current TF", style=shape.arrowup, location=location.belowbar, color=color.lime, size=size.small, text="Hammer")
plotshape(show and newCur and sigCurF == -1 and emaTouchCur, title="Shooting Current TF EMA", style=shape.arrowdown, location=location.abovebar, color=color.red, size=size.small, text="Shooting EMA")
plotshape(show and newCur and sigCurF == -1 and not emaTouchCur, title="Shooting Current TF", style=shape.arrowdown, location=location.abovebar, color=color.red, size=size.small, text="Shooting")

pocStable = barstate.isconfirmed ? pocCur : pocCur[1]
vahStable = barstate.isconfirmed ? vahCur : vahCur[1]
valStable = barstate.isconfirmed ? valCur : valCur[1]
plot(vpShowLines and vpFilterEnabled ? pocStable : na, "POC", color=color.new(color.aqua, 0), linewidth=2)
plot(vpShowLines and vpFilterEnabled ? vahStable : na, "VAH", color=color.new(color.purple, 0), linewidth=1)
plot(vpShowLines and vpFilterEnabled ? valStable : na, "VAL", color=color.new(color.orange, 0), linewidth=1)

float dxyInvScaled = na
if smtPlotDxyInv and isXau
    dxyInvRaw = request.security(dxySymbol, "", -close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
    dxyInvLo = ta.lowest(dxyInvRaw, smtNormLen)
    dxyInvHi = ta.highest(dxyInvRaw, smtNormLen)
    xauLoN = ta.lowest(low, smtNormLen)
    xauHiN = ta.highest(high, smtNormLen)
    dxyInvScaled := na(dxyInvLo) or na(dxyInvHi) or dxyInvHi == dxyInvLo ? na : (xauLoN + (dxyInvRaw - dxyInvLo) / (dxyInvHi - dxyInvLo) * (xauHiN - xauLoN))
plot(dxyInvScaled, "DXY inverted (norm)", color=color.new(color.blue, 0), linewidth=1)

alertcondition(sendAlerts and hsMultiTimeframe and new15 and sig15 > 0, "Hammer M15", "Hammer M15 on {{ticker}}")
alertcondition(sendAlerts and hsMultiTimeframe and new15 and sig15 < 0, "Shooting M15", "Shooting M15 on {{ticker}}")
alertcondition(sendAlerts and hsMultiTimeframe and new30 and sig30 > 0, "Hammer M30", "Hammer M30 on {{ticker}}")
alertcondition(sendAlerts and hsMultiTimeframe and new30 and sig30 < 0, "Shooting M30", "Shooting M30 on {{ticker}}")
alertcondition(sendAlerts and hsMultiTimeframe and new60 and sig60 > 0, "Hammer H1", "Hammer H1 on {{ticker}}")
alertcondition(sendAlerts and hsMultiTimeframe and new60 and sig60 < 0, "Shooting H1", "Shooting H1 on {{ticker}}")
alertcondition(sendAlerts and hsMultiTimeframe and new240 and sig240 > 0, "Hammer H4", "Hammer H4 on {{ticker}}")
alertcondition(sendAlerts and hsMultiTimeframe and new240 and sig240 < 0, "Shooting H4", "Shooting H4 on {{ticker}}")
alertcondition(sendAlerts and newCur and sigCurF == 1, "Hammer Current TF", "Hammer on {{ticker}} {{interval}}")
alertcondition(sendAlerts and newCur and sigCurF == -1, "Shooting Current TF", "Shooting on {{ticker}} {{interval}}")
