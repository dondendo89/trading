crtShowLines = input.bool(true, "Mostra linee High/Low/EQ", group="CRT")
crtShowLabels = input.bool(true, "Mostra etichette", group="CRT")

sfpEnabled = input.bool(false, "Swing Failure Pattern (LuxAlgo)", group="SFP Lux")
sfpLen = input.int(5, "Swings", minval=1, group="SFP Lux")
sfpBull = input.bool(true, "Bullish SFP", group="SFP Lux")
sfpBear = input.bool(true, "Bearish SFP", group="SFP Lux")

sfpIVal = input.string("None", "Validation", group="SFP Lux - Volume Validation", options=["Volume outside swing < Threshold", "Volume outside swing > Threshold", "None"])
