sfpPrem = input.bool(false, "Premium", group="SFP Lux - Volume Validation")

sfpShowDash = input.bool(true, "Show Dashboard", group="SFP Lux - Dashboard")
sfpDashLoc = input.string("Top Right", "Location", options=["Top Right", "Bottom Right", "Bottom Left"], group="SFP Lux - Dashboard")
sfpTextSize = input.string("Normal", "Size", options=["Tiny", "Small", "Normal"], group="SFP Lux - Dashboard")

sfpSwingLine = input.bool(true, "Swing Lines", group="SFP Lux - Style")
sfpOpposLine = input.bool(true, "Confirmation Lines", group="SFP Lux - Style")
sfpSfpLine = input.bool(true, "Swing Failure Wick", group="SFP Lux - Style")
sfpSfpLabel = input.bool(true, "Swing Failure Label", group="SFP Lux - Style")
sfpColBl = input.color(#089981, "Lines / Labels (Bullish)", group="SFP Lux - Style")
sfpColBr = input.color(#f23645, "Lines / Labels (Bearish)", group="SFP Lux - Style")
sfpColBl2 = input.color(#08998180, "SFP Wicks (Bullish)", group="SFP Lux - Style")
sfpColBr2 = input.color(#f2364580, "SFP Wicks (Bearish)", group="SFP Lux - Style")
