//@version=5
indicator("Matteo Capital - Box Session & Signals Final FIXED V3", overlay=true, max_labels_count=500)

// --- INPUT ---
showSessions = input.bool(false, "Mostra Box Sessioni (Asia, London, NY)")
showDailyHL  = input.bool(true, "Mostra Daily High/Low")
showDailyOpen = input.bool(false, "Mostra Daily Open (line viola)")
showNYOpen   = input.bool(true, "Mostra NY Open (14:30)")
showA2NRange = input.bool(true, "Mostra Range 00:00→NY (Max/Min)")
showMidnightLines = input.bool(true, "Mostra Linee 00:00 (High/Low)")
show02CandleLines = input.bool(true, "Mostra Linee 02:00 (High/Low)")
showAsiaBiasArrow = input.bool(true, "Freccia Asia @09:00")
useAsiaLondonSell13 = input.bool(true, "Sell @13 se Asia+02 sopra London")
hsEnabled = input.bool(true, "Hammer & Shooting")
hsFibLevel = input.float(defval=0.382, title="Hammer Fib Level", options=[0.236, 0.382, 0.5])
hsConfirm = input.bool(defval=true, title="Hammer Confirm next candle")
hsShowLabels = input.bool(defval=true, title="Hammer Show labels")
hsFibRetraceEnabled = input.bool(true, "Hammer Fib Retrace (0.5/0.382)")
hsFibUse05 = input.bool(true, "Fib 0.5")
hsFibUse0382 = input.bool(true, "Fib 0.382")

useDailyOpenFilter     = input.bool(true, "Filtro Daily Open (Midnight)")
useIbMidFilter         = input.bool(true, "Filtro IB Mid")
requireManipulation    = input.bool(false, "Richiedi Manipolazione (Sweep)")
sweepBufferTicks       = input.int(0, "Sweep buffer (ticks)", minval=0)
reclaimMaxBars         = input.int(6, "Reclaim max bars", minval=1)
midnightSignalsEnabled = input.bool(true, "Segnali Midnight (Sweep & Reclaim)")

// --- CONFIGURAZIONE ORARI (Roma) ---
tz = "Europe/Rome"

// --- 1. DAILY OPEN, HIGH, LOW ---
is_0000 = hour(time, tz) == 0 and minute(time, tz) == 0
var float dHigh = na
var float dLow = na
var float dailyOpen = na

if is_0000
    dailyOpen := open
    dHigh := high
    dLow := low
else
    dHigh := math.max(dHigh, high)
    dLow := math.min(dLow, low)

plot(showDailyOpen ? dailyOpen : na, "Daily Open", color.new(color.purple, 50), 1, plot.style_linebr)
plot(showDailyHL ? dHigh : na, "Daily High", color.white, 1, plot.style_linebr)
plot(showDailyHL ? dLow : na, "Daily Low", color.white, 1, plot.style_linebr)

var label dHighLbl = na
var label dLowLbl = na
if showDailyHL and not na(dHigh) and not na(dLow)
    if na(dHighLbl)
        dHighLbl := label.new(bar_index, dHigh, "Daily High", color=color.new(color.white, 100), textcolor=color.red, style=label.style_label_right, size=size.small)
    else
        label.set_x(dHighLbl, bar_index)
        label.set_y(dHighLbl, dHigh)
    if na(dLowLbl)
        dLowLbl := label.new(bar_index, dLow, "Daily Low", color=color.new(color.white, 100), textcolor=color.red, style=label.style_label_right, size=size.small)
    else
        label.set_x(dLowLbl, bar_index)
        label.set_y(dLowLbl, dLow)
else
    if not na(dHighLbl)
        label.delete(dHighLbl)
        dHighLbl := na
    if not na(dLowLbl)
        label.delete(dLowLbl)
        dLowLbl := na

// --- 2. NY OPEN (14:30) ---
var float nyOpenPrice = na
isAfterNyOpen = not na(time(timeframe.period, "1430-2359", tz))
nyOpenFrom1m = request.security(syminfo.tickerid, "1", ta.valuewhen(hour(time, tz) == 14 and minute(time, tz) == 30, open, 0), barmerge.gaps_off, barmerge.lookahead_off)
if is_0000
    nyOpenPrice := na
if isAfterNyOpen and not na(nyOpenFrom1m)
    nyOpenPrice := nyOpenFrom1m

plot(showNYOpen ? nyOpenPrice : na, "NY Open Line", color.blue, 2, plot.style_linebr)

var label nyOpenLbl = na
if showNYOpen and not na(nyOpenPrice)
    if na(nyOpenLbl)
        nyOpenLbl := label.new(bar_index, nyOpenPrice, "NY Open", color=color.new(color.white, 100), textcolor=color.red, style=label.style_label_right, size=size.small)
    else
        label.set_x(nyOpenLbl, bar_index)
        label.set_y(nyOpenLbl, nyOpenPrice)
else
    if not na(nyOpenLbl)
        label.delete(nyOpenLbl)
        nyOpenLbl := na

// --- 3. FUNZIONE BOX SESSIONI ---
var box asiaBox = na, var box londonBox = na, var box nyBox = na
var label asiaLab = na, var label londonLab = na, var label nyLab = na
var float aHigh = na, var float aLow = na
var float lHigh = na, var float lLow = na
var float nHigh = na, var float nLow = na

var float asiaOpen = na
var float asiaClose = na
var float asiaHigh = na
var float asiaLow = na
isInAsia = not na(time(timeframe.period, "0000-0800", tz))
if is_0000
    asiaOpen := na
    asiaClose := na
    asiaHigh := na
    asiaLow := na
if isInAsia
    if not isInAsia[1]
        asiaOpen := open
        asiaHigh := high
        asiaLow := low
    asiaClose := close
    asiaHigh := math.max(nz(asiaHigh, high), high)
    asiaLow := math.min(nz(asiaLow, low), low)

var float londonHighLive = na
var float londonLowLive = na
isInLondon = not na(time(timeframe.period, "0900-1730", tz))
if is_0000
    londonHighLive := na
    londonLowLive := na
if isInLondon
    if not isInLondon[1]
        londonHighLive := high
        londonLowLive := low
    else
        londonHighLive := math.max(nz(londonHighLive, high), high)
        londonLowLive := math.min(nz(londonLowLive, low), low)

draw_session(sess_time, sess_name, sess_color, sBox, sLab, sHigh, sLow) =>
    t = time(timeframe.period, sess_time, tz)
    isIn = not na(t)
    isFirst = isIn and na(t[1])
    resHigh = sHigh, resLow = sLow, resBox = sBox, resLab = sLab
    if isFirst
        resHigh := high
        resLow := low
        resBox := box.new(left=bar_index, top=resHigh, right=bar_index, bottom=resLow, bgcolor=color.new(sess_color, 92), border_color=color.new(sess_color, 100), border_width=0)
        if showSessions
            resLab := label.new(bar_index, high, sess_name, color=sess_color, textcolor=color.white, style=label.style_label_down, size=size.small)
    else if isIn
        resHigh := math.max(nz(resHigh, high), high)
        resLow := math.min(nz(resLow, low), low)
        box.set_top(resBox, resHigh)
        box.set_bottom(resBox, resLow)
        box.set_right(resBox, bar_index)
        label.set_x(resLab, bar_index)
        label.set_y(resLab, resHigh)
    [resBox, resLab, resHigh, resLow]

if showSessions
    [b1, l1, h1, lw1] = draw_session("0000-0800", "ASIA", color.green, asiaBox, asiaLab, aHigh, aLow)
    asiaBox := b1, asiaLab := l1, aHigh := h1, aLow := lw1
    [b2, l2, h2, lw2] = draw_session("0900-1730", "LONDON", color.blue, londonBox, londonLab, lHigh, lLow)
    londonBox := b2, londonLab := l2, lHigh := h2, lLow := lw2
    [b3, l3, h3, lw3] = draw_session("1430-2100", "NY", color.orange, nyBox, nyLab, nHigh, nLow)
    nyBox := b3, nyLab := l3, nHigh := h3, nLow := lw3

// --- 4. INITIAL BALANCE (09:00 - 10:00) ---
isInIB = not na(time(timeframe.period, "0900-1000", tz))
var float ibH = na
var float ibL = na
if isInIB
    if not isInIB[1]
        ibH := high
        ibL := low
    else
        ibH := math.max(ibH, high)
        ibL := math.min(ibL, low)
ibMid = (ibH + ibL) / 2
plot(ibH, "IB High", color.new(color.blue, 40), 1, plot.style_linebr)
plot(ibL, "IB Low", color.new(color.blue, 40), 1, plot.style_linebr)

// --- 5. SETUP 13:00 (LINEE ARANCIONI - START DALLE 13:00) ---
is_1300_range = not na(time(timeframe.period, "1300-1400", tz))
var float orangeH = na
var float orangeL = na

if is_0000
    orangeH := na
    orangeL := na

if is_1300_range
    if not is_1300_range[1]
        orangeH := high
        orangeL := low
    else
        orangeH := math.max(orangeH, high)
        orangeL := math.min(orangeL, low)

// Modifica: ora le linee partono dalle 13:00 (appena iniziano a esistere)
plot(hour(time, tz) >= 13 ? orangeH : na, "H13", color.orange, 2, plot.style_linebr)
plot(hour(time, tz) >= 13 ? orangeL : na, "L13", color.orange, 2, plot.style_linebr)

is_0200 = hour(time, tz) == 2 and minute(time, tz) == 0
var float c02H = na
var float c02L = na
if is_0000
    c02H := na
    c02L := na
if is_0200
    c02H := high
    c02L := low
plot(show02CandleLines and hour(time, tz) >= 2 ? c02H : na, "02 High", color.green, 2, plot.style_linebr)
plot(show02CandleLines and hour(time, tz) >= 2 ? c02L : na, "02 Low", color.green, 2, plot.style_linebr)

is_1300 = hour(time, tz) == 13 and minute(time, tz) == 0
c02AboveLondon = not na(c02H) and not na(c02L) and not na(londonHighLive) and c02H > londonHighLive and c02L > londonHighLive
plotshape(useAsiaLondonSell13 and is_1300 and c02AboveLondon, title="Sell 13 (02>London)", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small, text="SELL")

midCandleHigh = request.security(syminfo.tickerid, "1", ta.valuewhen(hour(time, tz) == 0 and minute(time, tz) == 0, high, 0), barmerge.gaps_off, barmerge.lookahead_on)
midCandleLow  = request.security(syminfo.tickerid, "1", ta.valuewhen(hour(time, tz) == 0 and minute(time, tz) == 0, low, 0), barmerge.gaps_off, barmerge.lookahead_on)

newDayRome = na(time[1]) ? true : dayofmonth(time, tz) != dayofmonth(time[1], tz)
midCandlePlotHigh = newDayRome ? na : midCandleHigh
midCandlePlotLow = newDayRome ? na : midCandleLow
plot(showMidnightLines ? midCandlePlotHigh : na, "00 High", color.green, 2, plot.style_linebr)
plot(showMidnightLines ? midCandlePlotLow : na, "00 Low", color.green, 2, plot.style_linebr)

var line a2nHighLine = na
var line a2nLowLine = na
if newDayRome
    if not na(a2nHighLine)
        line.delete(a2nHighLine)
        a2nHighLine := na
    if not na(a2nLowLine)
        line.delete(a2nLowLine)
        a2nLowLine := na
    if showA2NRange
        a2nHighLine := line.new(bar_index, midCandleHigh, bar_index + 1, midCandleHigh, extend=extend.right, color=color.green, width=2)
        a2nLowLine := line.new(bar_index, midCandleLow, bar_index + 1, midCandleLow, extend=extend.right, color=color.green, width=2)

if not showA2NRange
    if not na(a2nHighLine)
        line.delete(a2nHighLine)
        a2nHighLine := na
    if not na(a2nLowLine)
        line.delete(a2nLowLine)
        a2nLowLine := na
else
    if not na(a2nHighLine) and not na(midCandleHigh)
        line.set_xy1(a2nHighLine, line.get_x1(a2nHighLine), midCandleHigh)
        line.set_xy2(a2nHighLine, bar_index + 1, midCandleHigh)
    if not na(a2nLowLine) and not na(midCandleLow)
        line.set_xy1(a2nLowLine, line.get_x1(a2nLowLine), midCandleLow)
        line.set_xy2(a2nLowLine, bar_index + 1, midCandleLow)

buf = sweepBufferTicks * syminfo.mintick

var float midH = na
var float midL = na
var int midSweepDownBar = na
var int midSweepUpBar = na
var bool midLongDone = false
var bool midShortDone = false

if is_0000
    midH := high
    midL := low
    midSweepDownBar := na
    midSweepUpBar := na
    midLongDone := false
    midShortDone := false

if not na(midL) and na(midSweepDownBar) and low < (midL - buf)
    midSweepDownBar := bar_index
if not na(midH) and na(midSweepUpBar) and high > (midH + buf)
    midSweepUpBar := bar_index

midSweepDown = not na(midSweepDownBar)
midSweepUp = not na(midSweepUpBar)

newDay = year(time, tz) != year(time[1], tz) or month(time, tz) != month(time[1], tz) or dayofmonth(time, tz) != dayofmonth(time[1], tz)
midPlotH = newDay ? na : midH
midPlotL = newDay ? na : midL
plot(showA2NRange ? midPlotH : na, "MID High", color.green, 2, plot.style_linebr)
plot(showA2NRange ? midPlotL : na, "MID Low", color.green, 2, plot.style_linebr)

var int ibSweepDownBar = na
var int ibSweepUpBar = na
if is_0000
    ibSweepDownBar := na
    ibSweepUpBar := na

if not na(ibL) and na(ibSweepDownBar) and low < (ibL - buf)
    ibSweepDownBar := bar_index
if not na(ibH) and na(ibSweepUpBar) and high > (ibH + buf)
    ibSweepUpBar := bar_index

ibSweepDown = not na(ibSweepDownBar)
ibSweepUp = not na(ibSweepUpBar)

// --- 6. LOGICA SEGNALI ---
isKill = not na(time(timeframe.period, "1430-1630", tz))
is1m = timeframe.isminutes and timeframe.multiplier == 1
isStar13 = is1m ? (hour(time, tz) == 12 and minute(time, tz) == 59) : (hour(time, tz) == 13 and minute(time, tz) == 0)
isStar16 = is1m ? (hour(time, tz) == 15 and minute(time, tz) == 59) : (hour(time, tz) == 16 and minute(time, tz) == 0)
is_0900 = hour(time, tz) == 9 and minute(time, tz) == 0
asiaRangeHas = not na(asiaHigh) and not na(asiaLow)
asiaBiasBuy = asiaRangeHas and is_0900 and low > asiaHigh
asiaBiasSell = asiaRangeHas and is_0900 and high < asiaLow
var bool bDone = false
var bool sDone = false
if is_0000
    bDone := false
    sDone := false

dailyOkB = (not useDailyOpenFilter) or (close > dailyOpen)
dailyOkS = (not useDailyOpenFilter) or (close < dailyOpen)
ibOkB = (not useIbMidFilter) or (close > ibMid)
ibOkS = (not useIbMidFilter) or (close < ibMid)
manipOkB = (not requireManipulation) or midSweepDown or ibSweepDown
manipOkS = (not requireManipulation) or midSweepUp or ibSweepUp

validB = close > orangeH and isKill and not bDone and dailyOkB and ibOkB and manipOkB
validS = close < orangeL and isKill and not sDone and dailyOkS and ibOkS and manipOkS

if validB
    bDone := true
if validS
    sDone := true

plotshape(validB, "BUY", shape.triangleup, location.belowbar, color.green, size=size.small, text="BUY")
plotshape(validS, "SELL", shape.triangledown, location.abovebar, color.red, size=size.small, text="SELL")
plotshape(isStar13, title="13:00", style=shape.labelup, location=location.belowbar, color=color.yellow, text="★", textcolor=color.black, size=size.tiny)
plotshape(isStar16, title="16:00", style=shape.labelup, location=location.belowbar, color=color.yellow, text="★", textcolor=color.black, size=size.tiny)
plotshape(showAsiaBiasArrow and asiaBiasBuy, title="Asia Bias Buy", style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small, text="A")
plotshape(showAsiaBiasArrow and asiaBiasSell, title="Asia Bias Sell", style=shape.triangledown, location=location.belowbar, color=color.red, size=size.small, text="A")

hsIsGreen = open < close
hsIsRed = open > close
hsCandleSize = math.abs(high - low)
hsIsHammer = high - hsFibLevel * hsCandleSize < math.min(open, close)
hsIsShoot = low + hsFibLevel * hsCandleSize > math.max(open, close)
hsConfirmedHammer = hsConfirm ? hsIsHammer[1] and hsIsGreen : hsIsHammer
hsConfirmedShoot = hsConfirm ? hsIsShoot[1] and hsIsRed : hsIsShoot
hsOffset = hsConfirm ? -1 : 0
plotshape(hsEnabled and hsConfirmedHammer, title="Hammer", style=shape.arrowup, location=location.belowbar, color=color.green, textcolor=color.green, text="Hammer", offset=hsOffset, display=hsShowLabels ? display.all : display.none)
plotshape(hsEnabled and hsConfirmedShoot, title="Shooting", style=shape.arrowdown, location=location.abovebar, color=color.red, textcolor=color.red, text="Shooting", offset=hsOffset, display=hsShowLabels ? display.all : display.none)

var line hsFib0 = na
var line hsFib0382 = na
var line hsFib05 = na
var line hsFib1 = na
var line hsFibDiag = na
var int hsFibPatternIndex = na
var float hsFibHigh = na
var float hsFibLow = na
var int hsFibDir = 0
var bool hsFibPending = false
var int hsFibExpiry = na

hsBuyTouch = false
hsSellTouch = false
deleteFibNow = false
createFibNow = false

if hsEnabled and hsFibRetraceEnabled
    newHammer = hsConfirmedHammer
    newShoot = hsConfirmedShoot
    if newHammer or newShoot
        createFibNow := true
        hsFibPatternIndex := hsConfirm ? (bar_index - 1) : bar_index
        hsFibHigh := hsConfirm ? high[1] : high
        hsFibLow := hsConfirm ? low[1] : low
        hsFibDir := newHammer ? 1 : -1
        hsFibPending := true
        hsFibExpiry := hsConfirm ? bar_index : (bar_index + 1)

    if hsFibPending and not na(hsFibHigh) and not na(hsFibLow) and not na(hsFibExpiry)
        if bar_index == hsFibExpiry
            rr = hsFibHigh - hsFibLow
            lv0382 = hsFibLow + 0.382 * rr
            lv05 = hsFibLow + 0.5 * rr
            touched = (hsFibUse05 and low <= lv05 and high >= lv05) or (hsFibUse0382 and low <= lv0382 and high >= lv0382)
            if touched
                hsBuyTouch := hsFibDir == 1
                hsSellTouch := hsFibDir == -1
                hsFibPending := false
            else
                deleteFibNow := true
        else if bar_index > hsFibExpiry
            deleteFibNow := true
else
    deleteFibNow := true

if deleteFibNow or createFibNow
    if not na(hsFib0)
        line.delete(hsFib0)
    if not na(hsFib0382)
        line.delete(hsFib0382)
    if not na(hsFib05)
        line.delete(hsFib05)
    if not na(hsFib1)
        line.delete(hsFib1)
    if not na(hsFibDiag)
        line.delete(hsFibDiag)
    hsFib0 := na
    hsFib0382 := na
    hsFib05 := na
    hsFib1 := na
    hsFibDiag := na
    if deleteFibNow
        hsFibPatternIndex := na
        hsFibHigh := na
        hsFibLow := na
        hsFibDir := 0
        hsFibPending := false
        hsFibExpiry := na

if createFibNow and not na(hsFibPatternIndex) and not na(hsFibHigh) and not na(hsFibLow)
    r = hsFibHigh - hsFibLow
    lv0 = hsFibLow
    lv1 = hsFibHigh
    lv0382 = hsFibLow + 0.382 * r
    lv05 = hsFibLow + 0.5 * r
    hsFib0 := line.new(hsFibPatternIndex, lv0, hsFibPatternIndex + 1, lv0, extend=extend.right, color=color.new(color.gray, 0), width=1)
    hsFib1 := line.new(hsFibPatternIndex, lv1, hsFibPatternIndex + 1, lv1, extend=extend.right, color=color.new(color.gray, 0), width=1)
    if hsFibUse0382
        hsFib0382 := line.new(hsFibPatternIndex, lv0382, hsFibPatternIndex + 1, lv0382, extend=extend.right, color=color.orange, width=2)
    if hsFibUse05
        hsFib05 := line.new(hsFibPatternIndex, lv05, hsFibPatternIndex + 1, lv05, extend=extend.right, color=color.green, width=2)
    hsFibDiag := line.new(hsFibPatternIndex, hsFibHigh, hsFibPatternIndex + 20, hsFibLow, extend=extend.none, color=color.new(color.gray, 30), style=line.style_dashed, width=1)

plotshape(hsBuyTouch, title="Fib Buy (Hammer)", style=shape.triangleup, location=location.belowbar, color=color.lime, size=size.small, text="BUY")
plotshape(hsSellTouch, title="Fib Sell (Shooting)", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small, text="SELL")

canMidLong = midnightSignalsEnabled and midSweepDown and not midLongDone and (bar_index - midSweepDownBar) <= reclaimMaxBars
canMidShort = midnightSignalsEnabled and midSweepUp and not midShortDone and (bar_index - midSweepUpBar) <= reclaimMaxBars

midLong = canMidLong and close > midL and isKill and dailyOkB and ibOkB
midShort = canMidShort and close < midH and isKill and dailyOkS and ibOkS

if midLong
    midLongDone := true
if midShort
    midShortDone := true

plotshape(midLong, "BUY Mid", shape.triangleup, location.belowbar, color.aqua, size=size.small, text="BUY Mid")
plotshape(midShort, "SELL Mid", shape.triangledown, location.abovebar, color.fuchsia, size=size.small, text="SELL Mid")
