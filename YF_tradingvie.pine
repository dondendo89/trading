                line l5b = line.new(array.get(qIndex, sz - 1), array.get(qValue, sz - 1), array.get(qIndex, sz - 1) + mv - 2, array.get(qValue, sz - 4), xloc=xloc.bar_index, color=colQM_M, width=2, style=line.style_arrow_right)
                array.push(qmLines, l1b)
