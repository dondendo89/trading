                        if tt == "LL" or tt == "HL" or tt == "L"
                            if found == 0
                                lx2 := array.get(qIndex, ii)
                                ly2 := array.get(qValue, ii)
                                found := 1
                            else if found == 1
                                lx1 := array.get(qIndex, ii)
                                ly1 := array.get(qValue, ii)
                                found := 2
                                break
                    if found == 2 and lx2 != lx1
                        qmlTlSellPending := true
                        qmlTlSellLevel := lvl
