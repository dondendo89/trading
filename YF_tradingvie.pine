
//@version=5
indicator("YF Bot Logic (Structure Only: HH/HL/LH/LL)", overlay=true, max_bars_back=5000, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

depth = input.int(10, "Pivot Depth (left)", minval=1)
lb = input.int(2, "Pivot Confirmation (right)", minval=1)
PP = input.int(5, "Pivot Period", minval=1)

lookbackBars = input.int(100, "VP Lookback Bars", minval=20, maxval=500)
numRows = input.int(30, "VP Rows", minval=10, maxval=80)
valueAreaPercent = input.int(70, "Value Area %", minval=50, maxval=90)

showProfile = input.bool(false, "Show Volume Profile")
profileOffsetBars = input.int(10, "Profile Offset (Bars)", minval=0, maxval=100)
profileWidthBars = input.int(20, "Profile Max Width (Bars)", minval=5, maxval=100)
profilePosition = input.string("Right", "Profile Position", options=["Left", "Right"])

showLevels = input.bool(false, "Show POC/VAH/VAL Lines")
showPivots = input.bool(true, "Show HH/LL Labels")
showSignals = input.bool(false, "Show Signal Labels")
showQM = input.bool(false, "Show QM (M/W)")
showRbsSbr = input.bool(true, "Show RBS/SBR")
retestLineBars = input.int(40, "RBS/SBR Line Length (bars)", minval=5, maxval=500)
showQmlSnrTl = input.bool(true, "Show QML+SNR+TL")
qmlTolAtrMult = input.float(0.2, "QML Tol ATR Mult", minval=0.0, step=0.05)
tlTolAtrMult = input.float(0.2, "TL Tol ATR Mult", minval=0.0, step=0.05)
qmlTlMaxBars = input.int(200, "QML+TL Max Bars", minval=1, maxval=2000)
colTL = input.color(color.red, "TL Color")
colQML = input.color(color.gray, "QML Level Color")
retestAtrMult = input.float(0.2, "RBS/SBR Retest ATR Mult", minval=0.0, step=0.05)
retestMaxBars = input.int(50, "RBS/SBR Max Bars After Break", minval=1, maxval=500)
atrPeriod = input.int(21, "ATR Period", minval=1)
colQM_M = input.color(color.rgb(150, 75, 0), "QM M Color (brown)")
colQM_W = input.color(color.rgb(38, 150, 41), "QM W Color")
ATR = ta.atr(21)

colBull = input.color(color.lime, "Bull Color")
colBear = input.color(color.red, "Bear Color")
colPoc = input.color(color.rgb(33, 150, 243), "POC Color")
colVah = input.color(color.rgb(156, 39, 176), "VAH Color")
colVal = input.color(color.rgb(255, 152, 0), "VAL Color")

tvLink() =>
    "https://www.tradingview.com/chart/?symbol=" + str.replace(syminfo.tickerid, ":", "%3A")

var float[] _vpVols = array.new_float()
var float[] _vpPrices = array.new_float()
var box[] _vpBoxes = array.new_box()
var line _pocLine = na
var line _vahLine = na
var line _valLine = na
var label _pocLbl = na
var label _vahLbl = na
var label _valLbl = na

vpEnsureArrays() =>
    if array.size(_vpVols) != numRows
        array.clear(_vpVols)
        array.clear(_vpPrices)
        array.clear(_vpBoxes)
        for i = 0 to numRows - 1
            array.push(_vpVols, 0.0)
            array.push(_vpPrices, na)
            array.push(_vpBoxes, na)

vpReset() =>
    for i = 0 to array.size(_vpVols) - 1
        array.set(_vpVols, i, 0.0)

vpCompute() =>
    vpEnsureArrays()
    float hh = ta.highest(high, lookbackBars)
    float ll = ta.lowest(low, lookbackBars)
    float rng = hh - ll
    float rowH = rng / numRows
    bool ok = rng > 0 and rowH > 0
    if ok
        for i = 0 to numRows - 1
            array.set(_vpPrices, i, ll + (i + 0.5) * rowH)
        vpReset()
        for bi = 0 to lookbackBars - 1
            float bh = high[bi]
            float bl = low[bi]
            float bv = na(volume[bi]) ? 0.0 : volume[bi]
            int s = int(math.floor((bl - ll) / rowH))
            int e = int(math.floor((bh - ll) / rowH))
            s := math.max(0, math.min(numRows - 1, s))
            e := math.max(0, math.min(numRows - 1, e))
            int cnt = e - s + 1
            if cnt > 0 and bv > 0
                float vpl = bv / cnt
                for j = s to e
                    array.set(_vpVols, j, array.get(_vpVols, j) + vpl)
    [ok, rowH]

vpLevels() =>
    [ok, rowH] = vpCompute()
    float poc = na
    float vah = na
    float val = na
    if ok
        float tot = 0.0
        int pocIdx = 0
        float maxV = -1.0
        for i = 0 to numRows - 1
            float v = array.get(_vpVols, i)
            tot += v
            if v > maxV
                maxV := v
                pocIdx := i
        if tot > 0
            float target = tot * (valueAreaPercent / 100.0)
            float acc = array.get(_vpVols, pocIdx)
            int hi = pocIdx
            int lo = pocIdx
            while acc < target
                bool canUp = hi < numRows - 1
                bool canDn = lo > 0
                float upV = canUp ? array.get(_vpVols, hi + 1) : 0.0
                float dnV = canDn ? array.get(_vpVols, lo - 1) : 0.0
                if canUp and (not canDn or upV >= dnV)
                    acc += upV
                    hi += 1
                else if canDn
                    acc += dnV
                    lo -= 1
                else
                    break
            float pocC = array.get(_vpPrices, pocIdx)
            float vahC = array.get(_vpPrices, hi)
            float valC = array.get(_vpPrices, lo)
            poc := pocC
            vah := vahC + rowH / 2
            val := valC - rowH / 2
    [poc, vah, val, rowH]

vpDraw(poc, vah, val, rowH) =>
    if not showProfile
        for i = 0 to array.size(_vpBoxes) - 1
            box b = array.get(_vpBoxes, i)
            if not na(b)
                box.delete(b)
        array.clear(_vpBoxes)
    else
        int anchor = bar_index + profileOffsetBars
        int dir = profilePosition == "Right" ? 1 : -1
        float maxV = 0.0
        for i = 0 to numRows - 1
            maxV := math.max(maxV, array.get(_vpVols, i))
        for i = 0 to numRows - 1
            float cp = array.get(_vpPrices, i)
            float v = array.get(_vpVols, i)
            float norm = maxV > 0 ? v / maxV : 0.0
            int w = int(math.round(profileWidthBars * norm))
            w := math.max(1, w)
            int x1 = anchor
            int x2 = anchor + dir * w
            float top = cp + rowH / 2
            float bot = cp - rowH / 2
            bool inVa = not na(vah) and not na(val) and cp >= val and cp <= vah
            color c = inVa ? color.new(colVah, 80) : color.new(color.gray, 85)
            box b = array.get(_vpBoxes, i)
            if na(b)
                b := box.new(x1, top, x2, bot, xloc=xloc.bar_index, border_width=0, bgcolor=c)
                array.set(_vpBoxes, i, b)
            else
                box.set_lefttop(b, x1, top)
                box.set_rightbottom(b, x2, bot)
                box.set_bgcolor(b, c)

var float lastHighPivot = na
var float lastLowPivot = na
var float prevHH = na
var float prevLL = na
var bool pendingSell = false
var bool pendingBuy = false
var float pendingVAH = na
var float pendingVAL = na
var int pendingBar = na

var float lastRes = na
var float lastSup = na
var bool rbsPending = false
var float rbsLevel = na
var int rbsBreakBar = na
var bool sbrPending = false
var float sbrLevel = na
var int sbrBreakBar = na
var line[] rbsSbrLines = array.new_line()

var bool qmlTlBuyPending = false
var float qmlTlBuyLevel = na
var int qmlTlBuyStartBar = na
var int qmlTlBuyTLx1 = na
var float qmlTlBuyTLy1 = na
var int qmlTlBuyTLx2 = na
var float qmlTlBuyTLy2 = na
var line qmlTlBuyTLLine = na
var line qmlTlBuyLevelLine = na

var bool qmlTlSellPending = false
var float qmlTlSellLevel = na
var int qmlTlSellStartBar = na
var int qmlTlSellTLx1 = na
var float qmlTlSellTLy1 = na
var int qmlTlSellTLx2 = na
var float qmlTlSellTLy2 = na
var line qmlTlSellTLLine = na
var line qmlTlSellLevelLine = na

var int[] pivX = array.new_int()
var float[] pivY = array.new_float()
var string[] pivLbl = array.new_string()
var line[] qmLines = array.new_line()
var label[] qmLabels = array.new_label()
var label qmTag = na
var int lastQMBase = na
var string lastQMKind = ""

var string[] qType = array.new_string()
var float[] qValue = array.new_float()
var int[] qIndex = array.new_int()
var int PASS = 0

pushPivot(x, y, lbl) =>
    array.push(pivX, x)
    array.push(pivY, y)
    array.push(pivLbl, lbl)
    if array.size(pivX) > 80
        array.shift(pivX)
        array.shift(pivY)
        array.shift(pivLbl)

detectQM() =>
    string kind = ""
    if array.size(pivLbl) >= 5
        string l1 = array.get(pivLbl, array.size(pivLbl) - 1)
        string l2 = array.get(pivLbl, array.size(pivLbl) - 2)
        string l3 = array.get(pivLbl, array.size(pivLbl) - 3)
        string l4 = array.get(pivLbl, array.size(pivLbl) - 4)
        float p1 = array.get(pivY, array.size(pivY) - 1)
        float p5 = array.get(pivY, array.size(pivY) - 5)
        if l1 == "LL" and l2 == "HH" and l3 == "HL" and l4 == "HH" and p5 < p1
            kind := "M"
        if l1 == "HH" and l2 == "LL" and l3 == "LH" and l4 == "LL" and p5 > p1
            kind := "W"
    kind

var float poc = na
var float vah = na
var float val = na
var float rowH = na
bool useVP = showProfile or showLevels
if useVP
    [poc, vah, val, rowH] = vpLevels()
    vpDraw(poc, vah, val, rowH)
    if not showLevels
        if not na(_pocLine)
            line.delete(_pocLine)
            _pocLine := na
        if not na(_vahLine)
            line.delete(_vahLine)
            _vahLine := na
        if not na(_valLine)
            line.delete(_valLine)
            _valLine := na
        if not na(_pocLbl)
            label.delete(_pocLbl)
            _pocLbl := na
        if not na(_vahLbl)
            label.delete(_vahLbl)
            _vahLbl := na
        if not na(_valLbl)
            label.delete(_valLbl)
            _valLbl := na
    else
        if not na(poc)
            if na(_pocLine)
                _pocLine := line.new(bar_index, poc, bar_index + 1, poc, xloc=xloc.bar_index, extend=extend.right, color=colPoc, width=2)
            else
                line.set_xy1(_pocLine, bar_index, poc)
                line.set_xy2(_pocLine, bar_index + 1, poc)
        if not na(vah)
            if na(_vahLine)
                _vahLine := line.new(bar_index, vah, bar_index + 1, vah, xloc=xloc.bar_index, extend=extend.right, color=colVah, width=1, style=line.style_dashed)
            else
                line.set_xy1(_vahLine, bar_index, vah)
                line.set_xy2(_vahLine, bar_index + 1, vah)
        if not na(val)
            if na(_valLine)
                _valLine := line.new(bar_index, val, bar_index + 1, val, xloc=xloc.bar_index, extend=extend.right, color=colVal, width=1, style=line.style_dashed)
            else
                line.set_xy1(_valLine, bar_index, val)
                line.set_xy2(_valLine, bar_index + 1, val)
        if barstate.islast and showSignals
            if not na(_pocLbl)
                label.delete(_pocLbl)
            if not na(_vahLbl)
                label.delete(_vahLbl)
            if not na(_valLbl)
                label.delete(_valLbl)
            _pocLbl := not na(poc) ? label.new(bar_index, poc, "POC " + str.tostring(poc, format.mintick), xloc=xloc.bar_index, style=label.style_label_left, textcolor=color.white, color=color.new(colPoc, 0)) : na
            _vahLbl := not na(vah) ? label.new(bar_index, vah, "VAH " + str.tostring(vah, format.mintick), xloc=xloc.bar_index, style=label.style_label_left, textcolor=color.white, color=color.new(colVah, 0)) : na
            _valLbl := not na(val) ? label.new(bar_index, val, "VAL " + str.tostring(val, format.mintick), xloc=xloc.bar_index, style=label.style_label_left, textcolor=color.white, color=color.new(colVal, 0)) : na

ph = ta.pivothigh(high, depth, lb)
pl = ta.pivotlow(low, depth, lb)

var bool qmM = false
var bool qmW = false
qmM := false
qmW := false

var bool formedHH = false
var bool formedLH = false
var bool formedHL = false
var bool formedLL = false
formedHH := false
formedLH := false
formedHL := false
formedLL := false

if not na(ph)
    string lbl = na(lastHighPivot) ? "HH" : (ph > lastHighPivot ? "HH" : "LH")
    int px = bar_index - lb
    float py = ph
    lastRes := py
    if showPivots
        label.new(px, py, lbl, xloc=xloc.bar_index, style=label.style_label_down, color=color.new(colBear, 15), textcolor=color.white, size=size.small)
    pushPivot(px, py, lbl)
    string qmK = detectQM()
    if showQM and false and qmK != ""
        for ln in qmLines
            line.delete(ln)
        array.clear(qmLines)
        for lbx in qmLabels
            label.delete(lbx)
        array.clear(qmLabels)
        if not na(qmTag)
            label.delete(qmTag)
        int n = array.size(pivX)
        if n >= 5
            int base = n - 5
            int x5 = array.get(pivX, base + 0)
            int x4 = array.get(pivX, base + 1)
            int x3 = array.get(pivX, base + 2)
            int x2 = array.get(pivX, base + 3)
            int x1 = array.get(pivX, base + 4)
            float y5 = array.get(pivY, base + 0)
            float y4 = array.get(pivY, base + 1)
            float y3 = array.get(pivY, base + 2)
            float y2 = array.get(pivY, base + 3)
            float y1 = array.get(pivY, base + 4)
            float atr = ta.atr(atrPeriod)
            int mv = (x2 - x4) / 2
            if qmK == "W"
                line l1 = line.new(x5, y5, x4, y4, xloc=xloc.bar_index, color=colBull, width=2)
                line l2 = line.new(x4, y4, x3, y3, xloc=xloc.bar_index, color=colBull, width=2)
                line l3 = line.new(x3, y3, x2, y2, xloc=xloc.bar_index, color=colBull, width=2)
                line l4 = line.new(x2, y2, x1, y1, xloc=xloc.bar_index, color=colBull, width=2)
                line l5 = line.new(x1, y1, x1 + mv - 2, y4, xloc=xloc.bar_index, color=color.rgb(4, 215, 252), width=2, style=line.style_arrow_right)
                array.push(qmLines, l1)
                array.push(qmLines, l2)
                array.push(qmLines, l3)
                array.push(qmLines, l4)
                array.push(qmLines, l5)
                line e = line.new(x4, y4, x1 + mv, y4, xloc=xloc.bar_index, color=color.black, width=1, style=line.style_dotted)
                line s = line.new(x2, y2 - atr / 2, x1 + mv, y2 - atr / 2, xloc=xloc.bar_index, color=color.rgb(170, 29, 29), width=1, style=line.style_dotted)
                line t1 = line.new(x3, y3, x1 + mv, y3, xloc=xloc.bar_index, color=color.rgb(91, 172, 74), width=1, style=line.style_dotted)
                line t2 = line.new(x1, y1, x1 + mv, y1, xloc=xloc.bar_index, color=color.rgb(91, 172, 74), width=1, style=line.style_dotted)
                array.push(qmLines, e)
                array.push(qmLines, s)
                array.push(qmLines, t1)
                array.push(qmLines, t2)
                label le = label.new(x1 + mv + 1, y4, "Entry", xloc=xloc.bar_index, style=label.style_text_outline, color=color.rgb(255, 255, 255, 100))
                label ls = label.new(x1 + mv + 1, y2 - atr / 2, "SL", xloc=xloc.bar_index, style=label.style_text_outline, color=color.rgb(255, 255, 255, 100))
                label lt1 = label.new(x1 + mv + 1, y3, "TP1", xloc=xloc.bar_index, style=label.style_text_outline, color=color.rgb(255, 255, 255, 100))
                label lt2 = label.new(x1 + mv + 1, y1, "TP2", xloc=xloc.bar_index, style=label.style_text_outline, color=color.rgb(255, 255, 255, 100))
                array.push(qmLabels, le)
                array.push(qmLabels, ls)
                array.push(qmLabels, lt1)
                array.push(qmLabels, lt2)
            else
                line l1b = line.new(x5, y5, x4, y4, xloc=xloc.bar_index, color=colQM_M, width=2)
                line l2b = line.new(x4, y4, x3, y3, xloc=xloc.bar_index, color=colQM_M, width=2)
                line l3b = line.new(x3, y3, x2, y2, xloc=xloc.bar_index, color=colQM_M, width=2)
                line l4b = line.new(x2, y2, x1, y1, xloc=xloc.bar_index, color=colQM_M, width=2)
                line l5b = line.new(x1, y1, x1 + mv - 2, y4, xloc=xloc.bar_index, color=colQM_M, width=2, style=line.style_arrow_right)
                array.push(qmLines, l1b)
                array.push(qmLines, l2b)
                array.push(qmLines, l3b)
                array.push(qmLines, l4b)
                array.push(qmLines, l5b)
                line eb = line.new(x4, y4, x1 + mv, y4, xloc=xloc.bar_index, color=color.black, width=1, style=line.style_dotted)
                line sb = line.new(x2, y2 + atr / 2, x1 + mv, y2 + atr / 2, xloc=xloc.bar_index, color=color.rgb(170, 29, 29), width=1, style=line.style_dotted)
                line t1b = line.new(x3, y3, x1 + mv, y3, xloc=xloc.bar_index, color=color.rgb(91, 172, 74), width=1, style=line.style_dotted)
                line t2b = line.new(x1, y1, x1 + mv, y1, xloc=xloc.bar_index, color=color.rgb(91, 172, 74), width=1, style=line.style_dotted)
                array.push(qmLines, eb)
                array.push(qmLines, sb)
                array.push(qmLines, t1b)
                array.push(qmLines, t2b)
                label leb = label.new(x1 + mv + 1, y4, "Entry", xloc=xloc.bar_index, style=label.style_text_outline, color=color.rgb(255, 255, 255, 100))
                label lsb = label.new(x1 + mv + 1, y2 + atr / 2, "SL", xloc=xloc.bar_index, style=label.style_text_outline, color=color.rgb(255, 255, 255, 100))
                label lt1b = label.new(x1 + mv + 1, y3, "TP1", xloc=xloc.bar_index, style=label.style_text_outline, color=color.rgb(255, 255, 255, 100))
                label lt2b = label.new(x1 + mv + 1, y1, "TP2", xloc=xloc.bar_index, style=label.style_text_outline, color=color.rgb(255, 255, 255, 100))
                array.push(qmLabels, leb)
                array.push(qmLabels, lsb)
                array.push(qmLabels, lt1b)
                array.push(qmLabels, lt2b)
            qmTag := label.new(x1, y1, "QM " + qmK, xloc=xloc.bar_index, style=label.style_label_down, color=color.new(qmK == "M" ? colQM_M : colBull, 10), textcolor=color.white)
            lastQMBase := base
            lastQMKind := qmK
        string msg = (qmK == "M" ? "QM M (Bearish)" : "QM W (Bullish)") + "\n" + syminfo.tickerid + "\n" + "Close: " + str.tostring(close, format.mintick) + "\n" + tvLink()
        alert(msg, alert.freq_once_per_bar_close)
        qmM := qmK == "M"
        qmW := qmK == "W"
    lastHighPivot := py
    formedHH := lbl == "HH"
    formedLH := lbl == "LH"
    bool dblHH = not na(prevHH) and lbl == "HH" and py > prevHH
    if lbl == "HH"
        prevHH := py
        if dblHH and not na(vah)
            pendingSell := true
            pendingVAH := vah
            pendingBar := bar_index
    if dblHH and showSignals
        string msg = "DOPPIO MASSIMO (HH)\n" + syminfo.tickerid + "\n" + "Prezzo: " + str.tostring(py, format.mintick)
        alert(msg, alert.freq_once_per_bar_close)
if not na(pl)
    string lbl = na(lastLowPivot) ? "LL" : (pl < lastLowPivot ? "LL" : "HL")
    int px = bar_index - lb
    float py = pl
    lastSup := py
    if showPivots
        label.new(px, py, lbl, xloc=xloc.bar_index, style=label.style_label_up, color=color.new(colBull, 15), textcolor=color.white, size=size.small)
    pushPivot(px, py, lbl)
    string qmK = detectQM()
    if showQM and false and qmK != ""
        for ln in qmLines
            line.delete(ln)
        array.clear(qmLines)
        for lbx in qmLabels
            label.delete(lbx)
        array.clear(qmLabels)
        if not na(qmTag)
            label.delete(qmTag)
        int n = array.size(pivX)
        if n >= 5
            int base = n - 5
            int x5 = array.get(pivX, base + 0)
            int x4 = array.get(pivX, base + 1)
            int x3 = array.get(pivX, base + 2)
            int x2 = array.get(pivX, base + 3)
            int x1 = array.get(pivX, base + 4)
            float y5 = array.get(pivY, base + 0)
            float y4 = array.get(pivY, base + 1)
            float y3 = array.get(pivY, base + 2)
            float y2 = array.get(pivY, base + 3)
            float y1 = array.get(pivY, base + 4)
            float atr = ta.atr(atrPeriod)
            int mv = (x2 - x4) / 2
            if qmK == "W"
                line l1 = line.new(x5, y5, x4, y4, xloc=xloc.bar_index, color=colBull, width=2)
                line l2 = line.new(x4, y4, x3, y3, xloc=xloc.bar_index, color=colBull, width=2)
                line l3 = line.new(x3, y3, x2, y2, xloc=xloc.bar_index, color=colBull, width=2)
                line l4 = line.new(x2, y2, x1, y1, xloc=xloc.bar_index, color=colBull, width=2)
                line l5 = line.new(x1, y1, x1 + mv - 2, y4, xloc=xloc.bar_index, color=color.rgb(4, 215, 252), width=2, style=line.style_arrow_right)
                array.push(qmLines, l1)
                array.push(qmLines, l2)
                array.push(qmLines, l3)
                array.push(qmLines, l4)
                array.push(qmLines, l5)
                line e = line.new(x4, y4, x1 + mv, y4, xloc=xloc.bar_index, color=color.black, width=1, style=line.style_dotted)
                line s = line.new(x2, y2 - atr / 2, x1 + mv, y2 - atr / 2, xloc=xloc.bar_index, color=color.rgb(170, 29, 29), width=1, style=line.style_dotted)
                line t1 = line.new(x3, y3, x1 + mv, y3, xloc=xloc.bar_index, color=color.rgb(91, 172, 74), width=1, style=line.style_dotted)
                line t2 = line.new(x1, y1, x1 + mv, y1, xloc=xloc.bar_index, color=color.rgb(91, 172, 74), width=1, style=line.style_dotted)
                array.push(qmLines, e)
                array.push(qmLines, s)
                array.push(qmLines, t1)
                array.push(qmLines, t2)
                label le = label.new(x1 + mv + 1, y4, "Entry", xloc=xloc.bar_index, style=label.style_text_outline, color=color.rgb(255, 255, 255, 100))
                label ls = label.new(x1 + mv + 1, y2 - atr / 2, "SL", xloc=xloc.bar_index, style=label.style_text_outline, color=color.rgb(255, 255, 255, 100))
                label lt1 = label.new(x1 + mv + 1, y3, "TP1", xloc=xloc.bar_index, style=label.style_text_outline, color=color.rgb(255, 255, 255, 100))
                label lt2 = label.new(x1 + mv + 1, y1, "TP2", xloc=xloc.bar_index, style=label.style_text_outline, color=color.rgb(255, 255, 255, 100))
                array.push(qmLabels, le)
                array.push(qmLabels, ls)
                array.push(qmLabels, lt1)
                array.push(qmLabels, lt2)
            else
                line l1b = line.new(x5, y5, x4, y4, xloc=xloc.bar_index, color=colQM_M, width=2)
                line l2b = line.new(x4, y4, x3, y3, xloc=xloc.bar_index, color=colQM_M, width=2)
                line l3b = line.new(x3, y3, x2, y2, xloc=xloc.bar_index, color=colQM_M, width=2)
                line l4b = line.new(x2, y2, x1, y1, xloc=xloc.bar_index, color=colQM_M, width=2)
                line l5b = line.new(x1, y1, x1 + mv - 2, y4, xloc=xloc.bar_index, color=colQM_M, width=2, style=line.style_arrow_right)
                array.push(qmLines, l1b)
                array.push(qmLines, l2b)
                array.push(qmLines, l3b)
                array.push(qmLines, l4b)
                array.push(qmLines, l5b)
                line eb = line.new(x4, y4, x1 + mv, y4, xloc=xloc.bar_index, color=color.black, width=1, style=line.style_dotted)
                line sb = line.new(x2, y2 + atr / 2, x1 + mv, y2 + atr / 2, xloc=xloc.bar_index, color=color.rgb(170, 29, 29), width=1, style=line.style_dotted)
                line t1b = line.new(x3, y3, x1 + mv, y3, xloc=xloc.bar_index, color=color.rgb(91, 172, 74), width=1, style=line.style_dotted)
                line t2b = line.new(x1, y1, x1 + mv, y1, xloc=xloc.bar_index, color=color.rgb(91, 172, 74), width=1, style=line.style_dotted)
                array.push(qmLines, eb)
                array.push(qmLines, sb)
                array.push(qmLines, t1b)
                array.push(qmLines, t2b)
                label leb = label.new(x1 + mv + 1, y4, "Entry", xloc=xloc.bar_index, style=label.style_text_outline, color=color.rgb(255, 255, 255, 100))
                label lsb = label.new(x1 + mv + 1, y2 + atr / 2, "SL", xloc=xloc.bar_index, style=label.style_text_outline, color=color.rgb(255, 255, 255, 100))
                label lt1b = label.new(x1 + mv + 1, y3, "TP1", xloc=xloc.bar_index, style=label.style_text_outline, color=color.rgb(255, 255, 255, 100))
                label lt2b = label.new(x1 + mv + 1, y1, "TP2", xloc=xloc.bar_index, style=label.style_text_outline, color=color.rgb(255, 255, 255, 100))
                array.push(qmLabels, leb)
                array.push(qmLabels, lsb)
                array.push(qmLabels, lt1b)
                array.push(qmLabels, lt2b)
            qmTag := label.new(x1, y1, "QM " + qmK, xloc=xloc.bar_index, style=label.style_label_down, color=color.new(qmK == "M" ? colQM_M : colBull, 10), textcolor=color.white)
            lastQMBase := base
            lastQMKind := qmK
        string msg = (qmK == "M" ? "QM M (Bearish)" : "QM W (Bullish)") + "\n" + syminfo.tickerid + "\n" + "Close: " + str.tostring(close, format.mintick) + "\n" + tvLink()
        alert(msg, alert.freq_once_per_bar_close)
        qmM := qmK == "M"
        qmW := qmK == "W"
    lastLowPivot := py
    formedLL := lbl == "LL"
    formedHL := lbl == "HL"
    bool dblLL = not na(prevLL) and lbl == "LL" and py < prevLL
    if lbl == "LL"
        prevLL := py
        if dblLL and not na(val)
            pendingBuy := true
            pendingVAL := val
            pendingBar := bar_index
    if dblLL and showSignals
        string msg = "DOPPIO MINIMO (LL)\n" + syminfo.tickerid + "\n" + "Prezzo: " + str.tostring(py, format.mintick)
        alert(msg, alert.freq_once_per_bar_close)

touchSell = not na(vah) and close[1] > vah and low <= vah
touchBuy = not na(val) and close[1] < val and high >= val

if showSignals and touchSell
    label.new(bar_index, vah, "SELL Touch VAH", xloc=xloc.bar_index, style=label.style_label_down, color=color.new(colBear, 0), textcolor=color.white)
    alert("SELL Touch VAH\n" + syminfo.tickerid + "\nVAH: " + str.tostring(vah, format.mintick) + "\nClose: " + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)

if showSignals and touchBuy
    label.new(bar_index, val, "BUY Touch VAL", xloc=xloc.bar_index, style=label.style_label_up, color=color.new(colBull, 0), textcolor=color.white)
    alert("BUY Touch VAL\n" + syminfo.tickerid + "\nVAL: " + str.tostring(val, format.mintick) + "\nClose: " + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)

crossSell = pendingSell and not na(pendingVAH) and close[1] > pendingVAH and close <= pendingVAH
crossBuy = pendingBuy and not na(pendingVAL) and close[1] < pendingVAL and close >= pendingVAL

if showSignals and crossSell
    label.new(bar_index, pendingVAH, "SELL Cross VAH", xloc=xloc.bar_index, style=label.style_label_down, color=color.new(colBear, 0), textcolor=color.white)
    alert("SELL Cross VAH (dopo doppio HH)\n" + syminfo.tickerid + "\nVAH: " + str.tostring(pendingVAH, format.mintick) + "\nClose: " + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)
    pendingSell := false
    pendingVAH := na

if showSignals and crossBuy
    label.new(bar_index, pendingVAL, "BUY Cross VAL", xloc=xloc.bar_index, style=label.style_label_up, color=color.new(colBull, 0), textcolor=color.white)
    alert("BUY Cross VAL (dopo doppio LL)\n" + syminfo.tickerid + "\nVAL: " + str.tostring(pendingVAL, format.mintick) + "\nClose: " + str.tostring(close, format.mintick), alert.freq_once_per_bar_close)
    pendingBuy := false
    pendingVAL := na

float tol = ta.atr(atrPeriod) * retestAtrMult
bool breakUp = not na(lastRes) and close[1] <= lastRes and close > lastRes
bool breakDn = not na(lastSup) and close[1] >= lastSup and close < lastSup

if breakUp
    rbsPending := true
    rbsLevel := lastRes
    rbsBreakBar := bar_index
if breakDn
    sbrPending := true
    sbrLevel := lastSup
    sbrBreakBar := bar_index

bool rbsSignal = rbsPending and not na(rbsLevel) and (bar_index - rbsBreakBar) <= retestMaxBars and low <= (rbsLevel + tol) and close > rbsLevel
bool sbrSignal = sbrPending and not na(sbrLevel) and (bar_index - sbrBreakBar) <= retestMaxBars and high >= (sbrLevel - tol) and close < sbrLevel

if rbsSignal
    if showRbsSbr
        float lvl = rbsLevel
        int x0 = not na(rbsBreakBar) ? rbsBreakBar : bar_index
        int x1 = math.min(bar_index, x0 + retestLineBars)
        line ln = line.new(x0, lvl, x1, lvl, xloc=xloc.bar_index, extend=extend.none, color=color.rgb(38, 150, 41), width=2)
        array.push(rbsSbrLines, ln)
        if array.size(rbsSbrLines) > 200
            line.delete(array.shift(rbsSbrLines))
        label.new(bar_index, rbsLevel, "RBS", xloc=xloc.bar_index, style=label.style_label_up, color=color.new(color.green, 0), textcolor=color.white)
    alert("RBS (Resistance -> Support)\n" + syminfo.tickerid + "\nLevel: " + str.tostring(rbsLevel, format.mintick) + "\nClose: " + str.tostring(close, format.mintick) + "\n" + tvLink(), alert.freq_once_per_bar_close)
    rbsPending := false
    rbsLevel := na
if sbrSignal
    if showRbsSbr
        float lvl = sbrLevel
        int x0 = not na(sbrBreakBar) ? sbrBreakBar : bar_index
        int x1 = math.min(bar_index, x0 + retestLineBars)
        line ln = line.new(x0, lvl, x1, lvl, xloc=xloc.bar_index, extend=extend.none, color=color.rgb(128, 0, 0), width=2)
        array.push(rbsSbrLines, ln)
        if array.size(rbsSbrLines) > 200
            line.delete(array.shift(rbsSbrLines))
        label.new(bar_index, sbrLevel, "SBR", xloc=xloc.bar_index, style=label.style_label_down, color=color.new(color.maroon, 0), textcolor=color.white)
    alert("SBR (Support -> Resistance)\n" + syminfo.tickerid + "\nLevel: " + str.tostring(sbrLevel, format.mintick) + "\nClose: " + str.tostring(close, format.mintick) + "\n" + tvLink(), alert.freq_once_per_bar_close)
    sbrPending := false
    sbrLevel := na

if rbsPending and not na(rbsBreakBar) and (bar_index - rbsBreakBar) > retestMaxBars
    rbsPending := false
    rbsLevel := na
if sbrPending and not na(sbrBreakBar) and (bar_index - sbrBreakBar) > retestMaxBars
    sbrPending := false
    sbrLevel := na

alertcondition(rbsSignal, "RBS formed", "RBS formed")
alertcondition(sbrSignal, "SBR formed", "SBR formed")

var bool qmlTlBuySignal = false
var bool qmlTlSellSignal = false
qmlTlBuySignal := false
qmlTlSellSignal := false

if showQmlSnrTl
    float atrNow = ta.atr(atrPeriod)
    float qTol = atrNow * qmlTolAtrMult
    float tTol = atrNow * tlTolAtrMult
    if qmlTlBuyPending and not na(qmlTlBuyStartBar) and (bar_index - qmlTlBuyStartBar) <= qmlTlMaxBars and not na(qmlTlBuyLevel) and not na(qmlTlBuyTLx1) and not na(qmlTlBuyTLx2) and qmlTlBuyTLx2 != qmlTlBuyTLx1
        float yTL = qmlTlBuyTLy1 + (qmlTlBuyTLy2 - qmlTlBuyTLy1) * (bar_index - qmlTlBuyTLx1) / (qmlTlBuyTLx2 - qmlTlBuyTLx1)
        bool retest = low <= (qmlTlBuyLevel + qTol) and close > qmlTlBuyLevel
        bool tlOk = math.abs(qmlTlBuyLevel - yTL) <= tTol
        if retest and tlOk
            qmlTlBuySignal := true
            label.new(bar_index, qmlTlBuyLevel, "QML+TL BUY", xloc=xloc.bar_index, style=label.style_label_up, color=color.new(color.green, 0), textcolor=color.white)
            alert("QML+SNR+TL BUY\n" + syminfo.tickerid + "\nLevel: " + str.tostring(qmlTlBuyLevel, format.mintick) + "\nClose: " + str.tostring(close, format.mintick) + "\n" + tvLink(), alert.freq_once_per_bar_close)
            qmlTlBuyPending := false
    if qmlTlSellPending and not na(qmlTlSellStartBar) and (bar_index - qmlTlSellStartBar) <= qmlTlMaxBars and not na(qmlTlSellLevel) and not na(qmlTlSellTLx1) and not na(qmlTlSellTLx2) and qmlTlSellTLx2 != qmlTlSellTLx1
        float yTL = qmlTlSellTLy1 + (qmlTlSellTLy2 - qmlTlSellTLy1) * (bar_index - qmlTlSellTLx1) / (qmlTlSellTLx2 - qmlTlSellTLx1)
        bool retest = high >= (qmlTlSellLevel - qTol) and close < qmlTlSellLevel
        bool tlOk = math.abs(qmlTlSellLevel - yTL) <= tTol
        if retest and tlOk
            qmlTlSellSignal := true
            label.new(bar_index, qmlTlSellLevel, "QML+TL SELL", xloc=xloc.bar_index, style=label.style_label_down, color=color.new(color.red, 0), textcolor=color.white)
            alert("QML+SNR+TL SELL\n" + syminfo.tickerid + "\nLevel: " + str.tostring(qmlTlSellLevel, format.mintick) + "\nClose: " + str.tostring(close, format.mintick) + "\n" + tvLink(), alert.freq_once_per_bar_close)
            qmlTlSellPending := false

    if qmlTlBuyPending and not na(qmlTlBuyStartBar) and (bar_index - qmlTlBuyStartBar) > qmlTlMaxBars
        qmlTlBuyPending := false
        qmlTlBuyLevel := na
        if not na(qmlTlBuyTLLine)
            line.delete(qmlTlBuyTLLine)
            qmlTlBuyTLLine := na
        if not na(qmlTlBuyLevelLine)
            line.delete(qmlTlBuyLevelLine)
            qmlTlBuyLevelLine := na
    if qmlTlSellPending and not na(qmlTlSellStartBar) and (bar_index - qmlTlSellStartBar) > qmlTlMaxBars
        qmlTlSellPending := false
        qmlTlSellLevel := na
        if not na(qmlTlSellTLLine)
            line.delete(qmlTlSellTLLine)
            qmlTlSellTLLine := na
        if not na(qmlTlSellLevelLine)
            line.delete(qmlTlSellLevelLine)
            qmlTlSellLevelLine := na

alertcondition(qmlTlBuySignal, "QML+SNR+TL BUY", "QML+SNR+TL BUY")
alertcondition(qmlTlSellSignal, "QML+SNR+TL SELL", "QML+SNR+TL SELL")

alertcondition(formedHH, "Pivot HH", "Pivot HH")
alertcondition(formedLH, "Pivot LH", "Pivot LH")
alertcondition(formedHL, "Pivot HL", "Pivot HL")
alertcondition(formedLL, "Pivot LL", "Pivot LL")

if showQM
    bool HighPivot = not na(ta.pivothigh(high, PP, PP))
    bool LowPivot = not na(ta.pivotlow(low, PP, PP))
    float HighValue = ta.valuewhen(HighPivot, high[PP], 0)
    float LowValue = ta.valuewhen(LowPivot, low[PP], 0)
    int HighIndex = ta.valuewhen(HighPivot, bar_index[PP], 0)
    int LowIndex = ta.valuewhen(LowPivot, bar_index[PP], 0)
    if HighPivot and LowPivot
        if array.size(qType) == 0
            PASS := 1
        else if array.size(qType) >= 1
            if array.get(qType, array.size(qType) - 1) == "L" or array.get(qType, array.size(qType) - 1) == "LL"
                if LowPivot and LowValue < array.get(qValue, array.size(qValue) - 1)
                    array.pop(qType)
                    array.pop(qValue)
                    array.pop(qIndex)
                    array.push(qType, array.size(qType) > 2 ? (array.get(qValue, array.size(qValue) - 2) < LowValue ? "HL" : "LL") : "L")
                    array.push(qValue, LowValue)
                    array.push(qIndex, LowIndex)
                else
                    array.push(qType, array.size(qType) > 2 ? (array.get(qValue, array.size(qValue) - 2) < HighValue ? "HH" : "LH") : "H")
                    array.push(qValue, HighValue)
                    array.push(qIndex, HighIndex)
            else if array.get(qType, array.size(qType) - 1) == "H" or array.get(qType, array.size(qType) - 1) == "HH"
                if HighPivot and HighValue > array.get(qValue, array.size(qValue) - 1)
                    array.pop(qType)
                    array.pop(qValue)
                    array.pop(qIndex)
                    array.push(qType, array.size(qType) > 2 ? (array.get(qValue, array.size(qValue) - 2) < HighValue ? "HH" : "LH") : "H")
                    array.push(qValue, HighValue)
                    array.push(qIndex, HighIndex)
                else
                    array.push(qType, array.size(qType) > 2 ? (array.get(qValue, array.size(qValue) - 2) < LowValue ? "HL" : "LL") : "L")
                    array.push(qValue, LowValue)
                    array.push(qIndex, LowIndex)
            else if array.get(qType, array.size(qType) - 1) == "LH"
                if HighPivot and HighValue < array.get(qValue, array.size(qValue) - 1)
                    array.push(qType, array.size(qType) > 2 ? (array.get(qValue, array.size(qValue) - 2) < LowValue ? "HL" : "LL") : "L")
                    array.push(qValue, LowValue)
                    array.push(qIndex, LowIndex)
                else if HighPivot and HighValue > array.get(qValue, array.size(qValue) - 1)
                    if close < array.get(qValue, array.size(qValue) - 1)
                        array.pop(qType)
                        array.pop(qValue)
                        array.pop(qIndex)
                        array.push(qType, array.size(qType) > 2 ? (array.get(qValue, array.size(qValue) - 2) < HighValue ? "HH" : "LH") : "H")
                        array.push(qValue, HighValue)
                        array.push(qIndex, HighIndex)
                    else if close > array.get(qValue, array.size(qValue) - 1)
                        array.push(qType, array.size(qType) > 2 ? (array.get(qValue, array.size(qValue) - 2) < LowValue ? "HL" : "LL") : "L")
                        array.push(qValue, LowValue)
                        array.push(qIndex, LowIndex)
            else if array.get(qType, array.size(qType) - 1) == "HL"
                if LowPivot and LowValue > array.get(qValue, array.size(qValue) - 1)
                    array.push(qType, array.size(qType) > 2 ? (array.get(qValue, array.size(qValue) - 2) < HighValue ? "HH" : "LH") : "H")
                    array.push(qValue, HighValue)
                    array.push(qIndex, HighIndex)
                else if LowPivot and LowValue < array.get(qValue, array.size(qValue) - 1)
                    if close > array.get(qValue, array.size(qValue) - 1)
                        array.pop(qType)
                        array.pop(qValue)
                        array.pop(qIndex)
                        array.push(qType, array.size(qType) > 2 ? (array.get(qValue, array.size(qValue) - 2) < LowValue ? "HL" : "LL") : "L")
                        array.push(qValue, LowValue)
                        array.push(qIndex, LowIndex)
                    else if close < array.get(qValue, array.size(qValue) - 1)
                        array.push(qType, array.size(qType) > 2 ? (array.get(qValue, array.size(qValue) - 2) < HighValue ? "HH" : "LH") : "H")
                        array.push(qValue, HighValue)
                        array.push(qIndex, HighIndex)
    else if HighPivot
        if array.size(qType) == 0
            array.insert(qType, 0, "H")
            array.insert(qValue, 0, HighValue)
            array.insert(qIndex, 0, HighIndex)
        else if array.size(qType) >= 1
            if array.get(qType, array.size(qType) - 1) == "L" or array.get(qType, array.size(qType) - 1) == "HL" or array.get(qType, array.size(qType) - 1) == "LL"
                if HighPivot and HighValue > array.get(qValue, array.size(qValue) - 1)
                    array.push(qType, array.size(qType) > 2 ? (array.get(qValue, array.size(qValue) - 2) < HighValue ? "HH" : "LH") : "H")
                    array.push(qValue, HighValue)
                    array.push(qIndex, HighIndex)
                else if HighPivot and HighValue < array.get(qValue, array.size(qValue) - 1)
                    array.pop(qType)
                    array.pop(qValue)
                    array.pop(qIndex)
                    array.push(qType, array.size(qType) > 2 ? (array.get(qValue, array.size(qValue) - 2) < LowValue ? "HL" : "LL") : "L")
                    array.push(qValue, LowValue)
                    array.push(qIndex, LowIndex)
            else if array.get(qType, array.size(qType) - 1) == "H" or array.get(qType, array.size(qType) - 1) == "HH" or array.get(qType, array.size(qType) - 1) == "LH"
                if HighPivot and array.get(qValue, array.size(qValue) - 1) < HighValue
                    array.pop(qType)
                    array.pop(qValue)
                    array.pop(qIndex)
                    array.push(qType, array.size(qType) > 2 ? (array.get(qValue, array.size(qValue) - 2) < HighValue ? "HH" : "LH") : "H")
                    array.push(qValue, HighValue)
                    array.push(qIndex, HighIndex)
    else if LowPivot
        if array.size(qType) == 0
            array.insert(qType, 0, "L")
            array.insert(qValue, 0, LowValue)
            array.insert(qIndex, 0, LowIndex)
        else if array.size(qType) >= 1
            if array.get(qType, array.size(qType) - 1) == "H" or array.get(qType, array.size(qType) - 1) == "HH" or array.get(qType, array.size(qType) - 1) == "LH"
                if LowPivot and LowValue < array.get(qValue, array.size(qValue) - 1)
                    array.push(qType, array.size(qType) > 2 ? (array.get(qValue, array.size(qValue) - 2) < LowValue ? "HL" : "LL") : "L")
                    array.push(qValue, LowValue)
                    array.push(qIndex, LowIndex)
                else if LowPivot and LowValue > array.get(qValue, array.size(qValue) - 1)
                    array.pop(qType)
                    array.pop(qValue)
                    array.pop(qIndex)
                    array.push(qType, array.size(qType) > 2 ? (array.get(qValue, array.size(qValue) - 2) < HighValue ? "HH" : "LH") : "H")
                    array.push(qValue, HighValue)
                    array.push(qIndex, HighIndex)
            else if array.get(qType, array.size(qType) - 1) == "L" or array.get(qType, array.size(qType) - 1) == "HL" or array.get(qType, array.size(qType) - 1) == "LL"
                if array.get(qValue, array.size(qValue) - 1) > LowValue
                    array.pop(qType)
                    array.pop(qValue)
                    array.pop(qIndex)
                    array.push(qType, array.size(qType) > 2 ? (array.get(qValue, array.size(qValue) - 2) < LowValue ? "HL" : "LL") : "L")
                    array.push(qValue, LowValue)
                    array.push(qIndex, LowIndex)
    int sz = array.size(qType)
    if sz > 5
        string TH1 = array.get(qType, sz - 1)
        string TH2 = array.get(qType, sz - 2)
        string TH3 = array.get(qType, sz - 3)
        string TH4 = array.get(qType, sz - 4)
        string TH5 = array.get(qType, sz - 5)
        int IH = array.get(qIndex, sz - 1)
        float VH1 = array.get(qValue, sz - 1)
        float VH2 = array.get(qValue, sz - 2)
        float VH3 = array.get(qValue, sz - 3)
        float VH4 = array.get(qValue, sz - 4)
        float VH5 = array.get(qValue, sz - 5)
        string TL1 = TH1
        string TL2 = TH2
        string TL3 = TH3
        string TL4 = TH4
        string TL5 = TH5
        int IL = IH
        float VL1 = VH1
        float VL2 = VH2
        float VL3 = VH3
        float VL4 = VH4
        float VL5 = VH5
        bool BearQM = TH1 == "LL" and TH2 == "HH" and TH3 == "HL" and TH4 == "HH" and VH5 < VH1 and IH == (bar_index - PP)
        bool BullQM = TL1 == "HH" and TL2 == "LL" and TL3 == "LH" and TL4 == "LL" and VL5 > VL1 and IL == (bar_index - PP)
        if BearQM or BullQM
            if showQmlSnrTl
                if BullQM
                    float lvl = array.get(qValue, sz - 4)
                    int hx2 = na
                    float hy2 = na
                    int hx1 = na
                    float hy1 = na
                    int found = 0
                    for k = 0 to sz - 1
                        int ii = sz - 1 - k
                        string tt = array.get(qType, ii)
                        if tt == "HH" or tt == "LH" or tt == "H"
                            if found == 0
                                hx2 := array.get(qIndex, ii)
                                hy2 := array.get(qValue, ii)
                                found := 1
                            else if found == 1
                                hx1 := array.get(qIndex, ii)
                                hy1 := array.get(qValue, ii)
                                found := 2
                                break
                    if found == 2 and hx2 != hx1
                        qmlTlBuyPending := true
                        qmlTlBuyLevel := lvl
                        qmlTlBuyStartBar := bar_index
                        qmlTlBuyTLx1 := hx1
                        qmlTlBuyTLy1 := hy1
                        qmlTlBuyTLx2 := hx2
                        qmlTlBuyTLy2 := hy2
                        if not na(qmlTlBuyTLLine)
                            line.delete(qmlTlBuyTLLine)
                        if not na(qmlTlBuyLevelLine)
                            line.delete(qmlTlBuyLevelLine)
                        qmlTlBuyTLLine := line.new(hx1, hy1, hx2, hy2, xloc=xloc.bar_index, extend=extend.right, color=colTL, width=2)
                        qmlTlBuyLevelLine := line.new(array.get(qIndex, sz - 4), lvl, bar_index, lvl, xloc=xloc.bar_index, extend=extend.right, color=colQML, width=1, style=line.style_dotted)
                if BearQM
                    float lvl = array.get(qValue, sz - 4)
                    int lx2 = na
                    float ly2 = na
                    int lx1 = na
                    float ly1 = na
                    int found = 0
                    for k = 0 to sz - 1
                        int ii = sz - 1 - k
