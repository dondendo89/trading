sfpUseDailyExtreme = input.bool(true, "Solo vicino a Daily High/Low", group="SFP Lux - Filtri")
sfpDailyExtremeBufferTicks = input.int(20, "Distanza max da Daily (ticks)", minval=0, group="SFP Lux - Filtri")
