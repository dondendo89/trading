//@version=6
indicator("Swing Anchored Vwap [BigBeluga] + Alerts", overlay = true, max_polylines_count = 100, max_bars_back = 5000)

useTfLen = input.bool(true, "Usa periodo per TF (M1/M5/M15/H1/H4)", group="Length")
length = input.int(50, "Length (fallback)", minval=1, group="Length")
len_M1 = input.int(50, "M1 - Length", minval=1, group="Length")
len_M5 = input.int(50, "M5 - Length", minval=1, group="Length")
len_M15 = input.int(50, "M15 - Length", minval=1, group="Length")
len_H1 = input.int(50, "H1 - Length", minval=1, group="Length")
len_H4 = input.int(50, "H4 - Length", minval=1, group="Length")
l_vwap_col = input.color(color.lime, "", inline = "col")
h_vwap_col = input.color(color.blue, "", inline = "col")
width1 = input.int(1, "Vwap Line Width")
alertsEnabled = input.bool(true, "Alert Swing HIGH/LOW")

var trend = bool(na)
var high_index = int(na)
var high_val = float(na)
var low_index = int(na)
var low_val = float(na)

tfMult = timeframe.multiplier
tfIsM1 = timeframe.isminutes and tfMult == 1
tfIsM5 = timeframe.isminutes and tfMult == 5
tfIsM15 = timeframe.isminutes and tfMult == 15
tfIsH1 = timeframe.isintraday and tfMult == 60
tfIsH4 = timeframe.isintraday and tfMult == 240
lengthSel = useTfLen ? (tfIsM1 ? len_M1 : tfIsM5 ? len_M5 : tfIsM15 ? len_M15 : tfIsH1 ? len_H1 : tfIsH4 ? len_H4 : length) : length

h = ta.highest(lengthSel)
l = ta.lowest(lengthSel)

swingHigh = high[1] == h[1] and high < h
swingLow = low[1] == l[1] and low > l

if alertsEnabled and swingHigh
    alert("BB SWING HIGH", alert.freq_once_per_bar_close)
if alertsEnabled and swingLow
    alert("BB SWING LOW", alert.freq_once_per_bar_close)

if swingHigh
    high_index := bar_index - 1
    high_val := high[1]

h_vwap = ta.vwap(high, swingHigh)

if swingLow
    low_index := bar_index - 1
    low_val := low[1]

l_vwap = ta.vwap(low, swingLow)

if high == h
    trend := true
if low == l
    trend := false

draw_active_vwap(_trend)=>
    src = _trend ? high : low
    index = _trend ? low_index : high_index
    vwapColor = _trend ? l_vwap_col : h_vwap_col
    stl = _trend ? label.style_label_up : label.style_label_down

    if _trend or not _trend
        var polyline poly = na
        var lbl = label(na)
        var lbl1 = label(na)
        var line_ = line(na)
        poly.delete()
        lbl.delete()
        lbl1.delete()
        line_.delete()

        cp = array.new<chart.point>()
        for i = 0 to bar_index - index
            vwap_ = _trend ? l_vwap[i] : h_vwap[i]
            if i == 0
                line_ := line.new(bar_index, vwap_, bar_index + 5, vwap_, color = vwapColor, width = 2, style = line.style_arrow_right)
                lbl1 := label.new(bar_index + 5, vwap_, str.tostring(vwap_, "###,###,###.##"), color = #00000000, style = label.style_label_left, textcolor = chart.fg_color)
            if i == bar_index - index
                lbl := label.new(bar_index - i, src[i], color = vwapColor, style = stl)
            cp_ = chart.point.from_index(bar_index - i, vwap_)
            cp.push(cp_)
        poly := polyline.new(cp, line_color = vwapColor, line_width = 2)

draw_active_vwap(trend)

if trend and trend != trend[1]
    cp = array.new<chart.point>()
    for i = 0 to bar_index - high_index
        if i == bar_index - high_index
            label.new(bar_index - i, high[i], color = color.new(h_vwap_col, 40), style = label.style_label_down)
        cp_ = chart.point.from_index(bar_index - i, h_vwap[i])
        cp.push(cp_)
    polyline.new(cp, line_color = color.new(h_vwap_col, 30), line_width = width1)

if not trend and trend != trend[1]
    cp = array.new<chart.point>()
    for i = 0 to bar_index - low_index
        if i == bar_index - low_index
            label.new(bar_index - i, low[i], color = color.new(l_vwap_col, 40), style = label.style_label_up)
        cp_ = chart.point.from_index(bar_index - i, l_vwap[i])
        cp.push(cp_)
    polyline.new(cp, line_color = color.new(l_vwap_col, 40), line_width = width1)
