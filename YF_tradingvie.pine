                label ls = label.new(array.get(qIndex, sz - 1) + mv + 1, array.get(qValue, sz - 2) - ATR / 2, "SL", xloc=xloc.bar_index, style=label.style_text_outline, color=color.rgb(255, 255, 255, 100))
                label lt1 = label.new(array.get(qIndex, sz - 1) + mv + 1, array.get(qValue, sz - 3), "TP1", xloc=xloc.bar_index, style=label.style_text_outline, color=color.rgb(255, 255, 255, 100))
