//@version=5
indicator("Matteo Capital - Box Session & Signals Final FIXED V3", overlay=true, max_labels_count=500, max_lines_count=500)

// --- INPUT ---
showSessions = input.bool(false, "Mostra Box Sessioni (Asia, London, NY)")
showSessionNames = input.bool(true, "Mostra Nomi Sessioni (Asia, London, NY)")
showDailyHL  = input.bool(true, "Mostra Daily High/Low")
showDailyOpen = input.bool(false, "Mostra Daily Open (line viola)")
showNYOpen   = input.bool(true, "Mostra NY Open (14:30)")
showA2NRange = input.bool(true, "Mostra Range 00:00→NY (Max/Min)")
showMidnightLines = input.bool(true, "Mostra Linee 00:00 (High/Low)")
show02CandleLines = input.bool(true, "Mostra Linee 02:00 (High/Low)")
showAsiaBiasArrow = input.bool(true, "Freccia Asia @09:00")
useAsiaLondonSell13 = input.bool(true, "Sell @13 se Asia+02 sopra London")
hsEnabled = input.bool(true, "Hammer & Shooting")
hsFibLevel = input.float(defval=0.382, title="Hammer Fib Level", options=[0.236, 0.382, 0.5])
hsConfirm = input.bool(defval=true, title="Hammer Confirm next candle")
hsShowLabels = input.bool(defval=true, title="Hammer Show labels")
hsFibRetraceEnabled = input.bool(true, "Hammer Fib Retrace (0.5/0.382)")
hsFibUse05 = input.bool(true, "Fib 0.5")
hsFibUse0382 = input.bool(true, "Fib 0.382")

useDailyOpenFilter     = input.bool(true, "Filtro Daily Open (Midnight)")
useIbMidFilter         = input.bool(true, "Filtro IB Mid")
requireManipulation    = input.bool(false, "Richiedi Manipolazione (Sweep)")
sweepBufferTicks       = input.int(0, "Sweep buffer (ticks)", minval=0)
reclaimMaxBars         = input.int(6, "Reclaim max bars", minval=1)
midnightSignalsEnabled = input.bool(true, "Segnali Midnight (Sweep & Reclaim)")

retestToleranceTicks = input.int(5, "Tolleranza Bacio (Ticks)", minval=0, group="Logica Matteo Capital")
requireSweepBeforeKiss = input.bool(true, "Richiedi Sweep prima del Bacio", group="Logica Matteo Capital")
sweepOutsideKillzone = input.bool(false, "Sweep fuori Killzone", group="Logica Matteo Capital")
kissOutsideKillzone = input.bool(false, "KISS fuori Killzone", group="Logica Matteo Capital")
kissSignalsEnabled = input.bool(true, "Segnali KISS (BUY/SELL)", group="Logica Matteo Capital")
buySellSignalsEnabled = input.bool(true, "Segnali BUY/SELL", group="Logica Matteo Capital")

luxEnabled = input.bool(true, "Swing Patterns Lux", group="Lux Swing")
luxLen = input.int(21, "Length", minval=1, group="Lux Swing")
luxShowLabels = input.bool(true, "Show Labels", group="Lux Swing")
luxSwingHColor = input.color(color.red, "Swing High", group="Lux Swing")
luxSwingLColor = input.color(color.teal, "Swing Low", group="Lux Swing")
luxNotifyEnabled = input.bool(true, "Notifiche Lux (alert)", group="Lux Swing")
luxNotifySwings = input.bool(true, "Notifica Swing HH/HL", group="Lux Swing")
luxNotifyPatterns = input.bool(true, "Notifica Candle Patterns", group="Lux Swing")
luxNotifyHammer = input.bool(true, "Hammer", group="Lux Swing")
luxNotifyInvertedHammer = input.bool(true, "Inverted Hammer", group="Lux Swing")
luxNotifyBullishEngulfing = input.bool(true, "Bullish Engulfing", group="Lux Swing")
luxNotifyHangingMan = input.bool(true, "Hanging Man", group="Lux Swing")
luxNotifyShootingStar = input.bool(true, "Shooting Star", group="Lux Swing")
luxNotifyBearishEngulfing = input.bool(true, "Bearish Engulfing", group="Lux Swing")
luxNotifyNone = input.bool(true, "None", group="Lux Swing")

instEnabled = input.bool(true, "Sweep institutional", group="Sweep institutional")
instCooldownPeriod = input.int(10, title="Cooldown Period", minval=0, group="Sweep institutional")
instShowSwing = input.bool(true, title="Show Swings?", inline="s_1", group="Sweep institutional")
instSwingClr = input.color(color.new(color.black, 0), title="", inline="s_1", group="Sweep institutional")
instBullWidth = input.int(1, title="Line Width:", group="Sweep institutional Bullish")
instBullStyle = input.string("Dashed", title="Line Style:", options=["Solid", "Dotted", "Dashed"], group="Sweep institutional Bullish")
instBullColor = input.color(color.new(color.teal, 0), title="Bullish Color:", group="Sweep institutional Bullish")
instBearWidth = input.int(1, title="Line Width:", group="Sweep institutional Bearish")
instBearStyle = input.string("Dashed", title="Line Style:", options=["Solid", "Dotted", "Dashed"], group="Sweep institutional Bearish")
instBearColor = input.color(color.new(color.maroon, 0), title="Bearish Color:", group="Sweep institutional Bearish")

SmtEnabled = input.bool(false, "SMT", group="SMT")
SmtSymbol1 = input.symbol("TVC:DXY", "SMT Symbol 1", group="SMT")
SmtUseSymbol2 = input.bool(false, "Usa Symbol 2", group="SMT")
SmtSymbol2 = input.symbol("OANDA:EURUSD", "SMT Symbol 2", group="SMT")
SmtInverseOn = input.string("Nessuno", "Inversione", options=["Nessuno", "Symbol 1", "Symbol 2"], group="SMT")
SmtUseTfPivots = input.bool(true, "Usa pivot per TF (M1/M15/H1/H4)", group="SMT")
SmtPivotLen_M1 = input.int(1, "M1 - Pivot candele", minval=1, group="SMT")
SmtPivotLen_M15 = input.int(1, "M15 - Pivot candele", minval=1, group="SMT")
SmtPivotLen_H1 = input.int(1, "H1 - Pivot candele", minval=1, group="SMT")
SmtPivotLen_H4 = input.int(1, "H4 - Pivot candele", minval=1, group="SMT")
SmtPivotLen = input.int(1, "Pivot candele (fallback)", minval=1, group="SMT")
SmtShowLabels = input.bool(true, "Mostra etichette", group="SMT")

dashEnabled = input.bool(true, "Dashboard SH/SL (H1/H4)", group="Dashboard")
dashPos = input.string("Top Right", "Posizione", options=["Top Right", "Top Left", "Bottom Right", "Bottom Left"], group="Dashboard")
dashTextSize = input.string("Small", "Testo", options=["Tiny", "Small", "Normal"], group="Dashboard")

earlySwingEnabled = input.bool(true, "Early Swing Anticipation", group="Early Swing")
earlyShowPossibleSWH = input.bool(true, "Mostra Possible SWH", group="Early Swing")
earlyLeftBars = input.int(2, "Candele Sinistra", minval=1, group="Early Swing")
earlyRightBars = input.int(2, "Candele Destra Conferma", minval=1, group="Early Swing")
earlyVolFilter = input.bool(true, "Filtro Volume", group="Early Swing")
earlyShowLabels = input.bool(true, "Mostra Etichette", group="Early Swing")
earlyShowDailyExtremeShSl = input.bool(false, "Filtro Daily High/Low", group="Early Swing")
earlyDailyExtremeBufferTicks = input.int(0, "Distanza max da Daily High/Low (ticks)", minval=0, group="Early Swing")

swingPatternEnabled = input.bool(true, "Swing Pattern (Swing High/Low)", group="Swing Pattern")
swingPatternLeftBars = input.int(2, "Candele Sinistra", minval=1, group="Swing Pattern")
swingPatternRightBars = input.int(2, "Candele Destra", minval=1, group="Swing Pattern")
swingPatternUseTfBars = input.bool(true, "Usa Candele Sinistra/Destra per TF (M1/M15/H1/H4)", group="Swing Pattern")
swingPatternLeftBars_M1 = input.int(2, "M1 - Candele Sinistra", minval=1, group="Swing Pattern")
swingPatternRightBars_M1 = input.int(2, "M1 - Candele Destra", minval=1, group="Swing Pattern")
swingPatternLeftBars_M15 = input.int(2, "M15 - Candele Sinistra", minval=1, group="Swing Pattern")
swingPatternRightBars_M15 = input.int(2, "M15 - Candele Destra", minval=1, group="Swing Pattern")
swingPatternLeftBars_H1 = input.int(2, "H1 - Candele Sinistra", minval=1, group="Swing Pattern")
swingPatternRightBars_H1 = input.int(2, "H1 - Candele Destra", minval=1, group="Swing Pattern")
swingPatternLeftBars_H4 = input.int(2, "H4 - Candele Sinistra", minval=1, group="Swing Pattern")
swingPatternRightBars_H4 = input.int(2, "H4 - Candele Destra", minval=1, group="Swing Pattern")
swingUseInstitutionalSwings = input.bool(false, "Usa swing tipo Sweep institutional", group="Swing Pattern")
swingPatternOnlyAlerts = input.bool(true, "Solo notifica Swing Pattern", group="Swing Pattern")
swingRequireReclaimAfterSweep = input.bool(false, "Mostra solo dopo reclaim Sweep recente", group="Swing Pattern")
swingRequireOppositeSwingSweep = input.bool(false, "Richiedi sweep ultimo swing opposto", group="Swing Pattern")
swingOppositeSwingSweepBufferTicks = input.int(0, "Buffer sweep swing opposto (ticks)", minval=0, group="Swing Pattern")
swingRequireH13L13Sweep = input.bool(false, "Richiedi sweep H13/L13", group="Swing Pattern")
swingRequireAsiaSweep = input.bool(false, "Richiedi sweep Asia High/Low", group="Swing Pattern")
swingAsiaSweepWindow = input.session("0800-1100", "Finestra sweep Asia", group="Swing Pattern")
swingRequireIBSweep = input.bool(false, "Richiedi sweep IB High/Low", group="Swing Pattern")
swingIBSweepWindow = input.session("1000-1300", "Finestra sweep IB", group="Swing Pattern")
swingShowOverLowL13 = input.bool(false, "Segnale Over Low (sotto L13)", group="Swing Pattern")
swingOverLowL13BufferTicks = input.int(0, "Buffer Over Low L13 (ticks)", minval=0, group="Swing Pattern")
swingShowDailyExtremeShSl = input.bool(false, "Mostra SH vicino a Daily High e SL vicino a Daily Low", group="Swing Pattern")
swingDailyExtremeBufferTicks = input.int(0, "Distanza max da Daily High/Low (ticks)", minval=0, group="Swing Pattern")
swingShowSessionExtremeShSl = input.bool(false, "Filtro Session High/Low (Asia/London/NY)", group="Swing Pattern")
swingSessionUseAsia = input.bool(true, "Usa Asia", group="Swing Pattern")
swingSessionUseLondon = input.bool(true, "Usa London", group="Swing Pattern")
swingSessionUseNy = input.bool(true, "Usa NY", group="Swing Pattern")
swingSessionExtremeBufferTicks = input.int(0, "Distanza max da Session High/Low (ticks)", minval=0, group="Swing Pattern")
swingMinSwingRangeTicks = input.int(0, "Min range swing (ticks)", minval=0, group="Swing Pattern")
swingMinReactionSepTicks = input.int(1, "Min distanza reazione (ticks)", minval=0, group="Swing Pattern")
swingConfirmBos = input.bool(true, "Conferma BOS (close)", group="Swing Pattern")
swingBullDivEnabled = input.bool(true, "Divergenza Bullish (RSI)", group="Swing Pattern")
swingBullDivRsiLen = input.int(14, "RSI Length", minval=2, group="Swing Pattern")
swingDivUseRsiThresholds = input.bool(true, "Filtro soglie RSI", group="Swing Pattern")
swingDivBullPrevRsiMax = input.int(40, "RSI max 1° low", minval=1, maxval=50, group="Swing Pattern")
swingDivBearPrevRsiMin = input.int(60, "RSI min 1° high", minval=50, maxval=99, group="Swing Pattern")
swingDivMinRsiDelta = input.float(0.0, "Min delta RSI", minval=0.0, step=0.1, group="Swing Pattern")
swingRsiFilterEnabled = input.bool(false, "Filtro RSI (SH/SL)", group="Swing Pattern")
swingRsiMode = input.string("Conservative", "RSI Mode", options=["Aggressive", "Conservative"], group="Swing Pattern")
swingRsiBuyAgg = input.int(30, "RSI BUY Aggressive (≤)", minval=1, maxval=50, group="Swing Pattern")
swingRsiBuyCons = input.int(40, "RSI BUY Conservative (≤)", minval=1, maxval=50, group="Swing Pattern")
swingRsiSellAgg = input.int(70, "RSI SELL Aggressive (≥)", minval=50, maxval=99, group="Swing Pattern")
swingRsiSellCons = input.int(60, "RSI SELL Conservative (≥)", minval=50, maxval=99, group="Swing Pattern")
swingMacdConfirmEnabled = input.bool(false, "Conferma MACD cross", group="Swing Pattern")

// --- CONFIGURAZIONE ORARI (Roma) ---
tz = "Europe/Rome"

isAfterNyClose = not na(time(timeframe.period, "2100-2359", tz))
showUntilNyClose = not isAfterNyClose

instLineStyle(s) =>
    s == "Solid" ? line.style_solid : s == "Dotted" ? line.style_dotted : line.style_dashed

f_dashPos(_s) =>
    _s == "Top Left" ? position.top_left : _s == "Bottom Right" ? position.bottom_right : _s == "Bottom Left" ? position.bottom_left : position.top_right

f_dashSize(_s) =>
    _s == "Tiny" ? size.tiny : _s == "Normal" ? size.normal : size.small

f_pivotStats(_left, _right) =>
    ph = ta.pivothigh(high, _left, _right)
    pl = ta.pivotlow(low, _left, _right)
    shTime = ta.valuewhen(not na(ph), time[_right], 0)
    shPrice = ta.valuewhen(not na(ph), ph, 0)
    slTime = ta.valuewhen(not na(pl), time[_right], 0)
    slPrice = ta.valuewhen(not na(pl), pl, 0)
    [shTime, shPrice, slTime, slPrice]

f_lastType(_shTime, _slTime) =>
    na(_shTime) and na(_slTime) ? "—" : na(_slTime) ? "SH" : na(_shTime) ? "SL" : _shTime > _slTime ? "SH" : _slTime > _shTime ? "SL" : "SH/SL"

f_cellTxt(_t, _p) =>
    na(_t) ? "—" : str.format("{0,date,dd/MM HH:mm}", _t) + "\n" + str.tostring(_p, format.mintick)

// --- 1. DAILY OPEN, HIGH, LOW ---
is_0000 = hour(time, tz) == 0 and minute(time, tz) == 0
isNewDay = year(time, tz) != year(time[1], tz) or month(time, tz) != month(time[1], tz) or dayofmonth(time, tz) != dayofmonth(time[1], tz)
var float dHigh = na
var float dLow = na
var float dailyOpen = na

if is_0000 or isNewDay
    dailyOpen := open
    dHigh := high
    dLow := low
else
    dHigh := math.max(dHigh, high)
    dLow := math.min(dLow, low)

plot(showUntilNyClose and showDailyOpen ? dailyOpen : na, "Daily Open", color.new(color.purple, 50), 1, plot.style_linebr)
plot(showUntilNyClose and showDailyHL ? dHigh : na, "Daily High", color.white, 1, plot.style_linebr)
plot(showUntilNyClose and showDailyHL ? dLow : na, "Daily Low", color.white, 1, plot.style_linebr)

var label dHighLbl = na
var label dLowLbl = na
if showUntilNyClose and showDailyHL and not na(dHigh) and not na(dLow)
    if na(dHighLbl)
        dHighLbl := label.new(bar_index, dHigh, "Daily High", color=color.new(color.white, 100), textcolor=color.red, style=label.style_label_right, size=size.small)
    else
        label.set_x(dHighLbl, bar_index)
        label.set_y(dHighLbl, dHigh)
    if na(dLowLbl)
        dLowLbl := label.new(bar_index, dLow, "Daily Low", color=color.new(color.white, 100), textcolor=color.red, style=label.style_label_right, size=size.small)
    else
        label.set_x(dLowLbl, bar_index)
        label.set_y(dLowLbl, dLow)
else
    if not na(dHighLbl)
        label.delete(dHighLbl)
        dHighLbl := na
    if not na(dLowLbl)
        label.delete(dLowLbl)
        dLowLbl := na

// --- 2. NY OPEN (14:30) ---
var float nyOpenPrice = na
isAfterNyOpen = not na(time(timeframe.period, "1430-2359", tz))
nyOpenFrom1m = request.security(syminfo.tickerid, "1", ta.valuewhen(hour(time, tz) == 14 and minute(time, tz) == 30, open, 0), barmerge.gaps_off, barmerge.lookahead_off)
if is_0000
    nyOpenPrice := na
if isAfterNyOpen and not na(nyOpenFrom1m)
    nyOpenPrice := nyOpenFrom1m

plot(showUntilNyClose and showNYOpen ? nyOpenPrice : na, "NY Open Line", color.blue, 2, plot.style_linebr)

var label nyOpenLbl = na
if showUntilNyClose and showNYOpen and not na(nyOpenPrice)
    if na(nyOpenLbl)
        nyOpenLbl := label.new(bar_index, nyOpenPrice, "NY Open", color=color.new(color.white, 100), textcolor=color.red, style=label.style_label_right, size=size.small)
    else
        label.set_x(nyOpenLbl, bar_index)
        label.set_y(nyOpenLbl, nyOpenPrice)
else
    if not na(nyOpenLbl)
        label.delete(nyOpenLbl)
        nyOpenLbl := na

// --- 3. FUNZIONE BOX SESSIONI ---
var box asiaBox = na, var box londonBox = na, var box nyBox = na
var label asiaLab = na, var label londonLab = na, var label nyLab = na
var float aHigh = na, var float aLow = na
var float lHigh = na, var float lLow = na
var float nHigh = na, var float nLow = na

var float asiaOpen = na
var float asiaClose = na
var float asiaHigh = na
var float asiaLow = na
isInAsia = not na(time(timeframe.period, "0000-0800", tz))
if is_0000
    asiaOpen := na
    asiaClose := na
    asiaHigh := na
    asiaLow := na
if isInAsia
    if not isInAsia[1]
        asiaOpen := open
        asiaHigh := high
        asiaLow := low
    asiaClose := close
    asiaHigh := math.max(nz(asiaHigh, high), high)
    asiaLow := math.min(nz(asiaLow, low), low)

var float londonHighLive = na
var float londonLowLive = na
isInLondon = not na(time(timeframe.period, "0900-1730", tz))
if is_0000
    londonHighLive := na
    londonLowLive := na
if isInLondon
    if not isInLondon[1]
        londonHighLive := high
        londonLowLive := low
    else
        londonHighLive := math.max(nz(londonHighLive, high), high)
        londonLowLive := math.min(nz(londonLowLive, low), low)

var float nyHighLive = na
var float nyLowLive = na
isInNySess = not na(time(timeframe.period, "1430-2100", tz))
if is_0000
    nyHighLive := na
    nyLowLive := na
if isInNySess
    if not isInNySess[1]
        nyHighLive := high
        nyLowLive := low
    else
        nyHighLive := math.max(nz(nyHighLive, high), high)
        nyLowLive := math.min(nz(nyLowLive, low), low)

draw_session(sess_time, sess_name, sess_color, sBox, sLab, sHigh, sLow) =>
    t = time(timeframe.period, sess_time, tz)
    isIn = not na(t)
    isFirst = isIn and na(t[1])
    resHigh = sHigh, resLow = sLow, resBox = sBox, resLab = sLab
    if isFirst
        resHigh := high
        resLow := low
        resBox := box.new(left=bar_index, top=resHigh, right=bar_index, bottom=resLow, bgcolor=color.new(sess_color, 92), border_color=color.new(sess_color, 100), border_width=0)
        if showSessionNames
            resLab := label.new(bar_index, high, sess_name, color=sess_color, textcolor=color.white, style=label.style_label_down, size=size.small)
    else if isIn
        resHigh := math.max(nz(resHigh, high), high)
        resLow := math.min(nz(resLow, low), low)
        box.set_top(resBox, resHigh)
        box.set_bottom(resBox, resLow)
        box.set_right(resBox, bar_index)
        if showSessionNames
            if na(resLab)
                resLab := label.new(bar_index, resHigh, sess_name, color=sess_color, textcolor=color.white, style=label.style_label_down, size=size.small)
            label.set_x(resLab, bar_index)
            label.set_y(resLab, resHigh)
        else
            if not na(resLab)
                label.delete(resLab)
                resLab := na
    [resBox, resLab, resHigh, resLow]

if showSessions
    [b1, l1, h1, lw1] = draw_session("0000-0800", "ASIA", color.green, asiaBox, asiaLab, aHigh, aLow)
    asiaBox := b1, asiaLab := l1, aHigh := h1, aLow := lw1
    [b2, l2, h2, lw2] = draw_session("0900-1730", "LONDON", color.blue, londonBox, londonLab, lHigh, lLow)
    londonBox := b2, londonLab := l2, lHigh := h2, lLow := lw2
    [b3, l3, h3, lw3] = draw_session("1430-2100", "NY", color.orange, nyBox, nyLab, nHigh, nLow)
    nyBox := b3, nyLab := l3, nHigh := h3, nLow := lw3

// --- 4. INITIAL BALANCE (09:00 - 10:00) ---
isInIB = not na(time(timeframe.period, "0900-1000", tz))
isAfterIBStart = not na(time(timeframe.period, "0900-2359", tz))
var float ibH = na
var float ibL = na
if is_0000
    ibH := na
    ibL := na
if isInIB
    if not isInIB[1]
        ibH := high
        ibL := low
    else
        ibH := math.max(ibH, high)
        ibL := math.min(ibL, low)
ibMid = (ibH + ibL) / 2
plot(showUntilNyClose and isAfterIBStart ? ibH : na, "IB High", color.new(color.blue, 40), 1, plot.style_linebr)
plot(showUntilNyClose and isAfterIBStart ? ibL : na, "IB Low", color.new(color.blue, 40), 1, plot.style_linebr)

var float orangeH = na
var float orangeL = na

if is_0000
    orangeH := na
    orangeL := na

orangeH60 = request.security(syminfo.tickerid, "60", ta.valuewhen(hour(time, tz) == 13 and minute(time, tz) == 0, high, 0), barmerge.gaps_off, barmerge.lookahead_off)
orangeL60 = request.security(syminfo.tickerid, "60", ta.valuewhen(hour(time, tz) == 13 and minute(time, tz) == 0, low, 0), barmerge.gaps_off, barmerge.lookahead_off)
orangeT60 = request.security(syminfo.tickerid, "60", ta.valuewhen(hour(time, tz) == 13 and minute(time, tz) == 0, time, 0), barmerge.gaps_off, barmerge.lookahead_off)
orangeIsToday = not na(orangeT60) and dayofmonth(orangeT60, tz) == dayofmonth(time, tz) and month(orangeT60, tz) == month(time, tz) and year(orangeT60, tz) == year(time, tz)
if orangeIsToday and not na(orangeH60) and not na(orangeL60)
    orangeH := orangeH60
    orangeL := orangeL60

plot(showUntilNyClose and orangeIsToday and not na(orangeH) ? orangeH : na, "H13", color.orange, 2, plot.style_linebr)
plot(showUntilNyClose and orangeIsToday and not na(orangeL) ? orangeL : na, "L13", color.orange, 2, plot.style_linebr)

is_0200 = hour(time, tz) == 2 and minute(time, tz) == 0
isAfter02 = not na(time(timeframe.period, "0200-2359", tz))
var float c02H = na
var float c02L = na
if is_0000
    c02H := na
    c02L := na
if is_0200
    c02H := high
    c02L := low
plot(showUntilNyClose and show02CandleLines and isAfter02 ? c02H : na, "02 High", color.green, 2, plot.style_linebr)
plot(showUntilNyClose and show02CandleLines and isAfter02 ? c02L : na, "02 Low", color.green, 2, plot.style_linebr)

is_1300 = hour(time, tz) == 13 and minute(time, tz) == 0
c02AboveLondon = not na(c02H) and not na(c02L) and not na(londonHighLive) and c02H > londonHighLive and c02L > londonHighLive
var label[] mcSigLabels = array.new_label()
f_addSigLabel(_x, _y, _txt, _bg, _tc, _style, _size) =>
    lb = label.new(_x, _y, _txt, xloc=xloc.bar_index, style=_style, color=_bg, textcolor=_tc, size=_size)
    array.push(mcSigLabels, lb)
    if array.size(mcSigLabels) > 450
        label.delete(array.shift(mcSigLabels))
    lb

if useAsiaLondonSell13 and is_1300 and c02AboveLondon
    f_addSigLabel(bar_index, high, "SELL", color.red, color.white, label.style_label_down, size.small)

midCandleHigh = request.security(syminfo.tickerid, "1", ta.valuewhen(hour(time, tz) == 0 and minute(time, tz) == 0, high, 0), barmerge.gaps_off, barmerge.lookahead_on)
midCandleLow  = request.security(syminfo.tickerid, "1", ta.valuewhen(hour(time, tz) == 0 and minute(time, tz) == 0, low, 0), barmerge.gaps_off, barmerge.lookahead_on)

newDayRome = na(time[1]) ? true : dayofmonth(time, tz) != dayofmonth(time[1], tz)
midCandlePlotHigh = newDayRome ? na : midCandleHigh
midCandlePlotLow = newDayRome ? na : midCandleLow
plot(showUntilNyClose and showMidnightLines ? midCandlePlotHigh : na, "00 High", color.green, 2, plot.style_linebr)
plot(showUntilNyClose and showMidnightLines ? midCandlePlotLow : na, "00 Low", color.green, 2, plot.style_linebr)

var line a2nHighLine = na
var line a2nLowLine = na
if newDayRome
    if not na(a2nHighLine)
        line.delete(a2nHighLine)
        a2nHighLine := na
    if not na(a2nLowLine)
        line.delete(a2nLowLine)
        a2nLowLine := na
    if showA2NRange
        a2nHighLine := line.new(bar_index, midCandleHigh, bar_index, midCandleHigh, extend=extend.none, color=color.green, width=2)
        a2nLowLine := line.new(bar_index, midCandleLow, bar_index, midCandleLow, extend=extend.none, color=color.green, width=2)

if not showA2NRange
    if not na(a2nHighLine)
        line.delete(a2nHighLine)
        a2nHighLine := na
    if not na(a2nLowLine)
        line.delete(a2nLowLine)
        a2nLowLine := na
else
    if showUntilNyClose
        if not na(a2nHighLine) and not na(midCandleHigh)
            line.set_xy1(a2nHighLine, line.get_x1(a2nHighLine), midCandleHigh)
            line.set_xy2(a2nHighLine, bar_index, midCandleHigh)
        if not na(a2nLowLine) and not na(midCandleLow)
            line.set_xy1(a2nLowLine, line.get_x1(a2nLowLine), midCandleLow)
            line.set_xy2(a2nLowLine, bar_index, midCandleLow)

buf = sweepBufferTicks * syminfo.mintick

var float midH = na
var float midL = na
var int midSweepDownBar = na
var int midSweepUpBar = na
var bool midLongDone = false
var bool midShortDone = false

if is_0000
    midH := high
    midL := low
    midSweepDownBar := na
    midSweepUpBar := na
    midLongDone := false
    midShortDone := false

if not na(midL) and na(midSweepDownBar) and low < (midL - buf)
    midSweepDownBar := bar_index
if not na(midH) and na(midSweepUpBar) and high > (midH + buf)
    midSweepUpBar := bar_index

midSweepDown = not na(midSweepDownBar)
midSweepUp = not na(midSweepUpBar)

newDay = year(time, tz) != year(time[1], tz) or month(time, tz) != month(time[1], tz) or dayofmonth(time, tz) != dayofmonth(time[1], tz)
midPlotH = newDay ? na : midH
midPlotL = newDay ? na : midL
plot(showUntilNyClose and showA2NRange ? midPlotH : na, "MID High", color.green, 2, plot.style_linebr)
plot(showUntilNyClose and showA2NRange ? midPlotL : na, "MID Low", color.green, 2, plot.style_linebr)

var int ibSweepDownBar = na
var int ibSweepUpBar = na
if is_0000
    ibSweepDownBar := na
    ibSweepUpBar := na

if not na(ibL) and na(ibSweepDownBar) and low < (ibL - buf)
    ibSweepDownBar := bar_index
if not na(ibH) and na(ibSweepUpBar) and high > (ibH + buf)
    ibSweepUpBar := bar_index

ibSweepDown = not na(ibSweepDownBar)
ibSweepUp = not na(ibSweepUpBar)

// --- 6. LOGICA SEGNALI ---
isKill = not na(time(timeframe.period, "1430-1630", tz))
is1m = timeframe.isminutes and timeframe.multiplier == 1
isStar13 = is1m ? (hour(time, tz) == 12 and minute(time, tz) == 59) : (hour(time, tz) == 13 and minute(time, tz) == 0)
isStar16 = is1m ? (hour(time, tz) == 15 and minute(time, tz) == 59) : (hour(time, tz) == 16 and minute(time, tz) == 0)
is_0900 = hour(time, tz) == 9 and minute(time, tz) == 0
asiaRangeHas = not na(asiaHigh) and not na(asiaLow)
asiaBiasBuy = asiaRangeHas and is_0900 and low > asiaHigh
asiaBiasSell = asiaRangeHas and is_0900 and high < asiaLow
var bool bDone = false
var bool sDone = false
if is_0000
    bDone := false
    sDone := false

var bool sweptH = false
var bool sweptL = false
var bool bacioDoneB = false
var bool bacioDoneS = false

if is_0000
    sweptH := false
    sweptL := false
    bacioDoneB := false
    bacioDoneS := false

if isKill or sweepOutsideKillzone
    if not na(orangeH) and high > orangeH
        sweptH := true
    if not na(orangeL) and low < orangeL
        sweptL := true

tol = retestToleranceTicks * syminfo.mintick
kissWindowOk = isKill or kissOutsideKillzone
validKISS_BUY = kissSignalsEnabled and kissWindowOk and not na(orangeL) and (not requireSweepBeforeKiss or sweptL) and not bacioDoneB and low <= (orangeL + tol) and close > orangeL
validKISS_SELL = kissSignalsEnabled and kissWindowOk and not na(orangeH) and (not requireSweepBeforeKiss or sweptH) and not bacioDoneS and high >= (orangeH - tol) and close < orangeH

if validKISS_BUY
    bacioDoneB := true
if validKISS_SELL
    bacioDoneS := true

dailyOkB = (not useDailyOpenFilter) or (close > dailyOpen)
dailyOkS = (not useDailyOpenFilter) or (close < dailyOpen)
ibOkB = (not useIbMidFilter) or (close > ibMid)
ibOkS = (not useIbMidFilter) or (close < ibMid)
manipOkB = (not requireManipulation) or midSweepDown or ibSweepDown
manipOkS = (not requireManipulation) or midSweepUp or ibSweepUp

validB = buySellSignalsEnabled and close > orangeH and isKill and not bDone and dailyOkB and ibOkB and manipOkB
validS = buySellSignalsEnabled and close < orangeL and isKill and not sDone and dailyOkS and ibOkS and manipOkS

if validB
    bDone := true
if validS
    sDone := true

if validKISS_BUY
    f_addSigLabel(bar_index, low, "KISS\nBUY", color.green, color.white, label.style_label_up, size.small)
if validKISS_SELL
    f_addSigLabel(bar_index, high, "KISS\nSELL", color.red, color.white, label.style_label_down, size.small)
if sweptL and not sweptL[1]
    f_addSigLabel(bar_index, low, "Swept", color.red, color.white, label.style_label_up, size.tiny)
if sweptH and not sweptH[1]
    f_addSigLabel(bar_index, high, "Swept", color.red, color.white, label.style_label_down, size.tiny)

overLowBuf = swingOverLowL13BufferTicks * syminfo.mintick
overLowL13 = showUntilNyClose and orangeIsToday and not na(orangeL) and ta.crossunder(low, orangeL - overLowBuf)
if swingShowOverLowL13 and overLowL13
    f_addSigLabel(bar_index, low, "OVER\nLOW", color.new(color.red, 0), color.white, label.style_label_up, size.tiny)
alertcondition(not swingPatternOnlyAlerts and swingShowOverLowL13 and overLowL13, title="Over Low (L13)", message="{{ticker}} Over Low (sotto L13)")

plotshape(isStar13, title="13:00", style=shape.labelup, location=location.belowbar, color=color.yellow, text="★", textcolor=color.black, size=size.tiny)
plotshape(isStar16, title="16:00", style=shape.labelup, location=location.belowbar, color=color.yellow, text="★", textcolor=color.black, size=size.tiny)
if validB
    f_addSigLabel(bar_index, low, "BUY", color.green, color.white, label.style_label_up, size.small)
if validS
    f_addSigLabel(bar_index, high, "SELL", color.red, color.white, label.style_label_down, size.small)
if showAsiaBiasArrow and asiaBiasBuy
    f_addSigLabel(bar_index, low, "A", color.green, color.white, label.style_label_up, size.small)
if showAsiaBiasArrow and asiaBiasSell
    f_addSigLabel(bar_index, low, "A", color.red, color.white, label.style_label_down, size.small)

hsIsGreen = open < close
hsIsRed = open > close
hsCandleSize = math.abs(high - low)
hsIsHammer = high - hsFibLevel * hsCandleSize < math.min(open, close)
hsIsShoot = low + hsFibLevel * hsCandleSize > math.max(open, close)
hsConfirmedHammer = hsConfirm ? hsIsHammer[1] and hsIsGreen : hsIsHammer
hsConfirmedShoot = hsConfirm ? hsIsShoot[1] and hsIsRed : hsIsShoot
hsOffset = hsConfirm ? -1 : 0
plotshape(hsEnabled and hsConfirmedHammer, title="Hammer", style=shape.arrowup, location=location.belowbar, color=color.green, textcolor=color.green, text="Hammer", offset=hsOffset, display=hsShowLabels ? display.all : display.none)
plotshape(hsEnabled and hsConfirmedShoot, title="Shooting", style=shape.arrowdown, location=location.abovebar, color=color.red, textcolor=color.red, text="Shooting", offset=hsOffset, display=hsShowLabels ? display.all : display.none)

var line hsFib0 = na
var line hsFib0382 = na
var line hsFib05 = na
var line hsFib1 = na
var line hsFibDiag = na
var int hsFibPatternIndex = na
var float hsFibHigh = na
var float hsFibLow = na
var int hsFibDir = 0
var bool hsFibPending = false
var int hsFibExpiry = na

hsBuyTouch = false
hsSellTouch = false
deleteFibNow = false
createFibNow = false

if hsEnabled and hsFibRetraceEnabled
    newHammer = hsConfirmedHammer
    newShoot = hsConfirmedShoot
    if newHammer or newShoot
        createFibNow := true
        hsFibPatternIndex := hsConfirm ? (bar_index - 1) : bar_index
        hsFibHigh := hsConfirm ? high[1] : high
        hsFibLow := hsConfirm ? low[1] : low
        hsFibDir := newHammer ? 1 : -1
        hsFibPending := true
        hsFibExpiry := hsConfirm ? bar_index : (bar_index + 1)

    if hsFibPending and not na(hsFibHigh) and not na(hsFibLow) and not na(hsFibExpiry)
        if bar_index == hsFibExpiry
            rr = hsFibHigh - hsFibLow
            lv0382 = hsFibLow + 0.382 * rr
            lv05 = hsFibLow + 0.5 * rr
            touched = (hsFibUse05 and low <= lv05 and high >= lv05) or (hsFibUse0382 and low <= lv0382 and high >= lv0382)
            if touched
                hsBuyTouch := hsFibDir == 1
                hsSellTouch := hsFibDir == -1
                hsFibPending := false
            else
                deleteFibNow := true
        else if bar_index > hsFibExpiry
            deleteFibNow := true
else
    deleteFibNow := true

if deleteFibNow or createFibNow
    if not na(hsFib0)
        line.delete(hsFib0)
    if not na(hsFib0382)
        line.delete(hsFib0382)
    if not na(hsFib05)
        line.delete(hsFib05)
    if not na(hsFib1)
        line.delete(hsFib1)
    if not na(hsFibDiag)
        line.delete(hsFibDiag)
    hsFib0 := na
    hsFib0382 := na
    hsFib05 := na
    hsFib1 := na
    hsFibDiag := na
    if deleteFibNow
        hsFibPatternIndex := na
        hsFibHigh := na
        hsFibLow := na
        hsFibDir := 0
        hsFibPending := false
        hsFibExpiry := na

if createFibNow and not na(hsFibPatternIndex) and not na(hsFibHigh) and not na(hsFibLow)
    r = hsFibHigh - hsFibLow
    lv0 = hsFibLow
    lv1 = hsFibHigh
    lv0382 = hsFibLow + 0.382 * r
    lv05 = hsFibLow + 0.5 * r
    hsFib0 := line.new(hsFibPatternIndex, lv0, hsFibPatternIndex + 1, lv0, extend=extend.right, color=color.new(color.gray, 0), width=1)
    hsFib1 := line.new(hsFibPatternIndex, lv1, hsFibPatternIndex + 1, lv1, extend=extend.right, color=color.new(color.gray, 0), width=1)
    if hsFibUse0382
        hsFib0382 := line.new(hsFibPatternIndex, lv0382, hsFibPatternIndex + 1, lv0382, extend=extend.right, color=color.orange, width=2)
    if hsFibUse05
        hsFib05 := line.new(hsFibPatternIndex, lv05, hsFibPatternIndex + 1, lv05, extend=extend.right, color=color.green, width=2)
    hsFibDiag := line.new(hsFibPatternIndex, hsFibHigh, hsFibPatternIndex + 20, hsFibLow, extend=extend.none, color=color.new(color.gray, 30), style=line.style_dashed, width=1)

plotshape(hsBuyTouch, title="Fib Buy (Hammer)", style=shape.triangleup, location=location.belowbar, color=color.lime, size=size.small, text="BUY")
plotshape(hsSellTouch, title="Fib Sell (Shooting)", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small, text="SELL")

canMidLong = midnightSignalsEnabled and midSweepDown and not midLongDone and (bar_index - midSweepDownBar) <= reclaimMaxBars
canMidShort = midnightSignalsEnabled and midSweepUp and not midShortDone and (bar_index - midSweepUpBar) <= reclaimMaxBars

midLong = canMidLong and close > midL and isKill and dailyOkB and ibOkB
midShort = canMidShort and close < midH and isKill and dailyOkS and ibOkS

if midLong
    midLongDone := true
if midShort
    midShortDone := true

plotshape(midLong, "BUY Mid", shape.triangleup, location.belowbar, color.aqua, size=size.small, text="BUY Mid")
plotshape(midShort, "SELL Mid", shape.triangledown, location.abovebar, color.fuchsia, size=size.small, text="SELL Mid")

var float lux_phy = na
var float lux_ply = na

lux_o = open[luxLen]
lux_h = high[luxLen]
lux_l = low[luxLen]
lux_c = close[luxLen]
lux_d = math.abs(lux_c - lux_o)
lux_ph = ta.pivothigh(luxLen, luxLen)
lux_pl = ta.pivotlow(luxLen, luxLen)

lux_has_pl = not na(lux_pl)
lux_has_ph = not na(lux_ph)

lux_hammer = lux_has_pl and math.min(lux_o, lux_c) - lux_l > lux_d and lux_h - math.max(lux_c, lux_o) < lux_d
lux_ihammer = lux_has_pl and lux_h - math.max(lux_c, lux_o) > lux_d and math.min(lux_c, lux_o) - lux_l < lux_d
lux_bulleng = lux_c > lux_o and lux_c[1] < lux_o[1] and lux_c > lux_o[1] and lux_o < lux_c[1]
lux_hanging = lux_has_ph and math.min(lux_c, lux_o) - lux_l > lux_d and lux_h - math.max(lux_o, lux_c) < lux_d
lux_shooting = lux_has_ph and lux_h - math.max(lux_o, lux_c) > lux_d and math.min(lux_c, lux_o) - lux_l < lux_d
lux_beareng = lux_c > lux_o and lux_c[1] < lux_o[1] and lux_c > lux_o[1] and lux_o < lux_c[1]

lux_code = lux_hammer ? 1 : lux_ihammer ? 2 : lux_bulleng ? 3 : lux_hanging ? 4 : lux_shooting ? 5 : lux_beareng ? 6 : 0
lux_title = lux_code == 1 ? "Hammer" : lux_code == 2 ? "Inverted Hammer" : lux_code == 3 ? "Bullish Engulfing" : lux_code == 4 ? "Hanging Man" : lux_code == 5 ? "Shooting Star" : lux_code == 6 ? "Bearish Engulfing" : "None"
luxPatternAllowed = (lux_code == 0 and luxNotifyNone) or (lux_code == 1 and luxNotifyHammer) or (lux_code == 2 and luxNotifyInvertedHammer) or (lux_code == 3 and luxNotifyBullishEngulfing) or (lux_code == 4 and luxNotifyHangingMan) or (lux_code == 5 and luxNotifyShootingStar) or (lux_code == 6 and luxNotifyBearishEngulfing)
luxTitleForLabel = (luxNotifyPatterns and luxPatternAllowed) ? lux_title : ""

if luxEnabled and (lux_has_ph or lux_has_pl)
    if lux_has_ph
        H = na(lux_phy) ? "HH" : (lux_ph > lux_phy ? "HH" : "LH")
        lux_phy := lux_ph
        if luxShowLabels
            label.new(bar_index[luxLen], lux_ph, luxTitleForLabel == "" ? H : (H + "\n" + luxTitleForLabel), color=color.new(color.white, 100), style=label.style_label_down, textcolor=luxSwingHColor, size=size.small)
    else if lux_has_pl
        L = na(lux_ply) ? "HL" : (lux_pl < lux_ply ? "LL" : "HL")
        lux_ply := lux_pl
        if luxShowLabels
            label.new(bar_index[luxLen], lux_pl, luxTitleForLabel == "" ? L : (L + "\n" + luxTitleForLabel), color=color.new(color.white, 100), style=label.style_label_up, textcolor=luxSwingLColor, size=size.small)

alertcondition(luxNotifyEnabled and luxNotifySwings and luxEnabled and lux_has_ph, title="Lux Swing High", message="{{ticker}} Lux Swing High (LuxAlgo)")
alertcondition(luxNotifyEnabled and luxNotifySwings and luxEnabled and lux_has_pl, title="Lux Swing Low", message="{{ticker}} Lux Swing Low (LuxAlgo)")

alertcondition(luxNotifyEnabled and luxNotifyPatterns and luxEnabled and (lux_has_ph or lux_has_pl) and lux_code == 0 and luxNotifyNone, title="Lux None", message="Lux None on {{ticker}} TF={{interval}}")
alertcondition(luxNotifyEnabled and luxNotifyPatterns and luxEnabled and (lux_has_ph or lux_has_pl) and lux_code == 1 and luxNotifyHammer, title="Lux Hammer", message="Lux Hammer on {{ticker}} TF={{interval}}")
alertcondition(luxNotifyEnabled and luxNotifyPatterns and luxEnabled and (lux_has_ph or lux_has_pl) and lux_code == 2 and luxNotifyInvertedHammer, title="Lux Inverted Hammer", message="Lux Inverted Hammer on {{ticker}} TF={{interval}}")
alertcondition(luxNotifyEnabled and luxNotifyPatterns and luxEnabled and (lux_has_ph or lux_has_pl) and lux_code == 3 and luxNotifyBullishEngulfing, title="Lux Bullish Engulfing", message="Lux Bullish Engulfing on {{ticker}} TF={{interval}}")
alertcondition(luxNotifyEnabled and luxNotifyPatterns and luxEnabled and (lux_has_ph or lux_has_pl) and lux_code == 4 and luxNotifyHangingMan, title="Lux Hanging Man", message="Lux Hanging Man on {{ticker}} TF={{interval}}")
alertcondition(luxNotifyEnabled and luxNotifyPatterns and luxEnabled and (lux_has_ph or lux_has_pl) and lux_code == 5 and luxNotifyShootingStar, title="Lux Shooting Star", message="Lux Shooting Star on {{ticker}} TF={{interval}}")
alertcondition(luxNotifyEnabled and luxNotifyPatterns and luxEnabled and (lux_has_ph or lux_has_pl) and lux_code == 6 and luxNotifyBearishEngulfing, title="Lux Bearish Engulfing", message="Lux Bearish Engulfing on {{ticker}} TF={{interval}}")

instLbLeft = 1
instLbRight = 1
var int instBullSignalIndex = 0
var int instBearSignalIndex = 0

var line instBullLine = na
var line instBearLine = na

var line instHighLine = na
var line instLowLine = na

var label instSwingHighLbl = na
var label instSwingLowLbl = na
var label instSwingHighLblTxt = na
var label instSwingLowLblTxt = na

var float instSwingLowVal = na
var float instSwingHighVal = na

var int instSwingLowCounter = 0
var int instSwingHighCounter = 0
var bool instIsSwingLowCheck = false
var bool instIsSwingHighCheck = false
var bool instStopPrintingLow = false
var bool instStopPrintingHigh = false

var instSwingHighArr = array.new_label(0)
var instSwingHighTextArr = array.new_label(0)
var instSwingLowArr = array.new_label(0)
var instSwingLowTextArr = array.new_label(0)

instPL = ta.pivotlow(low, instLbLeft, instLbRight)
instPH = ta.pivothigh(high, instLbLeft, instLbRight)
instPLVal = ta.valuewhen(not na(instPL), low[instLbRight], 0)
instPHVal = ta.valuewhen(not na(instPH), high[instLbRight], 0)
instPrevLowIndex = ta.valuewhen(not na(instPL), bar_index[instLbRight], 0)
instPrevHighIndex = ta.valuewhen(not na(instPH), bar_index[instLbRight], 0)
instLP = ta.lowest(low, instLbLeft)
instHP = ta.highest(high, instLbLeft)
instHighestClose = ta.highest(close, instLbLeft)
instLowestClose = ta.lowest(close, instLbLeft)

instBullishSFP = low < instPLVal and close > instPLVal and open > instPLVal and low == instLP and instLowestClose >= instPLVal
instBearishSFP = high > instPHVal and close < instPHVal and open < instPHVal and high == instHP and instHighestClose <= instPHVal

instBullCond = instBullishSFP[3] and close > instPLVal and close[1] > instPLVal[1] and close[2] > instPLVal[2] and bar_index >= instBullSignalIndex + instCooldownPeriod
instBearCond = instBearishSFP[3] and close < instPHVal and close[1] < instPHVal[1] and close[2] < instPHVal[2] and bar_index >= instBearSignalIndex + instCooldownPeriod

if instEnabled
    if high < instSwingLowVal and instIsSwingLowCheck
        instSwingLowCounter := instSwingLowCounter + 1

    if low > instSwingHighVal and instIsSwingHighCheck
        instSwingHighCounter := instSwingHighCounter + 1

    if ta.crossunder(close, instSwingLowVal) and instIsSwingLowCheck == false
        instIsSwingLowCheck := true
        instSwingLowCounter := 1

    if ta.crossover(close, instSwingHighVal) and instIsSwingHighCheck == false
        instIsSwingHighCheck := true
        instSwingHighCounter := 1

    if instSwingLowCounter == 5 and instIsSwingLowCheck
        instStopPrintingLow := true
        instIsSwingLowCheck := false
        line.set_x2(instLowLine, bar_index[4])

    if instSwingHighCounter == 5 and instIsSwingHighCheck
        instStopPrintingHigh := true
        instIsSwingHighCheck := false
        line.set_x2(instHighLine, bar_index[4])

if instEnabled and instBullCond
    instBullSignalIndex := bar_index
    instBullLine := line.new(instPrevLowIndex, instPLVal, bar_index - 3, instPLVal, color=instBullColor, width=instBullWidth, style=instLineStyle(instBullStyle))

if instEnabled and instBearCond
    instBearSignalIndex := bar_index
    instBearLine := line.new(instPrevHighIndex, instPHVal, bar_index - 3, instPHVal, color=instBearColor, width=instBearWidth, style=instLineStyle(instBearStyle))

if instEnabled
    if array.size(instSwingHighArr) >= 3
        label.delete(array.shift(instSwingHighArr))
        label.delete(array.shift(instSwingHighTextArr))

    if array.size(instSwingLowArr) >= 3
        label.delete(array.shift(instSwingLowArr))
        label.delete(array.shift(instSwingLowTextArr))

    if instShowSwing
        if instStopPrintingHigh == false
            line.set_x2(instHighLine, bar_index + 5)
        if instStopPrintingLow == false
            line.set_x2(instLowLine, bar_index + 5)

    if instShowSwing and not na(instPH) and instBearishSFP[instLbRight] == false
        instStopPrintingHigh := false
        instSwingHighVal := high[instLbRight]
        line.delete(instHighLine)
        instHighLine := line.new(bar_index[instLbRight], high[instLbRight], bar_index + 10, high[instLbRight], color=instSwingClr, width=2)

        instSwingHighLbl := label.new(bar_index[instLbRight], high[instLbRight], text="", yloc=yloc.abovebar, color=instSwingClr, textcolor=instSwingClr, style=label.style_triangledown, size=size.auto)
        instSwingHighLblTxt := label.new(bar_index[instLbRight], high[instLbRight], text="Swing\nH", yloc=yloc.abovebar, color=instSwingClr, textcolor=instSwingClr, style=label.style_none, size=size.small)
        array.push(instSwingHighArr, instSwingHighLbl)
        array.push(instSwingHighTextArr, instSwingHighLblTxt)

    if instShowSwing and not na(instPL) and instBullishSFP[instLbRight] == false
        instStopPrintingLow := false
        instSwingLowVal := low[instLbRight]
        line.delete(instLowLine)
        instLowLine := line.new(bar_index[instLbRight], low[instLbRight], bar_index + 10, low[instLbRight], color=instSwingClr, width=2)

        instSwingLowLbl := label.new(bar_index[instLbRight], low[instLbRight], text="", yloc=yloc.belowbar, color=instSwingClr, textcolor=instSwingClr, style=label.style_triangleup, size=size.auto)
        instSwingLowLblTxt := label.new(bar_index[instLbRight], low[instLbRight], text="Swing\nL", yloc=yloc.belowbar, color=instSwingClr, textcolor=instSwingClr, style=label.style_none, size=size.small)
        array.push(instSwingLowArr, instSwingLowLbl)
        array.push(instSwingLowTextArr, instSwingLowLblTxt)

plotshape(instEnabled and instBullCond, text="Sweep", color=instBullColor, textcolor=instBullColor, location=location.belowbar, offset=-3)
plotshape(instEnabled and instBearCond, text="Sweep", color=instBearColor, textcolor=instBearColor, location=location.abovebar, offset=-3)

alertcondition(not swingPatternOnlyAlerts and instEnabled and instBullishSFP, title="Bullish Sweep", message="{{ticker}} Bullish Sweep, Price:{{close}}")
alertcondition(not swingPatternOnlyAlerts and instEnabled and instBearishSFP, title="Bearish Sweep", message="{{ticker}} Bearish Sweep, Price:{{close}}")

earlyAvgVol = ta.sma(volume, 20)
earlyStrongVol = volume > earlyAvgVol
earlyDailyBuf = earlyDailyExtremeBufferTicks * syminfo.mintick

earlyPotentialLow = low <= ta.lowest(low, earlyLeftBars + 1)
earlyLiquiditySweepLow = low < low[1] and close > low[1]
earlyBullReaction = close > open
earlyPassLow = not earlyShowDailyExtremeShSl or (not na(dLow) and math.abs(low - dLow) <= earlyDailyBuf)
earlySwingLow = earlySwingEnabled and earlyPotentialLow and earlyLiquiditySweepLow and earlyBullReaction and (not earlyVolFilter or earlyStrongVol) and earlyPassLow

earlyPotentialHigh = high >= ta.highest(high, earlyLeftBars + 1)
earlyLiquiditySweepHigh = high > high[1] and close < high[1]
earlyBearReaction = close < open
earlyPassHigh = not earlyShowDailyExtremeShSl or (not na(dHigh) and math.abs(high - dHigh) <= earlyDailyBuf)
earlySwingHigh = earlySwingEnabled and earlyPotentialHigh and earlyLiquiditySweepHigh and earlyBearReaction and (not earlyVolFilter or earlyStrongVol) and earlyPassHigh

plotshape(earlySwingLow, title="Anticipo Swing Low", location=location.belowbar, style=shape.triangleup, color=color.yellow, size=size.small)

plotshape(earlyShowPossibleSWH and earlySwingHigh, title="Anticipo Swing High", location=location.abovebar, style=shape.triangledown, color=color.yellow, size=size.small)

if earlyShowLabels and earlySwingLow
    label.new(bar_index, low, "Possible SWL", style=label.style_label_up, color=color.yellow, textcolor=color.black)

if earlyShowLabels and earlyShowPossibleSWH and earlySwingHigh
    label.new(bar_index, high, "Possible SWH", style=label.style_label_down, color=color.yellow, textcolor=color.black)

alertcondition(not swingPatternOnlyAlerts and earlySwingLow, title="Early Swing Low Alert", message="Possibile Swing Low in formazione")
alertcondition(not swingPatternOnlyAlerts and earlySwingHigh, title="Early Swing High Alert", message="Possibile Swing High in formazione")

tfIsM1 = timeframe.isminutes and timeframe.multiplier == 1
tfIsM15 = timeframe.isminutes and timeframe.multiplier == 15
tfIsH1 = timeframe.isminutes and timeframe.multiplier == 60
tfIsH4 = timeframe.isminutes and timeframe.multiplier == 240

swingLbL = swingPatternUseTfBars ? (tfIsM1 ? swingPatternLeftBars_M1 : tfIsM15 ? swingPatternLeftBars_M15 : tfIsH1 ? swingPatternLeftBars_H1 : tfIsH4 ? swingPatternLeftBars_H4 : swingPatternLeftBars) : swingPatternLeftBars
swingLbR = swingPatternUseTfBars ? (tfIsM1 ? swingPatternRightBars_M1 : tfIsM15 ? swingPatternRightBars_M15 : tfIsH1 ? swingPatternRightBars_H1 : tfIsH4 ? swingPatternRightBars_H4 : swingPatternRightBars) : swingPatternRightBars

swingWin = swingLbL + swingLbR
swingCenter = swingLbR
hasSwingWindow = bar_index >= swingWin

swingRsi = ta.rsi(close, swingBullDivRsiLen)
[macdLine, macdSignal, _] = ta.macd(close, 12, 26, 9)
macdBullCross = ta.crossover(macdLine, macdSignal)
macdBearCross = ta.crossunder(macdLine, macdSignal)

buyThr = swingRsiMode == "Aggressive" ? swingRsiBuyAgg : swingRsiBuyCons
sellThr = swingRsiMode == "Aggressive" ? swingRsiSellAgg : swingRsiSellCons
passRsiSh = not swingRsiFilterEnabled or swingRsi[swingCenter] >= sellThr
passRsiSl = not swingRsiFilterEnabled or swingRsi[swingCenter] <= buyThr
passMacdSh = not swingMacdConfirmEnabled or macdBearCross
passMacdSl = not swingMacdConfirmEnabled or macdBullCross
swingEps = syminfo.mintick * 0.1
swingSep = swingMinReactionSepTicks * syminfo.mintick
swingMinSwingRange = swingMinSwingRangeTicks * syminfo.mintick
var float swingLastLowPrice = na
var float swingLastLowRsi = na
var int swingLastLowBarIndex = na
var float swingLastHighPrice = na
var float swingLastHighRsi = na
var int swingLastHighBarIndex = na
var swingDivLines = array.new_line(0)
var float swingLiqLastLowPrice = na
var float swingLiqLastHighPrice = na
var bool swingOppSweptForSH = false
var bool swingOppSweptForSL = false

swingPH = ta.pivothigh(high, swingLbL, swingLbR)
swingPL = ta.pivotlow(low, swingLbL, swingLbR)

var float swingLastSweepLowLevel = na
var float swingLastSweepHighLevel = na
var bool swingAllowSL = true
var bool swingAllowSH = true
var bool swingAsiaSweptH = false
var bool swingAsiaSweptL = false
var bool swingIbSweptH = false
var bool swingIbSweptL = false

if is_0000
    swingLastSweepLowLevel := na
    swingLastSweepHighLevel := na
    swingAllowSL := true
    swingAllowSH := true
    swingLiqLastLowPrice := na
    swingLiqLastHighPrice := na
    swingOppSweptForSH := false
    swingOppSweptForSL := false
    swingAsiaSweptH := false
    swingAsiaSweptL := false
    swingIbSweptH := false
    swingIbSweptL := false

swingInAsiaSweepWin = not na(time(timeframe.period, swingAsiaSweepWindow, tz))
swingInIBSweepWin = not na(time(timeframe.period, swingIBSweepWindow, tz))

if swingInAsiaSweepWin and asiaRangeHas
    if high > asiaHigh
        swingAsiaSweptH := true
    if low < asiaLow
        swingAsiaSweptL := true

if swingInIBSweepWin and not na(ibH) and not na(ibL)
    if high > ibH
        swingIbSweptH := true
    if low < ibL
        swingIbSweptL := true

if (isKill or sweepOutsideKillzone) and not na(orangeL) and low < orangeL
    swingLastSweepLowLevel := orangeL
    swingAllowSL := false

if (isKill or sweepOutsideKillzone) and not na(orangeH) and high > orangeH
    swingLastSweepHighLevel := orangeH
    swingAllowSH := false

if not na(swingLastSweepLowLevel) and ta.crossover(close, swingLastSweepLowLevel)
    swingAllowSL := true

if not na(swingLastSweepHighLevel) and ta.crossunder(close, swingLastSweepHighLevel)
    swingAllowSH := true

swingRangeOk = (high[swingCenter] - low[swingCenter]) >= swingMinSwingRange
swingReactBearOk = close[swingCenter - 1] < open[swingCenter - 1] and high[swingCenter - 1] < (high[swingCenter] - swingSep) and open[swingCenter - 1] < (high[swingCenter] - swingSep) and close[swingCenter - 1] < (high[swingCenter] - swingSep)
swingReactBullOk = close[swingCenter - 1] > open[swingCenter - 1] and low[swingCenter - 1] > (low[swingCenter] + swingSep) and open[swingCenter - 1] > (low[swingCenter] + swingSep) and close[swingCenter - 1] > (low[swingCenter] + swingSep)
swingBosBearOk = not swingConfirmBos or (swingLbR == 1 ? close < low[swingCenter] : close < low[swingCenter - 1])
swingBosBullOk = not swingConfirmBos or (swingLbR == 1 ? close > high[swingCenter] : close > high[swingCenter - 1])

swingHighOkInst = not na(swingPH) and swingRangeOk and swingReactBearOk and swingBosBearOk
swingLowOkInst = not na(swingPL) and swingRangeOk and swingReactBullOk and swingBosBullOk

swingHighOkStrict = hasSwingWindow
if swingHighOkStrict
    for i = 0 to swingWin
        if i != swingCenter and high[i] >= high[swingCenter]
            swingHighOkStrict := false
    for j = swingLbL to 1
        if high[swingCenter + j] >= high[swingCenter + j - 1]
            swingHighOkStrict := false
    for j = 1 to swingLbR
        if high[swingCenter - j + 1] <= high[swingCenter - j]
            swingHighOkStrict := false
    swingHighOkStrict := swingHighOkStrict and swingRangeOk and swingReactBearOk and swingBosBearOk

swingLowOkStrict = hasSwingWindow
if swingLowOkStrict
    for i = 0 to swingWin
        if i != swingCenter and low[i] <= low[swingCenter]
            swingLowOkStrict := false
    for j = swingLbL to 1
        if low[swingCenter + j] <= low[swingCenter + j - 1]
            swingLowOkStrict := false
    for j = 1 to swingLbR
        if low[swingCenter - j + 1] >= low[swingCenter - j]
            swingLowOkStrict := false
    swingLowOkStrict := swingLowOkStrict and swingRangeOk and swingReactBullOk and swingBosBullOk

swingHighOk = swingUseInstitutionalSwings ? swingHighOkInst : swingHighOkStrict
swingLowOk = swingUseInstitutionalSwings ? swingLowOkInst : swingLowOkStrict

swingOppBuf = swingOppositeSwingSweepBufferTicks * syminfo.mintick
swingHighOkBase = swingHighOk and (not swingRequireReclaimAfterSweep or swingAllowSH)
swingLowOkBase = swingLowOk and (not swingRequireReclaimAfterSweep or swingAllowSL)

if swingPatternEnabled and swingLowOkBase
    swingLiqLastLowPrice := low[swingCenter]
    swingOppSweptForSH := false
    if swingRequireOppositeSwingSweep and not na(swingLiqLastLowPrice) and ta.lowest(low, swingCenter) < (swingLiqLastLowPrice - swingOppBuf)
        swingOppSweptForSH := true
if swingPatternEnabled and swingHighOkBase
    swingLiqLastHighPrice := high[swingCenter]
    swingOppSweptForSL := false
    if swingRequireOppositeSwingSweep and not na(swingLiqLastHighPrice) and ta.highest(high, swingCenter) > (swingLiqLastHighPrice + swingOppBuf)
        swingOppSweptForSL := true

if swingPatternEnabled and swingRequireOppositeSwingSweep
    if not na(swingLiqLastLowPrice) and low < (swingLiqLastLowPrice - swingOppBuf)
        swingOppSweptForSH := true
    if not na(swingLiqLastHighPrice) and high > (swingLiqLastHighPrice + swingOppBuf)
        swingOppSweptForSL := true

requireAnySessionSweep = swingRequireH13L13Sweep or swingRequireAsiaSweep or swingRequireIBSweep
passSessionSh = not requireAnySessionSweep or (swingRequireH13L13Sweep and sweptL) or (swingRequireAsiaSweep and swingAsiaSweptH) or (swingRequireIBSweep and swingIbSweptH)
passSessionSl = not requireAnySessionSweep or (swingRequireH13L13Sweep and sweptH) or (swingRequireAsiaSweep and swingAsiaSweptL) or (swingRequireIBSweep and swingIbSweptL)

swingHighOk := swingHighOkBase and (not swingRequireOppositeSwingSweep or (not na(swingLiqLastLowPrice) and swingOppSweptForSH)) and passSessionSh
swingLowOk := swingLowOkBase and (not swingRequireOppositeSwingSweep or (not na(swingLiqLastHighPrice) and swingOppSweptForSL)) and passSessionSl

swingBullDiv = swingPatternEnabled and swingBullDivEnabled and swingLowOk and not na(swingLastLowPrice) and low[swingCenter] < swingLastLowPrice and swingRsi[swingCenter] > (swingLastLowRsi + swingDivMinRsiDelta) and (not swingDivUseRsiThresholds or swingLastLowRsi <= swingDivBullPrevRsiMax)
if swingBullDiv and not na(swingLastLowBarIndex)
    newX = bar_index - swingCenter
    newY = low[swingCenter]
    ln = line.new(swingLastLowBarIndex, swingLastLowPrice, newX, newY, color=color.new(color.aqua, 0), width=2)
    array.push(swingDivLines, ln)
    if array.size(swingDivLines) > 10
        line.delete(array.shift(swingDivLines))
if swingPatternEnabled and swingLowOk
    swingLastLowPrice := low[swingCenter]
    swingLastLowRsi := swingRsi[swingCenter]
    swingLastLowBarIndex := bar_index - swingCenter
    swingOppSweptForSH := false

swingBearDiv = swingPatternEnabled and swingBullDivEnabled and swingHighOk and not na(swingLastHighPrice) and high[swingCenter] > swingLastHighPrice and swingRsi[swingCenter] < (swingLastHighRsi - swingDivMinRsiDelta) and (not swingDivUseRsiThresholds or swingLastHighRsi >= swingDivBearPrevRsiMin)
if swingBearDiv and not na(swingLastHighBarIndex)
    newXh = bar_index - swingCenter
    newYh = high[swingCenter]
    lnh = line.new(swingLastHighBarIndex, swingLastHighPrice, newXh, newYh, color=color.new(color.fuchsia, 0), width=2)
    array.push(swingDivLines, lnh)
    if array.size(swingDivLines) > 10
        line.delete(array.shift(swingDivLines))
if swingPatternEnabled and swingHighOk
    swingLastHighPrice := high[swingCenter]
    swingLastHighRsi := swingRsi[swingCenter]
    swingLastHighBarIndex := bar_index - swingCenter
    swingOppSweptForSL := false

swingDailyBuf = swingDailyExtremeBufferTicks * syminfo.mintick
swingSessBuf = swingSessionExtremeBufferTicks * syminfo.mintick

dHighAtPivot = dHigh[swingCenter]
dLowAtPivot = dLow[swingCenter]
nearDailyHigh = (swingShowDailyExtremeShSl and not na(dHighAtPivot) and math.abs(high[swingCenter] - dHighAtPivot) <= swingDailyBuf)
nearDailyLow = (swingShowDailyExtremeShSl and not na(dLowAtPivot) and math.abs(low[swingCenter] - dLowAtPivot) <= swingDailyBuf)

asiaHas = not na(asiaHigh) and not na(asiaLow)
londonHas = not na(londonHighLive) and not na(londonLowLive)
nyHas = not na(nyHighLive) and not na(nyLowLive)

nearSessHigh = swingShowSessionExtremeShSl and (
     (swingSessionUseAsia and asiaHas and math.abs(high[swingCenter] - asiaHigh) <= swingSessBuf) or
     (swingSessionUseLondon and londonHas and math.abs(high[swingCenter] - londonHighLive) <= swingSessBuf) or
     (swingSessionUseNy and nyHas and math.abs(high[swingCenter] - nyHighLive) <= swingSessBuf)
 )
nearSessLow = swingShowSessionExtremeShSl and (
     (swingSessionUseAsia and asiaHas and math.abs(low[swingCenter] - asiaLow) <= swingSessBuf) or
     (swingSessionUseLondon and londonHas and math.abs(low[swingCenter] - londonLowLive) <= swingSessBuf) or
     (swingSessionUseNy and nyHas and math.abs(low[swingCenter] - nyLowLive) <= swingSessBuf)
 )

extremeFilterOn = swingShowDailyExtremeShSl or swingShowSessionExtremeShSl
passExtremeSh = not extremeFilterOn or nearDailyHigh or nearSessHigh
passExtremeSl = not extremeFilterOn or nearDailyLow or nearSessLow

normalShowHigh = swingPatternEnabled and swingHighOk and passExtremeSh and passMacdSh
normalShowLow = swingPatternEnabled and swingLowOk and passExtremeSl and passMacdSl
rsiOverrideHigh = swingRsiFilterEnabled and swingPatternEnabled and swingHighOkBase and passExtremeSh and passRsiSh
rsiOverrideLow = swingRsiFilterEnabled and swingPatternEnabled and swingLowOkBase and passExtremeSl and passRsiSl
swingShowHighFinal = normalShowHigh or rsiOverrideHigh
swingShowLowFinal = normalShowLow or rsiOverrideLow

SmtHigh1 = request.security(SmtSymbol1, timeframe.period, high)
SmtLow1 = request.security(SmtSymbol1, timeframe.period, low)
SmtHigh2 = request.security(SmtSymbol2, timeframe.period, high)
SmtLow2 = request.security(SmtSymbol2, timeframe.period, low)
SmtPivot = SmtUseTfPivots ? (timeframe.isminutes and timeframe.multiplier == 1 ? SmtPivotLen_M1 : timeframe.isminutes and timeframe.multiplier == 15 ? SmtPivotLen_M15 : timeframe.isminutes and timeframe.multiplier == 60 ? SmtPivotLen_H1 : timeframe.isminutes and timeframe.multiplier == 240 ? SmtPivotLen_H4 : SmtPivotLen) : SmtPivotLen
mainPh1 = ta.pivothigh(high, SmtPivot, SmtPivot)
mainPl1 = ta.pivotlow(low, SmtPivot, SmtPivot)
inv1 = SmtInverseOn == "Symbol 1"
inv2 = SmtInverseOn == "Symbol 2"
smtPh1_1 = inv1 ? ta.pivotlow(SmtLow1, SmtPivot, SmtPivot) : ta.pivothigh(SmtHigh1, SmtPivot, SmtPivot)
smtPl1_1 = inv1 ? ta.pivothigh(SmtHigh1, SmtPivot, SmtPivot) : ta.pivotlow(SmtLow1, SmtPivot, SmtPivot)
smtPh1_2 = inv2 ? ta.pivotlow(SmtLow2, SmtPivot, SmtPivot) : ta.pivothigh(SmtHigh2, SmtPivot, SmtPivot)
smtPl1_2 = inv2 ? ta.pivothigh(SmtHigh2, SmtPivot, SmtPivot) : ta.pivotlow(SmtLow2, SmtPivot, SmtPivot)

var float lastMainPh1 = na
var float lastMainPl1 = na
var int lastMainPh1Bar = na
var int lastMainPl1Bar = na
var float lastSmtPh1_1 = na
var float lastSmtPl1_1 = na
var float lastSmtPh1_2 = na
var float lastSmtPl1_2 = na
var int lastSmtBearPivotBar1 = na
var int lastSmtBullPivotBar1 = na
var int lastSmtBearPivotBar2 = na
var int lastSmtBullPivotBar2 = na
var line[] smtDivLines = array.new_line()
f_addSmtLine(_x1, _y1, _x2, _y2, _clr) =>
    ln = line.new(_x1, _y1, _x2, _y2, xloc=xloc.bar_index, extend=extend.none, color=_clr, width=2)
    array.push(smtDivLines, ln)
    if array.size(smtDivLines) > 200
        line.delete(array.shift(smtDivLines))
    ln

smtBearSig1 = false
smtBullSig1 = false
smtBearSig2 = false
smtBullSig2 = false
if SmtEnabled and showUntilNyClose
    if not na(mainPh1) and not na(smtPh1_1) and not na(lastMainPh1) and not na(lastSmtPh1_1)
        smtBearSig1 := mainPh1 > lastMainPh1 and smtPh1_1 <= lastSmtPh1_1
        pivotBar = bar_index - SmtPivot
        if smtBearSig1 and SmtShowLabels and (na(lastSmtBearPivotBar1) or lastSmtBearPivotBar1 != pivotBar)
            label.new(pivotBar, mainPh1, "SMT1", style=label.style_label_down, color=color.new(color.fuchsia, 0), textcolor=color.white, size=size.tiny)
            lastSmtBearPivotBar1 := pivotBar
        if smtBearSig1 and not na(lastMainPh1Bar)
            f_addSmtLine(lastMainPh1Bar, lastMainPh1, pivotBar, mainPh1, color.new(color.fuchsia, 0))
    if not na(mainPl1) and not na(smtPl1_1) and not na(lastMainPl1) and not na(lastSmtPl1_1)
        smtBullSig1 := mainPl1 < lastMainPl1 and smtPl1_1 >= lastSmtPl1_1
        pivotBar = bar_index - SmtPivot
        if smtBullSig1 and SmtShowLabels and (na(lastSmtBullPivotBar1) or lastSmtBullPivotBar1 != pivotBar)
            label.new(pivotBar, mainPl1, "SMT1", style=label.style_label_up, color=color.new(color.aqua, 0), textcolor=color.black, size=size.tiny)
            lastSmtBullPivotBar1 := pivotBar
        if smtBullSig1 and not na(lastMainPl1Bar)
            f_addSmtLine(lastMainPl1Bar, lastMainPl1, pivotBar, mainPl1, color.new(color.aqua, 0))

    if SmtUseSymbol2
        if not na(mainPh1) and not na(smtPh1_2) and not na(lastMainPh1) and not na(lastSmtPh1_2)
            smtBearSig2 := mainPh1 > lastMainPh1 and smtPh1_2 <= lastSmtPh1_2
            pivotBar = bar_index - SmtPivot
            if smtBearSig2 and SmtShowLabels and (na(lastSmtBearPivotBar2) or lastSmtBearPivotBar2 != pivotBar)
                label.new(pivotBar, mainPh1, "SMT2", style=label.style_label_down, color=color.new(color.fuchsia, 0), textcolor=color.white, size=size.tiny)
                lastSmtBearPivotBar2 := pivotBar
            if smtBearSig2 and not na(lastMainPh1Bar)
                f_addSmtLine(lastMainPh1Bar, lastMainPh1, pivotBar, mainPh1, color.new(color.fuchsia, 0))
        if not na(mainPl1) and not na(smtPl1_2) and not na(lastMainPl1) and not na(lastSmtPl1_2)
            smtBullSig2 := mainPl1 < lastMainPl1 and smtPl1_2 >= lastSmtPl1_2
            pivotBar = bar_index - SmtPivot
            if smtBullSig2 and SmtShowLabels and (na(lastSmtBullPivotBar2) or lastSmtBullPivotBar2 != pivotBar)
                label.new(pivotBar, mainPl1, "SMT2", style=label.style_label_up, color=color.new(color.aqua, 0), textcolor=color.black, size=size.tiny)
                lastSmtBullPivotBar2 := pivotBar
            if smtBullSig2 and not na(lastMainPl1Bar)
                f_addSmtLine(lastMainPl1Bar, lastMainPl1, pivotBar, mainPl1, color.new(color.aqua, 0))
    if not na(mainPh1)
        lastMainPh1 := mainPh1
        lastMainPh1Bar := bar_index - SmtPivot
    if not na(mainPl1)
        lastMainPl1 := mainPl1
        lastMainPl1Bar := bar_index - SmtPivot
    if not na(smtPh1_1)
        lastSmtPh1_1 := smtPh1_1
    if not na(smtPl1_1)
        lastSmtPl1_1 := smtPl1_1
    if SmtUseSymbol2
        if not na(smtPh1_2)
            lastSmtPh1_2 := smtPh1_2
        if not na(smtPl1_2)
            lastSmtPl1_2 := smtPl1_2

plotshape(swingShowHighFinal, title="Swing High", location=location.abovebar, style=shape.triangledown, color=color.new(color.red, 0), size=size.small, text="SH", offset=-swingCenter)
plotshape(swingShowLowFinal, title="Swing Low", location=location.belowbar, style=shape.triangleup, color=color.new(color.lime, 0), size=size.small, text="SL", offset=-swingCenter)
plotshape(swingBullDiv, title="Bullish Divergence", location=location.belowbar, style=shape.labelup, color=color.new(color.aqua, 0), text="DIV", textcolor=color.black, size=size.tiny, offset=-swingCenter)
plotshape(swingBearDiv, title="Bearish Divergence", location=location.abovebar, style=shape.labeldown, color=color.new(color.fuchsia, 0), text="DIV", textcolor=color.white, size=size.tiny, offset=-swingCenter)

leftH1 = swingPatternUseTfBars ? swingPatternLeftBars_H1 : swingPatternLeftBars
rightH1 = swingPatternUseTfBars ? swingPatternRightBars_H1 : swingPatternRightBars
leftH4 = swingPatternUseTfBars ? swingPatternLeftBars_H4 : swingPatternLeftBars
rightH4 = swingPatternUseTfBars ? swingPatternRightBars_H4 : swingPatternRightBars

[dashH1ShT, dashH1ShP, dashH1SlT, dashH1SlP] = request.security(syminfo.tickerid, "60", f_pivotStats(leftH1, rightH1), barmerge.gaps_off, barmerge.lookahead_off)
[dashH4ShT, dashH4ShP, dashH4SlT, dashH4SlP] = request.security(syminfo.tickerid, "240", f_pivotStats(leftH4, rightH4), barmerge.gaps_off, barmerge.lookahead_off)

var table dashTbl = na
var string dashPosPrev = na
if barstate.isfirst or dashPosPrev != dashPos
    if not na(dashTbl)
        table.delete(dashTbl)
    dashTbl := table.new(f_dashPos(dashPos), 4, 3, border_width=1)
    dashPosPrev := dashPos

if barstate.islast and not na(dashTbl)
    sz = f_dashSize(dashTextSize)
    if dashEnabled
        hdrBg = color.new(color.black, 0)
        hdrTx = color.white
        table.cell(dashTbl, 0, 0, "TF", bgcolor=hdrBg, text_color=hdrTx, text_size=sz)
        table.cell(dashTbl, 1, 0, "LAST", bgcolor=hdrBg, text_color=hdrTx, text_size=sz)
        table.cell(dashTbl, 2, 0, "SH", bgcolor=hdrBg, text_color=hdrTx, text_size=sz)
        table.cell(dashTbl, 3, 0, "SL", bgcolor=hdrBg, text_color=hdrTx, text_size=sz)

        h1Last = f_lastType(dashH1ShT, dashH1SlT)
        h4Last = f_lastType(dashH4ShT, dashH4SlT)
        bg1 = color.new(color.black, 80)
        table.cell(dashTbl, 0, 1, "H1", bgcolor=bg1, text_color=color.white, text_size=sz)
        table.cell(dashTbl, 1, 1, h1Last, bgcolor=bg1, text_color=h1Last == "SH" ? color.red : h1Last == "SL" ? color.lime : color.white, text_size=sz)
        table.cell(dashTbl, 2, 1, f_cellTxt(dashH1ShT, dashH1ShP), bgcolor=bg1, text_color=color.white, text_size=sz)
        table.cell(dashTbl, 3, 1, f_cellTxt(dashH1SlT, dashH1SlP), bgcolor=bg1, text_color=color.white, text_size=sz)

        table.cell(dashTbl, 0, 2, "H4", bgcolor=bg1, text_color=color.white, text_size=sz)
        table.cell(dashTbl, 1, 2, h4Last, bgcolor=bg1, text_color=h4Last == "SH" ? color.red : h4Last == "SL" ? color.lime : color.white, text_size=sz)
        table.cell(dashTbl, 2, 2, f_cellTxt(dashH4ShT, dashH4ShP), bgcolor=bg1, text_color=color.white, text_size=sz)
        table.cell(dashTbl, 3, 2, f_cellTxt(dashH4SlT, dashH4SlP), bgcolor=bg1, text_color=color.white, text_size=sz)
    else
        table.cell(dashTbl, 0, 0, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 1, 0, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 2, 0, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 3, 0, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 0, 1, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 1, 1, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 2, 1, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 3, 1, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 0, 2, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 1, 2, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 2, 2, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 3, 2, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)

alertcondition(swingPatternOnlyAlerts and swingShowHighFinal, title="Swing High", message="{{ticker}} Swing High")
alertcondition(swingPatternOnlyAlerts and swingShowLowFinal, title="Swing Low", message="{{ticker}} Swing Low")
alertcondition(swingPatternOnlyAlerts and swingBullDiv, title="Bullish Divergence", message="{{ticker}} Bullish Divergence (RSI)")
alertcondition(swingPatternOnlyAlerts and swingBearDiv, title="Bearish Divergence", message="{{ticker}} Bearish Divergence (RSI)")
smtBearAny = smtBearSig1 or smtBearSig2
smtBullAny = smtBullSig1 or smtBullSig2

alertcondition(SmtEnabled and smtBearSig1, title="SMT1 Bearish", message="{{ticker}} SMT Bearish vs SMT Symbol 1")
alertcondition(SmtEnabled and smtBullSig1, title="SMT1 Bullish", message="{{ticker}} SMT Bullish vs SMT Symbol 1")
alertcondition(SmtEnabled and SmtUseSymbol2 and smtBearSig2, title="SMT2 Bearish", message="{{ticker}} SMT Bearish vs SMT Symbol 2")
alertcondition(SmtEnabled and SmtUseSymbol2 and smtBullSig2, title="SMT2 Bullish", message="{{ticker}} SMT Bullish vs SMT Symbol 2")
alertcondition(SmtEnabled and smtBearAny, title="SMT Bearish (Any)", message="{{ticker}} SMT Bearish")
alertcondition(SmtEnabled and smtBullAny, title="SMT Bullish (Any)", message="{{ticker}} SMT Bullish")
