swingMinReactionSepTicks = input.int(1, "Min distanza reazione (ticks)", minval=0, group="Swing Pattern")
swingConfirmBos = input.bool(true, "Conferma BOS (close)", group="Swing Pattern")
swingBullDivEnabled = input.bool(true, "Divergenza Bullish (RSI)", group="Swing Pattern")
swingBullDivRsiLen = input.int(14, "RSI Length", minval=2, group="Swing Pattern")
swingDivUseRsiThresholds = input.bool(true, "Filtro soglie RSI", group="Swing Pattern")
swingDivBullPrevRsiMax = input.int(40, "RSI max 1° low", minval=1, maxval=50, group="Swing Pattern")
swingDivBearPrevRsiMin = input.int(60, "RSI min 1° high", minval=50, maxval=99, group="Swing Pattern")
swingDivMinRsiDelta = input.float(0.0, "Min delta RSI", minval=0.0, step=0.1, group="Swing Pattern")
swingDivShowDailyExtreme = input.bool(false, "Mostra DIV vicino a Daily High/Low", group="Swing Pattern")
swingDivDailyExtremeBufferTicks = input.int(0, "Distanza max DIV da Daily High/Low (ticks)", minval=0, group="Swing Pattern")
swingRsiFilterEnabled = input.bool(false, "Filtro RSI (SH/SL)", group="Swing Pattern")
swingRsiMode = input.string("Conservative", "RSI Mode", options=["Aggressive", "Conservative"], group="Swing Pattern")
swingRsiBuyAgg = input.int(30, "RSI BUY Aggressive (≤)", minval=1, maxval=50, group="Swing Pattern")
swingRsiBuyCons = input.int(40, "RSI BUY Conservative (≤)", minval=1, maxval=50, group="Swing Pattern")
swingRsiSellAgg = input.int(70, "RSI SELL Aggressive (≥)", minval=50, maxval=99, group="Swing Pattern")
swingRsiSellCons = input.int(60, "RSI SELL Conservative (≥)", minval=50, maxval=99, group="Swing Pattern")
swingMacdConfirmEnabled = input.bool(false, "Conferma MACD cross", group="Swing Pattern")
swingRequireHammerShootingForShSl = input.bool(false, "Filtro Hammer (SL) / Shooting (SH)", group="Swing Pattern")
onlyShSlMode = swingRequireHammerShootingForShSl

// --- CONFIGURAZIONE ORARI (Roma) ---
tz = "Europe/Rome"

isAfterNyClose = not na(time(timeframe.period, "2100-2359", tz))
showUntilNyClose = not isAfterNyClose

instLineStyle(s) =>
    s == "Solid" ? line.style_solid : s == "Dotted" ? line.style_dotted : line.style_dashed

f_dashPos(_s) =>
    _s == "Top Left" ? position.top_left : _s == "Bottom Right" ? position.bottom_right : _s == "Bottom Left" ? position.bottom_left : position.top_right

f_dashSize(_s) =>
    _s == "Tiny" ? size.tiny : _s == "Normal" ? size.normal : size.small

f_pivotStats(_left, _right) =>
    ph = ta.pivothigh(high, _left, _right)
    pl = ta.pivotlow(low, _left, _right)
    shTime = ta.valuewhen(not na(ph), time[_right], 0)
    shPrice = ta.valuewhen(not na(ph), ph, 0)
    slTime = ta.valuewhen(not na(pl), time[_right], 0)
    slPrice = ta.valuewhen(not na(pl), pl, 0)
    [shTime, shPrice, slTime, slPrice]

f_lastType(_shTime, _slTime) =>
    na(_shTime) and na(_slTime) ? "—" : na(_slTime) ? "SH" : na(_shTime) ? "SL" : _shTime > _slTime ? "SH" : _slTime > _shTime ? "SL" : "SH/SL"

f_cellTxt(_t, _p) =>
    na(_t) ? "—" : str.format("{0,date,dd/MM HH:mm}", _t) + "\n" + str.tostring(_p, format.mintick)

f_alert(_cond, _msg) =>
    if alertsEnabled and _cond
        alert(_msg, alert.freq_once_per_bar_close)

f_vpVa(_arr, _poc, _pct) =>
    n = array.size(_arr)
    tot = array.sum(_arr)
    target = tot * _pct / 100.0
    lo = _poc
    hi = _poc
    cum = array.get(_arr, _poc)
    while cum < target and (lo > 0 or hi < n - 1)
        nextLo = lo > 0 ? array.get(_arr, lo - 1) : -1.0
        nextHi = hi < n - 1 ? array.get(_arr, hi + 1) : -1.0
        if nextHi >= nextLo
            hi += 1
            cum += nextHi
        else
            lo -= 1
            cum += nextLo
    [lo, hi]

crtConfirmLeft = swingPatternUseTfBars ? (crtTf == "1" ? swingPatternLeftBars_M1 : crtTf == "15" ? swingPatternLeftBars_M15 : crtTf == "60" ? swingPatternLeftBars_H1 : crtTf == "240" ? swingPatternLeftBars_H4 : swingPatternLeftBars) : swingPatternLeftBars
crtConfirmRight = swingPatternUseTfBars ? (crtTf == "1" ? swingPatternRightBars_M1 : crtTf == "15" ? swingPatternRightBars_M15 : crtTf == "60" ? swingPatternRightBars_H1 : crtTf == "240" ? swingPatternRightBars_H4 : swingPatternRightBars) : swingPatternRightBars

f_crt() =>
    buf = crtSweepBufferTicks * syminfo.mintick
    rh = high[1]
    rl = low[1]
    bullSoup = not na(rh) and not na(rl) and low < (rl - buf) and close > rl and close < rh
    bearSoup = not na(rh) and not na(rl) and high > (rh + buf) and close < rh and close > rl
    soup = bullSoup or bearSoup
    var float rangeH = na
    var float rangeL = na
    var float eq = na
    var float soupH = na
    var float soupL = na
    var int dir = 0
    var int soupT = na
    var float soupDayH = na
    var float soupDayL = na
    var bool soupInKill = false

    is_0000_c = hour(time, tz) == 0 and minute(time, tz) == 0
    isNewDayC = year(time, tz) != year(time[1], tz) or month(time, tz) != month(time[1], tz) or dayofmonth(time, tz) != dayofmonth(time[1], tz)
    var float dH = na
    var float dL = na
    if is_0000_c or isNewDayC
        dH := high
        dL := low
    else
        dH := math.max(dH, high)
        dL := math.min(dL, low)

    hh = hour(time_close, tz)
    mm = minute(time_close, tz)
    inKill = (hh > 14 or (hh == 14 and mm >= 30)) and (hh < 16 or (hh == 16 and mm <= 30))

    rsiC = ta.rsi(close, swingBullDivRsiLen)

    ph = ta.pivothigh(high, crtConfirmLeft, crtConfirmRight)
    pl = ta.pivotlow(low, crtConfirmLeft, crtConfirmRight)
    shT = ta.valuewhen(not na(ph), time[crtConfirmRight], 0)
    slT = ta.valuewhen(not na(pl), time[crtConfirmRight], 0)

    if soup
        rangeH := rh
        rangeL := rl
        eq := (rh + rl) / 2.0
        dir := bullSoup ? 1 : -1
        soupH := high
        soupL := low
        soupT := time
        soupDayH := dH
        soupDayL := dL
        soupInKill := inKill
    barsSince = ta.barssince(soup)
    isDist = barsSince == 1
    entryLong = dir == 1 and isDist and low < open and close > open
    entryShort = dir == -1 and isDist and high > open and close < open
    [rangeH, rangeL, eq, dir, soupH, soupL, entryLong, entryShort, soupT, soup, bullSoup, bearSoup, dH, dL, inKill, rsiC, shT, slT, soupDayH, soupDayL, soupInKill]

// --- 1. DAILY OPEN, HIGH, LOW ---
is_0000 = hour(time, tz) == 0 and minute(time, tz) == 0
isNewDay = year(time, tz) != year(time[1], tz) or month(time, tz) != month(time[1], tz) or dayofmonth(time, tz) != dayofmonth(time[1], tz)
var float dHigh = na
var float dLow = na
var float dailyOpen = na

if is_0000 or isNewDay
    dailyOpen := open
    dHigh := high
    dLow := low
else
    dHigh := math.max(dHigh, high)
    dLow := math.min(dLow, low)

var label dHighLbl = na
var label dLowLbl = na
plot(not onlyShSlMode and not onlyMainMode and showUntilNyClose and showDailyOpen ? dailyOpen : na, "Daily Open", color.new(color.purple, 50), 1, plot.style_linebr)
plot(not onlyShSlMode and showUntilNyClose and showDailyHL and onlyAllowDailyHL ? dHigh : na, "Daily High", color.red, 1, plot.style_linebr)
plot(not onlyShSlMode and showUntilNyClose and showDailyHL and onlyAllowDailyHL ? dLow : na, "Daily Low", color.lime, 1, plot.style_linebr)

if not onlyShSlMode and not onlyMainMode and showUntilNyClose and showDailyHL and not na(dHigh) and not na(dLow)
    if na(dHighLbl)
        dHighLbl := label.new(bar_index, dHigh, "Daily High", color=color.new(color.white, 100), textcolor=color.red, style=label.style_label_right, size=size.small)
    else
        label.set_x(dHighLbl, bar_index)
        label.set_y(dHighLbl, dHigh)
    if na(dLowLbl)
        dLowLbl := label.new(bar_index, dLow, "Daily Low", color=color.new(color.white, 100), textcolor=color.red, style=label.style_label_right, size=size.small)
    else
        label.set_x(dLowLbl, bar_index)
        label.set_y(dLowLbl, dLow)
else
    if not na(dHighLbl)
        label.delete(dHighLbl)
        dHighLbl := na
    if not na(dLowLbl)
        label.delete(dLowLbl)
        dLowLbl := na

vpBin = vpBinTicks * syminfo.mintick
var float vpOrigin = na
var float vpSessLow = na
var float vpSessHigh = na
var float[] vpVol = array.new_float()
var box[] vpBoxes = array.new_box()
var line vpPocLine = na
var line vpVaLowLine = na
var line vpVaHighLine = na

vpReset = is_0000 or isNewDay
if vpReset
    vpOrigin := na
    vpSessLow := na
    vpSessHigh := na
    while array.size(vpVol) > 0
        array.pop(vpVol)
    while array.size(vpBoxes) > 0
        box.delete(array.pop(vpBoxes))
    if not na(vpPocLine)
        line.delete(vpPocLine)
        vpPocLine := na
    if not na(vpVaLowLine)
        line.delete(vpVaLowLine)
        vpVaLowLine := na
    if not na(vpVaHighLine)
        line.delete(vpVaHighLine)
        vpVaHighLine := na

vpEnd = (not showUntilNyClose) and showUntilNyClose[1]
if vpEnabled and not onlyShSlMode and not onlyQmMode and vpEnd
    vpOrigin := na
    vpSessLow := na
    vpSessHigh := na
    while array.size(vpVol) > 0
        array.pop(vpVol)
    while array.size(vpBoxes) > 0
        box.delete(array.pop(vpBoxes))
    if not na(vpPocLine)
        line.delete(vpPocLine)
        vpPocLine := na
    if not na(vpVaLowLine)
        line.delete(vpVaLowLine)
        vpVaLowLine := na
    if not na(vpVaHighLine)
        line.delete(vpVaHighLine)
        vpVaHighLine := na

vpActive = vpEnabled and not onlyShSlMode and not onlyQmMode and showUntilNyClose
if vpActive
    vpSessLow := na(vpSessLow) ? low : math.min(vpSessLow, low)
    vpSessHigh := na(vpSessHigh) ? high : math.max(vpSessHigh, high)
    if na(vpOrigin)
        vpOrigin := vpSessLow
        array.push(vpVol, 0.0)
    if vpSessLow < vpOrigin
        shiftBins = int(math.ceil((vpOrigin - vpSessLow) / vpBin))
        for _ = 0 to shiftBins - 1
            array.unshift(vpVol, 0.0)
        vpOrigin -= shiftBins * vpBin
    needHigh = vpOrigin + array.size(vpVol) * vpBin
    if vpSessHigh > needHigh
        addBins = int(math.ceil((vpSessHigh - needHigh) / vpBin))
        for _ = 0 to addBins
            array.push(vpVol, 0.0)
    idx = int(math.floor((hlc3 - vpOrigin) / vpBin))
    idx := math.max(0, math.min(idx, array.size(vpVol) - 1))
    array.set(vpVol, idx, array.get(vpVol, idx) + volume)

if vpEnabled and not onlyShSlMode and not onlyQmMode and showUntilNyClose and not na(vpOrigin) and array.size(vpVol) > 0 and barstate.islast
    bins = array.size(vpVol)
    maxVol = array.max(vpVol)
    poc = 0
    for i = 0 to bins - 1
        if array.get(vpVol, i) == maxVol
            poc := i
            break
    [vaLo, vaHi] = f_vpVa(vpVol, poc, vpValueAreaPct)
    stride = int(math.max(1, math.ceil(bins / vpMaxBinsDraw)))
    groups = int(math.ceil(bins / stride))
    while array.size(vpBoxes) > groups
        box.delete(array.pop(vpBoxes))
    while array.size(vpBoxes) < groups
        array.push(vpBoxes, box.new(bar_index, close, bar_index, close, bgcolor=vpColor, border_width=0))
    for g = 0 to groups - 1
        s = g * stride
        e = math.min(bins - 1, s + stride - 1)
        vSum = 0.0
        for j = s to e
            vSum += array.get(vpVol, j)
        w = maxVol > 0 ? int(math.round(vSum / maxVol * vpWidthBars)) : 0
        pLo = vpOrigin + s * vpBin
        pHi = vpOrigin + (e + 1) * vpBin
        inVa = vpShowVa and (s <= vaHi and e >= vaLo)
        bg = inVa ? vpVaColor : vpColor
        b = array.get(vpBoxes, g)
        box.set_left(b, bar_index - w)
        box.set_right(b, bar_index)
        box.set_bottom(b, pLo)
        box.set_top(b, pHi)
        box.set_bgcolor(b, bg)
        box.set_border_width(b, 0)
    pocY = vpOrigin + (poc + 0.5) * vpBin
    if vpShowPoc
        if na(vpPocLine)
            vpPocLine := line.new(bar_index - vpWidthBars, pocY, bar_index, pocY, xloc=xloc.bar_index, extend=extend.none, color=vpPocColor, width=2)
        else
            line.set_xy1(vpPocLine, bar_index - vpWidthBars, pocY)
            line.set_xy2(vpPocLine, bar_index, pocY)
    else
        if not na(vpPocLine)
            line.delete(vpPocLine)
            vpPocLine := na
    if vpShowVa
        vaLoY = vpOrigin + vaLo * vpBin
        vaHiY = vpOrigin + (vaHi + 1) * vpBin
        if na(vpVaLowLine)
            vpVaLowLine := line.new(bar_index - vpWidthBars, vaLoY, bar_index, vaLoY, xloc=xloc.bar_index, extend=extend.none, color=color.new(vpPocColor, 40), width=1)
        else
            line.set_xy1(vpVaLowLine, bar_index - vpWidthBars, vaLoY)
            line.set_xy2(vpVaLowLine, bar_index, vaLoY)
        if na(vpVaHighLine)
            vpVaHighLine := line.new(bar_index - vpWidthBars, vaHiY, bar_index, vaHiY, xloc=xloc.bar_index, extend=extend.none, color=color.new(vpPocColor, 40), width=1)
        else
            line.set_xy1(vpVaHighLine, bar_index - vpWidthBars, vaHiY)
            line.set_xy2(vpVaHighLine, bar_index, vaHiY)
    else
        if not na(vpVaLowLine)
            line.delete(vpVaLowLine)
            vpVaLowLine := na
        if not na(vpVaHighLine)
            line.delete(vpVaHighLine)
            vpVaHighLine := na

// --- 2. NY OPEN (14:30) ---
var float nyOpenPrice = na
isAfterNyOpen = not na(time(timeframe.period, "1430-2359", tz))
nyOpenFrom1m = request.security(syminfo.tickerid, "1", ta.valuewhen(hour(time, tz) == 14 and minute(time, tz) == 30, open, 0), barmerge.gaps_off, barmerge.lookahead_off)
if is_0000
    nyOpenPrice := na
if isAfterNyOpen and not na(nyOpenFrom1m)
    nyOpenPrice := nyOpenFrom1m

plot(not onlyShSlMode and not onlyQmMode and showUntilNyClose and showNYOpen ? nyOpenPrice : na, "NY Open Line", color.blue, 2, plot.style_linebr)

var label nyOpenLbl = na
if not onlyShSlMode and not onlyQmMode and showUntilNyClose and showNYOpen and not na(nyOpenPrice)
    if na(nyOpenLbl)
        nyOpenLbl := label.new(bar_index, nyOpenPrice, "NY Open", color=color.new(color.white, 100), textcolor=color.red, style=label.style_label_right, size=size.small)
    else
        label.set_x(nyOpenLbl, bar_index)
        label.set_y(nyOpenLbl, nyOpenPrice)
else
    if not na(nyOpenLbl)
        label.delete(nyOpenLbl)
        nyOpenLbl := na

// --- 3. FUNZIONE BOX SESSIONI ---
var box asiaBox = na, var box londonBox = na, var box nyBox = na
var label asiaLab = na, var label londonLab = na, var label nyLab = na
var float aHigh = na, var float aLow = na
var float lHigh = na, var float lLow = na
var float nHigh = na, var float nLow = na

var float asiaOpen = na
var float asiaClose = na
var float asiaHigh = na
var float asiaLow = na
isInAsia = not na(time(timeframe.period, "0000-0800", tz))
if is_0000
    asiaOpen := na
    asiaClose := na
    asiaHigh := na
    asiaLow := na
if isInAsia
    if not isInAsia[1]
        asiaOpen := open
        asiaHigh := high
        asiaLow := low
    asiaClose := close
    asiaHigh := math.max(nz(asiaHigh, high), high)
    asiaLow := math.min(nz(asiaLow, low), low)

var float londonHighLive = na
var float londonLowLive = na
isInLondon = not na(time(timeframe.period, "0900-1730", tz))
if is_0000
    londonHighLive := na
    londonLowLive := na
if isInLondon
    if not isInLondon[1]
        londonHighLive := high
        londonLowLive := low
    else
        londonHighLive := math.max(nz(londonHighLive, high), high)
        londonLowLive := math.min(nz(londonLowLive, low), low)

var float nyHighLive = na
var float nyLowLive = na
isInNySess = not na(time(timeframe.period, "1430-2100", tz))
if is_0000
    nyHighLive := na
    nyLowLive := na
if isInNySess
    if not isInNySess[1]
        nyHighLive := high
        nyLowLive := low
    else
        nyHighLive := math.max(nz(nyHighLive, high), high)
        nyLowLive := math.min(nz(nyLowLive, low), low)

draw_session(sess_time, sess_name, sess_color, sBox, sLab, sHigh, sLow) =>
    t = time(timeframe.period, sess_time, tz)
    isIn = not na(t)
    isFirst = isIn and na(t[1])
    resHigh = sHigh, resLow = sLow, resBox = sBox, resLab = sLab
    if isFirst
        resHigh := high
        resLow := low
        resBox := box.new(left=bar_index, top=resHigh, right=bar_index, bottom=resLow, bgcolor=color.new(sess_color, 92), border_color=color.new(sess_color, 100), border_width=0)
        if showSessionNames
            resLab := label.new(bar_index, high, sess_name, color=sess_color, textcolor=color.white, style=label.style_label_down, size=size.small)
    else if isIn
        resHigh := math.max(nz(resHigh, high), high)
        resLow := math.min(nz(resLow, low), low)
        box.set_top(resBox, resHigh)
        box.set_bottom(resBox, resLow)
        box.set_right(resBox, bar_index)
        if showSessionNames
            if na(resLab)
                resLab := label.new(bar_index, resHigh, sess_name, color=sess_color, textcolor=color.white, style=label.style_label_down, size=size.small)
            label.set_x(resLab, bar_index)
            label.set_y(resLab, resHigh)
        else
            if not na(resLab)
                label.delete(resLab)
                resLab := na
    [resBox, resLab, resHigh, resLow]

if showSessions and not onlyShSlMode and onlyAllowSessions
    [b1, l1, h1, lw1] = draw_session("0000-0800", "ASIA", color.green, asiaBox, asiaLab, aHigh, aLow)
    asiaBox := b1, asiaLab := l1, aHigh := h1, aLow := lw1
    [b2, l2, h2, lw2] = draw_session("0900-1730", "LONDON", color.blue, londonBox, londonLab, lHigh, lLow)
    londonBox := b2, londonLab := l2, lHigh := h2, lLow := lw2
    [b3, l3, h3, lw3] = draw_session("1430-2100", "NY", color.orange, nyBox, nyLab, nHigh, nLow)
    nyBox := b3, nyLab := l3, nHigh := h3, nLow := lw3
else
    if not na(asiaBox)
        box.delete(asiaBox)
        asiaBox := na
    if not na(asiaLab)
        label.delete(asiaLab)
        asiaLab := na
    if not na(londonBox)
        box.delete(londonBox)
        londonBox := na
    if not na(londonLab)
        label.delete(londonLab)
        londonLab := na
    if not na(nyBox)
        box.delete(nyBox)
        nyBox := na
    if not na(nyLab)
        label.delete(nyLab)
        nyLab := na

// --- 4. INITIAL BALANCE (09:00 - 10:00) ---
isInIB = not na(time(timeframe.period, "0900-1000", tz))
isAfterIBStart = not na(time(timeframe.period, "0900-2359", tz))
var float ibH = na
var float ibL = na
if is_0000
    ibH := na
    ibL := na
if isInIB
    if not isInIB[1]
        ibH := high
        ibL := low
    else
        ibH := math.max(ibH, high)
        ibL := math.min(ibL, low)
ibMid = (ibH + ibL) / 2
plot(not onlyShSlMode and not onlyQmMode and showUntilNyClose and isAfterIBStart ? ibH : na, "IB High", color.new(color.blue, 40), 1, plot.style_linebr)
plot(not onlyShSlMode and not onlyQmMode and showUntilNyClose and isAfterIBStart ? ibL : na, "IB Low", color.new(color.blue, 40), 1, plot.style_linebr)

var float orangeH = na
var float orangeL = na

if is_0000
    orangeH := na
    orangeL := na

orangeH60 = request.security(syminfo.tickerid, "60", ta.valuewhen(hour(time, tz) == 13 and minute(time, tz) == 0, high, 0), barmerge.gaps_off, barmerge.lookahead_off)
orangeL60 = request.security(syminfo.tickerid, "60", ta.valuewhen(hour(time, tz) == 13 and minute(time, tz) == 0, low, 0), barmerge.gaps_off, barmerge.lookahead_off)
orangeT60 = request.security(syminfo.tickerid, "60", ta.valuewhen(hour(time, tz) == 13 and minute(time, tz) == 0, time, 0), barmerge.gaps_off, barmerge.lookahead_off)
orangeIsToday = not na(orangeT60) and dayofmonth(orangeT60, tz) == dayofmonth(time, tz) and month(orangeT60, tz) == month(time, tz) and year(orangeT60, tz) == year(time, tz)
if orangeIsToday and not na(orangeH60) and not na(orangeL60)
    orangeH := orangeH60
    orangeL := orangeL60

plot(not onlyShSlMode and not onlyQmMode and showUntilNyClose and orangeIsToday and not na(orangeH) ? orangeH : na, "H13", color.orange, 2, plot.style_linebr)
plot(not onlyShSlMode and not onlyQmMode and showUntilNyClose and orangeIsToday and not na(orangeL) ? orangeL : na, "L13", color.orange, 2, plot.style_linebr)

is_0200 = hour(time, tz) == 2 and minute(time, tz) == 0
isAfter02 = not na(time(timeframe.period, "0200-2359", tz))
var float c02H = na
var float c02L = na
if is_0000
    c02H := na
    c02L := na
if is_0200
    c02H := high
    c02L := low
plot(not onlyShSlMode and not onlyQmMode and showUntilNyClose and show02CandleLines and isAfter02 ? c02H : na, "02 High", color.green, 2, plot.style_linebr)
plot(not onlyShSlMode and not onlyQmMode and showUntilNyClose and show02CandleLines and isAfter02 ? c02L : na, "02 Low", color.green, 2, plot.style_linebr)

is_1300 = hour(time, tz) == 13 and minute(time, tz) == 0
c02AboveLondon = not na(c02H) and not na(c02L) and not na(londonHighLive) and c02H > londonHighLive and c02L > londonHighLive
var label[] mcSigLabels = array.new_label()
f_sigSlot(_txt) =>
    str.contains(_txt, "CRT") ? 6 :
     str.contains(_txt, "RSI") ? 5 :
     str.contains(_txt, "DIV") ? 4 :
     str.contains(_txt, "SH") ? 3 :
     str.contains(_txt, "SL") ? 3 :
     str.contains(_txt, "OVER") ? 2 :
     str.contains(_txt, "KISS") ? 1 :
     _txt == "BUY" or _txt == "SELL" ? 1 : 0
f_addSigLabel(_x, _y, _txt, _bg, _tc, _style, _size) =>
    allowInOnlyQm = (onlyQmShowRsiCross and (_txt == "RSI↑" or _txt == "RSI↓")) or (onlyQmShowRsiMW and (_txt == "RSI\nM" or _txt == "RSI\nW"))
    if onlyShSlMode or (onlyQmMode and not allowInOnlyQm)
        na
    else
        step = labelStackTicks * syminfo.mintick
        slot = labelAutoStack and (_style == label.style_label_up or _style == label.style_label_down) ? f_sigSlot(_txt) : 0
        yAdj = _style == label.style_label_up ? (_y - slot * step) : _style == label.style_label_down ? (_y + slot * step) : _y
        lb = label.new(_x, yAdj, _txt, xloc=xloc.bar_index, style=_style, color=_bg, textcolor=_tc, size=_size)
        array.push(mcSigLabels, lb)
        if array.size(mcSigLabels) > 250
            label.delete(array.shift(mcSigLabels))
        lb

if useAsiaLondonSell13 and is_1300 and c02AboveLondon
    f_addSigLabel(bar_index, high, "SELL", color.red, color.white, label.style_label_down, size.small)

midCandleHigh = request.security(syminfo.tickerid, "1", ta.valuewhen(hour(time, tz) == 0 and minute(time, tz) == 0, high, 0), barmerge.gaps_off, barmerge.lookahead_on)
midCandleLow  = request.security(syminfo.tickerid, "1", ta.valuewhen(hour(time, tz) == 0 and minute(time, tz) == 0, low, 0), barmerge.gaps_off, barmerge.lookahead_on)

newDayRome = na(time[1]) ? true : dayofmonth(time, tz) != dayofmonth(time[1], tz)
midCandlePlotHigh = newDayRome ? na : midCandleHigh
midCandlePlotLow = newDayRome ? na : midCandleLow
plot(not onlyShSlMode and not onlyQmMode and showUntilNyClose and showMidnightLines ? midCandlePlotHigh : na, "00 High", color.green, 2, plot.style_linebr)
plot(not onlyShSlMode and not onlyQmMode and showUntilNyClose and showMidnightLines ? midCandlePlotLow : na, "00 Low", color.green, 2, plot.style_linebr)

var line a2nHighLine = na
var line a2nLowLine = na
if newDayRome
    if not na(a2nHighLine)
        line.delete(a2nHighLine)
        a2nHighLine := na
    if not na(a2nLowLine)
        line.delete(a2nLowLine)
        a2nLowLine := na
    if showA2NRange and not onlyShSlMode and not onlyQmMode
        a2nHighLine := line.new(bar_index, midCandleHigh, bar_index, midCandleHigh, extend=extend.none, color=color.green, width=2)
        a2nLowLine := line.new(bar_index, midCandleLow, bar_index, midCandleLow, extend=extend.none, color=color.green, width=2)

if not showA2NRange or onlyShSlMode
    if not na(a2nHighLine)
        line.delete(a2nHighLine)
        a2nHighLine := na
    if not na(a2nLowLine)
        line.delete(a2nLowLine)
        a2nLowLine := na
else
    if showUntilNyClose and not onlyShSlMode and not onlyQmMode
        if not na(a2nHighLine) and not na(midCandleHigh)
            line.set_xy1(a2nHighLine, line.get_x1(a2nHighLine), midCandleHigh)
            line.set_xy2(a2nHighLine, bar_index, midCandleHigh)
        if not na(a2nLowLine) and not na(midCandleLow)
            line.set_xy1(a2nLowLine, line.get_x1(a2nLowLine), midCandleLow)
            line.set_xy2(a2nLowLine, bar_index, midCandleLow)

buf = sweepBufferTicks * syminfo.mintick

var float midH = na
var float midL = na
var int midSweepDownBar = na
var int midSweepUpBar = na
var bool midLongDone = false
var bool midShortDone = false

if is_0000
    midH := high
    midL := low
    midSweepDownBar := na
    midSweepUpBar := na
    midLongDone := false
    midShortDone := false

if not na(midL) and na(midSweepDownBar) and low < (midL - buf)
    midSweepDownBar := bar_index
if not na(midH) and na(midSweepUpBar) and high > (midH + buf)
    midSweepUpBar := bar_index

midSweepDown = not na(midSweepDownBar)
midSweepUp = not na(midSweepUpBar)

newDay = year(time, tz) != year(time[1], tz) or month(time, tz) != month(time[1], tz) or dayofmonth(time, tz) != dayofmonth(time[1], tz)
midPlotH = newDay ? na : midH
midPlotL = newDay ? na : midL
plot(not onlyShSlMode and not onlyQmMode and showUntilNyClose and showA2NRange ? midPlotH : na, "MID High", color.green, 2, plot.style_linebr)
plot(not onlyShSlMode and not onlyQmMode and showUntilNyClose and showA2NRange ? midPlotL : na, "MID Low", color.green, 2, plot.style_linebr)

var int ibSweepDownBar = na
var int ibSweepUpBar = na
if is_0000
    ibSweepDownBar := na
    ibSweepUpBar := na

if not na(ibL) and na(ibSweepDownBar) and low < (ibL - buf)
    ibSweepDownBar := bar_index
if not na(ibH) and na(ibSweepUpBar) and high > (ibH + buf)
    ibSweepUpBar := bar_index

ibSweepDown = not na(ibSweepDownBar)
ibSweepUp = not na(ibSweepUpBar)

// --- 6. LOGICA SEGNALI ---
isKill = not na(time(timeframe.period, "1430-1630", tz))
is1m = timeframe.isminutes and timeframe.multiplier == 1
isStar13 = is1m ? (hour(time, tz) == 12 and minute(time, tz) == 59) : (hour(time, tz) == 13 and minute(time, tz) == 0)
isStar16 = is1m ? (hour(time, tz) == 15 and minute(time, tz) == 59) : (hour(time, tz) == 16 and minute(time, tz) == 0)
is_0900 = hour(time, tz) == 9 and minute(time, tz) == 0
asiaRangeHas = not na(asiaHigh) and not na(asiaLow)
asiaBiasBuy = asiaRangeHas and is_0900 and low > asiaHigh
asiaBiasSell = asiaRangeHas and is_0900 and high < asiaLow
var bool bDone = false
var bool sDone = false
if is_0000
    bDone := false
    sDone := false

var bool sweptH = false
var bool sweptL = false
var bool bacioDoneB = false
var bool bacioDoneS = false

if is_0000
    sweptH := false
    sweptL := false
    bacioDoneB := false
    bacioDoneS := false

if isKill or sweepOutsideKillzone
    if not na(orangeH) and high > orangeH
        sweptH := true
    if not na(orangeL) and low < orangeL
        sweptL := true

tol = retestToleranceTicks * syminfo.mintick
kissWindowOk = isKill or kissOutsideKillzone
validKISS_BUY = kissSignalsEnabled and kissWindowOk and not na(orangeL) and (not requireSweepBeforeKiss or sweptL) and not bacioDoneB and low <= (orangeL + tol) and close > orangeL
validKISS_SELL = kissSignalsEnabled and kissWindowOk and not na(orangeH) and (not requireSweepBeforeKiss or sweptH) and not bacioDoneS and high >= (orangeH - tol) and close < orangeH

if validKISS_BUY
    bacioDoneB := true
if validKISS_SELL
    bacioDoneS := true

dailyOkB = (not useDailyOpenFilter) or (close > dailyOpen)
dailyOkS = (not useDailyOpenFilter) or (close < dailyOpen)
ibOkB = (not useIbMidFilter) or (close > ibMid)
ibOkS = (not useIbMidFilter) or (close < ibMid)
manipOkB = (not requireManipulation) or midSweepDown or ibSweepDown
manipOkS = (not requireManipulation) or midSweepUp or ibSweepUp

validB = buySellSignalsEnabled and close > orangeH and isKill and not bDone and dailyOkB and ibOkB and manipOkB
validS = buySellSignalsEnabled and close < orangeL and isKill and not sDone and dailyOkS and ibOkS and manipOkS

if validB
    bDone := true
if validS
    sDone := true

if validKISS_BUY
    f_addSigLabel(bar_index, low, "KISS\nBUY", color.green, color.white, label.style_label_up, size.small)
if validKISS_SELL
    f_addSigLabel(bar_index, high, "KISS\nSELL", color.red, color.white, label.style_label_down, size.small)
if sweptL and not sweptL[1]
    f_addSigLabel(bar_index, low, "Swept", color.red, color.white, label.style_label_up, size.tiny)
if sweptH and not sweptH[1]
    f_addSigLabel(bar_index, high, "Swept", color.red, color.white, label.style_label_down, size.tiny)

overLowBuf = swingOverLowL13BufferTicks * syminfo.mintick
overLowL13 = showUntilNyClose and orangeIsToday and not na(orangeL) and ta.crossunder(low, orangeL - overLowBuf)
if swingShowOverLowL13 and overLowL13
    f_addSigLabel(bar_index, low, "OVER\nLOW", color.new(color.red, 0), color.white, label.style_label_up, size.tiny)
f_alert(not onlyShSlMode and not onlyQmMode and not swingPatternOnlyAlerts and swingShowOverLowL13 and overLowL13, syminfo.ticker + " Over Low (sotto L13)")

overHighBuf = swingOverHighH13BufferTicks * syminfo.mintick
overHighH13 = showUntilNyClose and orangeIsToday and not na(orangeH) and ta.crossover(high, orangeH + overHighBuf)
if swingShowOverHighH13 and overHighH13
    f_addSigLabel(bar_index, high, "OVER\nHIGH", color.new(color.lime, 0), color.black, label.style_label_down, size.tiny)
f_alert(not onlyShSlMode and not onlyQmMode and not swingPatternOnlyAlerts and swingShowOverHighH13 and overHighH13, syminfo.ticker + " Over High (sopra H13)")

overDailyBuf = swingOverDailyBufferTicks * syminfo.mintick
overDailyLow = showUntilNyClose and not na(dLow) and ta.crossunder(low, dLow - overDailyBuf)
overDailyHigh = showUntilNyClose and not na(dHigh) and ta.crossover(high, dHigh + overDailyBuf)
if swingShowOverDaily and overDailyLow
    f_addSigLabel(bar_index, low, "OVER\nD LOW", color.new(color.red, 0), color.white, label.style_label_up, size.tiny)
if swingShowOverDaily and overDailyHigh
    f_addSigLabel(bar_index, high, "OVER\nD HIGH", color.new(color.lime, 0), color.black, label.style_label_down, size.tiny)
f_alert(not onlyShSlMode and not onlyQmMode and not swingPatternOnlyAlerts and swingShowOverDaily and overDailyLow, syminfo.ticker + " Over Daily Low")
f_alert(not onlyShSlMode and not onlyQmMode and not swingPatternOnlyAlerts and swingShowOverDaily and overDailyHigh, syminfo.ticker + " Over Daily High")

if not onlyShSlMode and not onlyQmMode and isStar13
    f_addSigLabel(bar_index, low, "★", color.yellow, color.black, label.style_label_up, size.tiny)
if not onlyShSlMode and not onlyQmMode and isStar16
    f_addSigLabel(bar_index, low, "★", color.yellow, color.black, label.style_label_up, size.tiny)
if validB
    f_addSigLabel(bar_index, low, "BUY", color.green, color.white, label.style_label_up, size.small)
if validS
    f_addSigLabel(bar_index, high, "SELL", color.red, color.white, label.style_label_down, size.small)
if showAsiaBiasArrow and asiaBiasBuy
    f_addSigLabel(bar_index, low, "A", color.green, color.white, label.style_label_up, size.small)
if showAsiaBiasArrow and asiaBiasSell
    f_addSigLabel(bar_index, low, "A", color.red, color.white, label.style_label_down, size.small)

hsIsGreen = open < close
hsIsRed = open > close
hsCandleSize = math.abs(high - low)
hsIsHammer = high - hsFibLevel * hsCandleSize < math.min(open, close)
hsIsShoot = low + hsFibLevel * hsCandleSize > math.max(open, close)
hsConfirmedHammer = hsConfirm ? hsIsHammer[1] and hsIsGreen : hsIsHammer
hsConfirmedShoot = hsConfirm ? hsIsShoot[1] and hsIsRed : hsIsShoot
hsOffset = hsConfirm ? -1 : 0
hsLblYHammer = hsConfirm ? low[1] : low
hsLblYShoot = hsConfirm ? high[1] : high
if not onlyShSlMode and not onlyQmMode and hsEnabled and hsShowLabels and hsConfirmedHammer and not na(hsLblYHammer)
    f_addSigLabel(bar_index + hsOffset, hsLblYHammer, "Hammer", color.new(color.white, 100), color.green, label.style_label_up, size.tiny)
if not onlyShSlMode and not onlyQmMode and hsEnabled and hsShowLabels and hsConfirmedShoot and not na(hsLblYShoot)
    f_addSigLabel(bar_index + hsOffset, hsLblYShoot, "Shooting", color.new(color.white, 100), color.red, label.style_label_down, size.tiny)

var line hsFib0 = na
var line hsFib0382 = na
var line hsFib05 = na
var line hsFib1 = na
var line hsFibDiag = na
var int hsFibPatternIndex = na
var float hsFibHigh = na
var float hsFibLow = na
var int hsFibDir = 0
var bool hsFibPending = false
var int hsFibExpiry = na

hsBuyTouch = false
hsSellTouch = false
deleteFibNow = false
createFibNow = false

if hsEnabled and hsFibRetraceEnabled and not onlyShSlMode and not onlyQmMode
    newHammer = hsConfirmedHammer
    newShoot = hsConfirmedShoot
    if newHammer or newShoot
        createFibNow := true
        hsFibPatternIndex := hsConfirm ? (bar_index - 1) : bar_index
        hsFibHigh := hsConfirm ? high[1] : high
        hsFibLow := hsConfirm ? low[1] : low
        hsFibDir := newHammer ? 1 : -1
        hsFibPending := true
        hsFibExpiry := hsConfirm ? bar_index : (bar_index + 1)

    if hsFibPending and not na(hsFibHigh) and not na(hsFibLow) and not na(hsFibExpiry)
        if bar_index == hsFibExpiry
            rr = hsFibHigh - hsFibLow
            lv0382 = hsFibLow + 0.382 * rr
            lv05 = hsFibLow + 0.5 * rr
            touched = (hsFibUse05 and low <= lv05 and high >= lv05) or (hsFibUse0382 and low <= lv0382 and high >= lv0382)
            if touched
                hsBuyTouch := hsFibDir == 1
                hsSellTouch := hsFibDir == -1
                hsFibPending := false
            else
                deleteFibNow := true
        else if bar_index > hsFibExpiry
            deleteFibNow := true
else
    deleteFibNow := true

if deleteFibNow or createFibNow
    if not na(hsFib0)
        line.delete(hsFib0)
    if not na(hsFib0382)
        line.delete(hsFib0382)
    if not na(hsFib05)
        line.delete(hsFib05)
    if not na(hsFib1)
        line.delete(hsFib1)
    if not na(hsFibDiag)
        line.delete(hsFibDiag)
    hsFib0 := na
    hsFib0382 := na
    hsFib05 := na
    hsFib1 := na
    hsFibDiag := na
    if deleteFibNow
        hsFibPatternIndex := na
        hsFibHigh := na
        hsFibLow := na
        hsFibDir := 0
        hsFibPending := false
        hsFibExpiry := na

if not onlyShSlMode and not onlyQmMode and createFibNow and not na(hsFibPatternIndex) and not na(hsFibHigh) and not na(hsFibLow)
    r = hsFibHigh - hsFibLow
    lv0 = hsFibLow
    lv1 = hsFibHigh
    lv0382 = hsFibLow + 0.382 * r
    lv05 = hsFibLow + 0.5 * r
    hsFib0 := line.new(hsFibPatternIndex, lv0, hsFibPatternIndex + 1, lv0, extend=extend.right, color=color.new(color.gray, 0), width=1)
    hsFib1 := line.new(hsFibPatternIndex, lv1, hsFibPatternIndex + 1, lv1, extend=extend.right, color=color.new(color.gray, 0), width=1)
    if hsFibUse0382
        hsFib0382 := line.new(hsFibPatternIndex, lv0382, hsFibPatternIndex + 1, lv0382, extend=extend.right, color=color.orange, width=2)
    if hsFibUse05
        hsFib05 := line.new(hsFibPatternIndex, lv05, hsFibPatternIndex + 1, lv05, extend=extend.right, color=color.green, width=2)
    hsFibDiag := line.new(hsFibPatternIndex, hsFibHigh, hsFibPatternIndex + 20, hsFibLow, extend=extend.none, color=color.new(color.gray, 30), style=line.style_dashed, width=1)

if not onlyShSlMode and not onlyQmMode and hsBuyTouch
    f_addSigLabel(bar_index, low, "BUY", color.lime, color.black, label.style_label_up, size.tiny)
if not onlyShSlMode and not onlyQmMode and hsSellTouch
    f_addSigLabel(bar_index, high, "SELL", color.red, color.white, label.style_label_down, size.tiny)

canMidLong = midnightSignalsEnabled and midSweepDown and not midLongDone and (bar_index - midSweepDownBar) <= reclaimMaxBars
canMidShort = midnightSignalsEnabled and midSweepUp and not midShortDone and (bar_index - midSweepUpBar) <= reclaimMaxBars

midLong = canMidLong and close > midL and isKill and dailyOkB and ibOkB
midShort = canMidShort and close < midH and isKill and dailyOkS and ibOkS

if midLong
    midLongDone := true
if midShort
    midShortDone := true

if not onlyShSlMode and not onlyQmMode and midLong
    f_addSigLabel(bar_index, low, "BUY\nMID", color.aqua, color.black, label.style_label_up, size.tiny)
if not onlyShSlMode and not onlyQmMode and midShort
    f_addSigLabel(bar_index, high, "SELL\nMID", color.fuchsia, color.white, label.style_label_down, size.tiny)

var float lux_phy = na
var float lux_ply = na

lux_o = open[luxLen]
lux_h = high[luxLen]
lux_l = low[luxLen]
lux_c = close[luxLen]
lux_d = math.abs(lux_c - lux_o)
lux_ph = ta.pivothigh(luxLen, luxLen)
lux_pl = ta.pivotlow(luxLen, luxLen)

lux_has_pl = not na(lux_pl)
lux_has_ph = not na(lux_ph)

lux_hammer = lux_has_pl and math.min(lux_o, lux_c) - lux_l > lux_d and lux_h - math.max(lux_c, lux_o) < lux_d
lux_ihammer = lux_has_pl and lux_h - math.max(lux_c, lux_o) > lux_d and math.min(lux_c, lux_o) - lux_l < lux_d
lux_bulleng = lux_c > lux_o and lux_c[1] < lux_o[1] and lux_c > lux_o[1] and lux_o < lux_c[1]
lux_hanging = lux_has_ph and math.min(lux_c, lux_o) - lux_l > lux_d and lux_h - math.max(lux_o, lux_c) < lux_d
lux_shooting = lux_has_ph and lux_h - math.max(lux_o, lux_c) > lux_d and math.min(lux_c, lux_o) - lux_l < lux_d
lux_beareng = lux_c > lux_o and lux_c[1] < lux_o[1] and lux_c > lux_o[1] and lux_o < lux_c[1]

lux_code = lux_hammer ? 1 : lux_ihammer ? 2 : lux_bulleng ? 3 : lux_hanging ? 4 : lux_shooting ? 5 : lux_beareng ? 6 : 0
lux_title = lux_code == 1 ? "Hammer" : lux_code == 2 ? "Inverted Hammer" : lux_code == 3 ? "Bullish Engulfing" : lux_code == 4 ? "Hanging Man" : lux_code == 5 ? "Shooting Star" : lux_code == 6 ? "Bearish Engulfing" : "None"
luxPatternAllowed = (lux_code == 0 and luxNotifyNone) or (lux_code == 1 and luxNotifyHammer) or (lux_code == 2 and luxNotifyInvertedHammer) or (lux_code == 3 and luxNotifyBullishEngulfing) or (lux_code == 4 and luxNotifyHangingMan) or (lux_code == 5 and luxNotifyShootingStar) or (lux_code == 6 and luxNotifyBearishEngulfing)
luxTitleForLabel = (luxNotifyPatterns and luxPatternAllowed) ? lux_title : ""

if luxEnabled and not onlyShSlMode and not onlyQmMode and (lux_has_ph or lux_has_pl)
    if lux_has_ph
        H = na(lux_phy) ? "HH" : (lux_ph > lux_phy ? "HH" : "LH")
        lux_phy := lux_ph
        if luxShowLabels
            label.new(bar_index[luxLen], lux_ph, luxTitleForLabel == "" ? H : (H + "\n" + luxTitleForLabel), color=color.new(color.white, 100), style=label.style_label_down, textcolor=luxSwingHColor, size=size.small)
    else if lux_has_pl
        L = na(lux_ply) ? "HL" : (lux_pl < lux_ply ? "LL" : "HL")
        lux_ply := lux_pl
        if luxShowLabels
            label.new(bar_index[luxLen], lux_pl, luxTitleForLabel == "" ? L : (L + "\n" + luxTitleForLabel), color=color.new(color.white, 100), style=label.style_label_up, textcolor=luxSwingLColor, size=size.small)

instLbLeft = 1
instLbRight = 1
var int instBullSignalIndex = 0
var int instBearSignalIndex = 0

var line instBullLine = na
var line instBearLine = na

var line instHighLine = na
var line instLowLine = na

var label instSwingHighLbl = na
var label instSwingLowLbl = na
var label instSwingHighLblTxt = na
var label instSwingLowLblTxt = na

var float instSwingLowVal = na
var float instSwingHighVal = na

var int instSwingLowCounter = 0
var int instSwingHighCounter = 0
var bool instIsSwingLowCheck = false
var bool instIsSwingHighCheck = false
var bool instStopPrintingLow = false
var bool instStopPrintingHigh = false

var instSwingHighArr = array.new_label(0)
var instSwingHighTextArr = array.new_label(0)
var instSwingLowArr = array.new_label(0)
var instSwingLowTextArr = array.new_label(0)

instPL = ta.pivotlow(low, instLbLeft, instLbRight)
instPH = ta.pivothigh(high, instLbLeft, instLbRight)
instPLVal = ta.valuewhen(not na(instPL), low[instLbRight], 0)
instPHVal = ta.valuewhen(not na(instPH), high[instLbRight], 0)
instPrevLowIndex = ta.valuewhen(not na(instPL), bar_index[instLbRight], 0)
instPrevHighIndex = ta.valuewhen(not na(instPH), bar_index[instLbRight], 0)
instLP = ta.lowest(low, instLbLeft)
instHP = ta.highest(high, instLbLeft)
instHighestClose = ta.highest(close, instLbLeft)
instLowestClose = ta.lowest(close, instLbLeft)

instBullishSFP = low < instPLVal and close > instPLVal and open > instPLVal and low == instLP and instLowestClose >= instPLVal
instBearishSFP = high > instPHVal and close < instPHVal and open < instPHVal and high == instHP and instHighestClose <= instPHVal

instBullCond = instBullishSFP[3] and close > instPLVal and close[1] > instPLVal[1] and close[2] > instPLVal[2] and bar_index >= instBullSignalIndex + instCooldownPeriod
instBearCond = instBearishSFP[3] and close < instPHVal and close[1] < instPHVal[1] and close[2] < instPHVal[2] and bar_index >= instBearSignalIndex + instCooldownPeriod

if instEnabled and not onlyShSlMode and not onlyQmMode
    if high < instSwingLowVal and instIsSwingLowCheck
        instSwingLowCounter := instSwingLowCounter + 1

    if low > instSwingHighVal and instIsSwingHighCheck
        instSwingHighCounter := instSwingHighCounter + 1

    if ta.crossunder(close, instSwingLowVal) and instIsSwingLowCheck == false
        instIsSwingLowCheck := true
        instSwingLowCounter := 1

    if ta.crossover(close, instSwingHighVal) and instIsSwingHighCheck == false
        instIsSwingHighCheck := true
        instSwingHighCounter := 1

    if instSwingLowCounter == 5 and instIsSwingLowCheck
        instStopPrintingLow := true
        instIsSwingLowCheck := false
        line.set_x2(instLowLine, bar_index[4])

    if instSwingHighCounter == 5 and instIsSwingHighCheck
        instStopPrintingHigh := true
        instIsSwingHighCheck := false
        line.set_x2(instHighLine, bar_index[4])

if instEnabled and not onlyShSlMode and not onlyQmMode and instBullCond
    instBullSignalIndex := bar_index
    instBullLine := line.new(instPrevLowIndex, instPLVal, bar_index - 3, instPLVal, color=instBullColor, width=instBullWidth, style=instLineStyle(instBullStyle))

if instEnabled and not onlyShSlMode and not onlyQmMode and instBearCond
    instBearSignalIndex := bar_index
    instBearLine := line.new(instPrevHighIndex, instPHVal, bar_index - 3, instPHVal, color=instBearColor, width=instBearWidth, style=instLineStyle(instBearStyle))

if instEnabled and not onlyShSlMode and not onlyQmMode
    if array.size(instSwingHighArr) >= 3
        label.delete(array.shift(instSwingHighArr))
        label.delete(array.shift(instSwingHighTextArr))

    if array.size(instSwingLowArr) >= 3
        label.delete(array.shift(instSwingLowArr))
        label.delete(array.shift(instSwingLowTextArr))

    if instShowSwing
        if instStopPrintingHigh == false
            line.set_x2(instHighLine, bar_index + 5)
        if instStopPrintingLow == false
            line.set_x2(instLowLine, bar_index + 5)

    if instShowSwing and not na(instPH) and instBearishSFP[instLbRight] == false
        instStopPrintingHigh := false
        instSwingHighVal := high[instLbRight]
        line.delete(instHighLine)
        instHighLine := line.new(bar_index[instLbRight], high[instLbRight], bar_index + 10, high[instLbRight], color=instSwingClr, width=2)

        instSwingHighLbl := label.new(bar_index[instLbRight], high[instLbRight], text="", yloc=yloc.abovebar, color=instSwingClr, textcolor=instSwingClr, style=label.style_triangledown, size=size.auto)
        instSwingHighLblTxt := label.new(bar_index[instLbRight], high[instLbRight], text="Swing\nH", yloc=yloc.abovebar, color=instSwingClr, textcolor=instSwingClr, style=label.style_none, size=size.small)
        array.push(instSwingHighArr, instSwingHighLbl)
        array.push(instSwingHighTextArr, instSwingHighLblTxt)

    if instShowSwing and not na(instPL) and instBullishSFP[instLbRight] == false
        instStopPrintingLow := false
        instSwingLowVal := low[instLbRight]
        line.delete(instLowLine)
        instLowLine := line.new(bar_index[instLbRight], low[instLbRight], bar_index + 10, low[instLbRight], color=instSwingClr, width=2)

        instSwingLowLbl := label.new(bar_index[instLbRight], low[instLbRight], text="", yloc=yloc.belowbar, color=instSwingClr, textcolor=instSwingClr, style=label.style_triangleup, size=size.auto)
        instSwingLowLblTxt := label.new(bar_index[instLbRight], low[instLbRight], text="Swing\nL", yloc=yloc.belowbar, color=instSwingClr, textcolor=instSwingClr, style=label.style_none, size=size.small)
        array.push(instSwingLowArr, instSwingLowLbl)
        array.push(instSwingLowTextArr, instSwingLowLblTxt)

if not onlyShSlMode and not onlyQmMode and instEnabled and instBullCond and not na(low[3])
    f_addSigLabel(bar_index - 3, low[3], "Sweep", color.new(instBullColor, 0), color.white, label.style_label_up, size.tiny)
if not onlyShSlMode and not onlyQmMode and instEnabled and instBearCond and not na(high[3])
    f_addSigLabel(bar_index - 3, high[3], "Sweep", color.new(instBearColor, 0), color.white, label.style_label_down, size.tiny)

earlyAvgVol = ta.sma(volume, 20)
earlyStrongVol = volume > earlyAvgVol
earlyDailyBuf = earlyDailyExtremeBufferTicks * syminfo.mintick

earlyPotentialLow = low <= ta.lowest(low, earlyLeftBars + 1)
earlyLiquiditySweepLow = low < low[1] and close > low[1]
earlyBullReaction = close > open
earlyPassLow = not earlyShowDailyExtremeShSl or (not na(dLow) and math.abs(low - dLow) <= earlyDailyBuf)
earlySwingLow = earlySwingEnabled and earlyPotentialLow and earlyLiquiditySweepLow and earlyBullReaction and (not earlyVolFilter or earlyStrongVol) and earlyPassLow

earlyPotentialHigh = high >= ta.highest(high, earlyLeftBars + 1)
earlyLiquiditySweepHigh = high > high[1] and close < high[1]
earlyBearReaction = close < open
earlyPassHigh = not earlyShowDailyExtremeShSl or (not na(dHigh) and math.abs(high - dHigh) <= earlyDailyBuf)
earlySwingHigh = earlySwingEnabled and earlyPotentialHigh and earlyLiquiditySweepHigh and earlyBearReaction and (not earlyVolFilter or earlyStrongVol) and earlyPassHigh

if not onlyShSlMode and not onlyQmMode and earlySwingLow
    if earlyShowLabels
        f_addSigLabel(bar_index, low, "Possible SWL", color.yellow, color.black, label.style_label_up, size.small)
    else
        f_addSigLabel(bar_index, low, "SWL?", color.yellow, color.black, label.style_label_up, size.tiny)

if not onlyShSlMode and not onlyQmMode and earlyShowPossibleSWH and earlySwingHigh
    if earlyShowLabels
        f_addSigLabel(bar_index, high, "Possible SWH", color.yellow, color.black, label.style_label_down, size.small)
    else
        f_addSigLabel(bar_index, high, "SWH?", color.yellow, color.black, label.style_label_down, size.tiny)

f_alert(not onlyShSlMode and not onlyQmMode and not swingPatternOnlyAlerts and earlySwingLow, "Possibile Swing Low in formazione")
f_alert(not onlyShSlMode and not onlyQmMode and not swingPatternOnlyAlerts and earlySwingHigh, "Possibile Swing High in formazione")

tfIsM1 = timeframe.isminutes and timeframe.multiplier == 1
tfIsM5 = timeframe.isminutes and timeframe.multiplier == 5
tfIsM15 = timeframe.isminutes and timeframe.multiplier == 15
tfIsH1 = timeframe.isminutes and timeframe.multiplier == 60
tfIsH4 = timeframe.isminutes and timeframe.multiplier == 240

[crtRangeH, crtRangeL, crtEq, crtDir, crtSoupH, crtSoupL, crtEntryLong, crtEntryShort, crtSoupT, crtSoup, crtBullSoup, crtBearSoup, crtDayH, crtDayL, crtInKill, crtRsi, crtLastShT, crtLastSlT, crtSoupDayH, crtSoupDayL, crtSoupInKill] = request.security(syminfo.tickerid, crtTf, f_crt(), barmerge.gaps_off, barmerge.lookahead_off)
crtDailyBuf = crtDailyExtremeBufferTicks * syminfo.mintick
crtBullOk = not crtUseDailyExtreme or (not na(crtSoupDayL) and not na(crtSoupL) and math.abs(crtSoupL - crtSoupDayL) <= crtDailyBuf)
crtBearOk = not crtUseDailyExtreme or (not na(crtSoupDayH) and not na(crtSoupH) and math.abs(crtSoupH - crtSoupDayH) <= crtDailyBuf)
crtSoupOk = (crtDir == 1 and crtBullOk) or (crtDir == -1 and crtBearOk)
crtSoupKillOk = not crtUseKillzone or crtSoupInKill

var line crtLineH = na
var line crtLineL = na
var line crtLineEq = na
var int crtLastSoupTime = na
var label crtSoupLbl = na
var label crtEntryLbl = na
crtNewSoup = crtEnabled and not onlyShSlMode and not onlyQmMode and crtSoup and crtSoupOk and crtSoupKillOk and not na(crtSoupT) and (na(crtLastSoupTime) or crtSoupT != crtLastSoupTime)
if crtNewSoup
    if not na(crtLineH)
        line.delete(crtLineH)
        crtLineH := na
    if not na(crtLineL)
        line.delete(crtLineL)
        crtLineL := na
    if not na(crtLineEq)
        line.delete(crtLineEq)
        crtLineEq := na
    if crtShowLines and not na(crtRangeH) and not na(crtRangeL)
        crtLineH := line.new(bar_index, crtRangeH, bar_index + 1, crtRangeH, extend=extend.right, color=color.new(color.orange, 0), width=1)
        crtLineL := line.new(bar_index, crtRangeL, bar_index + 1, crtRangeL, extend=extend.right, color=color.new(color.aqua, 0), width=1)
        if not na(crtEq)
            crtLineEq := line.new(bar_index, crtEq, bar_index + 1, crtEq, extend=extend.right, color=color.new(color.gray, 40), width=1, style=line.style_dashed)
    if crtShowLabels
        if not na(crtSoupLbl)
            label.delete(crtSoupLbl)
        crtSoupLbl := label.new(bar_index, close, crtDir == 1 ? "CRT\nBULL" : "CRT\nBEAR", xloc=xloc.bar_index, style=crtDir == 1 ? label.style_label_up : label.style_label_down, color=color.new(color.black, 0), textcolor=color.white, size=size.tiny)
    crtLastSoupTime := crtSoupT

if (not crtEnabled) or onlyShSlMode or (not crtShowLabels) or (crtUseKillzone and not crtSoupKillOk)
    if not na(crtSoupLbl)
        label.delete(crtSoupLbl)
        crtSoupLbl := na

crtEntryLongRaw = crtEnabled and not onlyShSlMode and not onlyQmMode and crtEntryLong and crtBullOk and crtSoupKillOk
crtEntryShortRaw = crtEnabled and not onlyShSlMode and not onlyQmMode and crtEntryShort and crtBearOk and crtSoupKillOk

swingLbL = swingPatternUseTfBars ? (tfIsM1 ? swingPatternLeftBars_M1 : tfIsM15 ? swingPatternLeftBars_M15 : tfIsH1 ? swingPatternLeftBars_H1 : tfIsH4 ? swingPatternLeftBars_H4 : swingPatternLeftBars) : swingPatternLeftBars
swingLbR = swingPatternUseTfBars ? (tfIsM1 ? swingPatternRightBars_M1 : tfIsM15 ? swingPatternRightBars_M15 : tfIsH1 ? swingPatternRightBars_H1 : tfIsH4 ? swingPatternRightBars_H4 : swingPatternRightBars) : swingPatternRightBars

swingWin = swingLbL + swingLbR
swingCenter = swingLbR
hasSwingWindow = bar_index >= swingWin

swingRsi = ta.rsi(close, swingBullDivRsiLen)
rsiMa = rsiCrossMaType == "EMA" ? ta.ema(swingRsi, rsiCrossMaLen) : ta.sma(swingRsi, rsiCrossMaLen)
rsiCrossDailyBuf = rsiCrossDailyExtremeBufferTicks * syminfo.mintick
rsiCrossSessBuf = rsiCrossSessionExtremeBufferTicks * syminfo.mintick
rsiCrossNearDailyHigh = rsiCrossUseDailyExtreme and not na(dHigh[swingCenter]) and math.abs(high[swingCenter] - dHigh[swingCenter]) <= rsiCrossDailyBuf
rsiCrossNearDailyLow = rsiCrossUseDailyExtreme and not na(dLow[swingCenter]) and math.abs(low[swingCenter] - dLow[swingCenter]) <= rsiCrossDailyBuf
rsiCrossNearSessHigh = rsiCrossUseSessionExtreme and (
     (rsiCrossSessionUseAsia and not na(asiaHigh[swingCenter]) and math.abs(high[swingCenter] - asiaHigh[swingCenter]) <= rsiCrossSessBuf) or
     (rsiCrossSessionUseLondon and not na(londonHighLive[swingCenter]) and math.abs(high[swingCenter] - londonHighLive[swingCenter]) <= rsiCrossSessBuf) or
     (rsiCrossSessionUseNy and not na(nyHighLive[swingCenter]) and math.abs(high[swingCenter] - nyHighLive[swingCenter]) <= rsiCrossSessBuf)
 )
rsiCrossNearSessLow = rsiCrossUseSessionExtreme and (
     (rsiCrossSessionUseAsia and not na(asiaLow[swingCenter]) and math.abs(low[swingCenter] - asiaLow[swingCenter]) <= rsiCrossSessBuf) or
     (rsiCrossSessionUseLondon and not na(londonLowLive[swingCenter]) and math.abs(low[swingCenter] - londonLowLive[swingCenter]) <= rsiCrossSessBuf) or
     (rsiCrossSessionUseNy and not na(nyLowLive[swingCenter]) and math.abs(low[swingCenter] - nyLowLive[swingCenter]) <= rsiCrossSessBuf)
 )
rsiCrossExtremeFilterOn = rsiCrossUseDailyExtreme or rsiCrossUseSessionExtreme
rsiCrossUpAtPivot = rsiCrossEnabled and swingRsi[swingCenter] > rsiMa[swingCenter] and swingRsi[swingCenter + 1] <= rsiMa[swingCenter + 1]
rsiCrossDnAtPivot = rsiCrossEnabled and swingRsi[swingCenter] < rsiMa[swingCenter] and swingRsi[swingCenter + 1] >= rsiMa[swingCenter + 1]
rsiCrossUpOkAtPivot = not rsiCrossExtremeFilterOn or rsiCrossNearDailyLow or rsiCrossNearSessLow
rsiCrossDnOkAtPivot = not rsiCrossExtremeFilterOn or rsiCrossNearDailyHigh or rsiCrossNearSessHigh

rsiPivotLen = rsiPatternUseTfPivots ? (tfIsM1 ? rsiPatternPivotLen_M1 : tfIsM15 ? rsiPatternPivotLen_M15 : tfIsH1 ? rsiPatternPivotLen_H1 : tfIsH4 ? rsiPatternPivotLen_H4 : rsiPatternPivotLen) : rsiPatternPivotLen
rsiPivotPh = ta.pivothigh(swingRsi, rsiPivotLen, rsiPivotLen)
rsiPivotPl = ta.pivotlow(swingRsi, rsiPivotLen, rsiPivotLen)
rsiPivotBar = bar_index - rsiPivotLen

var float rsiWLow1 = na
var int rsiWLow1Bar = na
var float rsiWMidHigh = na
var int rsiWMidHighBar = na

var float rsiMHigh1 = na
var int rsiMHigh1Bar = na
var float rsiMMidLow = na
var int rsiMMidLowBar = na

rsiWSig = false
rsiMSig = false

if rsiPatternEnabled and not onlyShSlMode and (not onlyQmMode or onlyQmShowRsiMW)
    rsiPatternDailyBuf = rsiPatternDailyExtremeBufferTicks * syminfo.mintick
    if not na(rsiPivotPh)
        phVal = rsiPivotPh
        phBar = rsiPivotBar
        rsiMNearDailyHigh = rsiPatternUseDailyExtreme and not na(dHigh[rsiPivotLen]) and math.abs(high[rsiPivotLen] - dHigh[rsiPivotLen]) <= rsiPatternDailyBuf
        if not na(rsiWLow1Bar) and phBar > rsiWLow1Bar
            rsiWMidHigh := na(rsiWMidHigh) ? phVal : math.max(rsiWMidHigh, phVal)
            rsiWMidHighBar := phBar

        if na(rsiMHigh1)
            rsiMHigh1 := phVal
            rsiMHigh1Bar := phBar
            rsiMMidLow := na
            rsiMMidLowBar := na
        else
            hasMid = not na(rsiMMidLow) and not na(rsiMMidLowBar) and rsiMMidLowBar > rsiMHigh1Bar and rsiMMidLowBar < phBar
            lowerHigh = phVal <= (rsiMHigh1 - rsiPatternMinDelta)
            deepEnough = hasMid and rsiMMidLow <= (math.min(rsiMHigh1, phVal) - rsiPatternMidDelta)
            if hasMid and lowerHigh and deepEnough and (not rsiPatternUseDailyExtreme or rsiMNearDailyHigh)
                rsiMSig := true
                if rsiPatternShowLabels
                    f_addSigLabel(phBar, high[rsiPivotLen], "RSI\nM", color.new(color.red, 0), color.black, label.style_label_down, size.tiny)
                rsiMHigh1 := phVal
                rsiMHigh1Bar := phBar
                rsiMMidLow := na
                rsiMMidLowBar := na
            else if phVal > rsiMHigh1
                rsiMHigh1 := phVal
                rsiMHigh1Bar := phBar
                rsiMMidLow := na
                rsiMMidLowBar := na

    if not na(rsiPivotPl)
        plVal = rsiPivotPl
        plBar = rsiPivotBar
        rsiWNearDailyLow = rsiPatternUseDailyExtreme and not na(dLow[rsiPivotLen]) and math.abs(low[rsiPivotLen] - dLow[rsiPivotLen]) <= rsiPatternDailyBuf
        if not na(rsiMHigh1Bar) and plBar > rsiMHigh1Bar
            rsiMMidLow := na(rsiMMidLow) ? plVal : math.min(rsiMMidLow, plVal)
            rsiMMidLowBar := plBar

        if na(rsiWLow1)
            rsiWLow1 := plVal
            rsiWLow1Bar := plBar
            rsiWMidHigh := na
            rsiWMidHighBar := na
        else
            hasMid = not na(rsiWMidHigh) and not na(rsiWMidHighBar) and rsiWMidHighBar > rsiWLow1Bar and rsiWMidHighBar < plBar
            higherLow = plVal >= (rsiWLow1 + rsiPatternMinDelta)
            highEnough = hasMid and rsiWMidHigh >= (math.max(rsiWLow1, plVal) + rsiPatternMidDelta)
            if hasMid and higherLow and highEnough and (not rsiPatternUseDailyExtreme or rsiWNearDailyLow)
                rsiWSig := true
                if rsiPatternShowLabels
                    f_addSigLabel(plBar, low[rsiPivotLen], "RSI\nW", color.new(color.aqua, 0), color.black, label.style_label_up, size.tiny)
                rsiWLow1 := plVal
                rsiWLow1Bar := plBar
                rsiWMidHigh := na
                rsiWMidHighBar := na
            else if plVal < rsiWLow1
                rsiWLow1 := plVal
                rsiWLow1Bar := plBar
                rsiWMidHigh := na
                rsiWMidHighBar := na

[macdLine, macdSignal, _] = ta.macd(close, 12, 26, 9)
macdBullCross = ta.crossover(macdLine, macdSignal)
macdBearCross = ta.crossunder(macdLine, macdSignal)

buyThr = swingRsiMode == "Aggressive" ? swingRsiBuyAgg : swingRsiBuyCons
sellThr = swingRsiMode == "Aggressive" ? swingRsiSellAgg : swingRsiSellCons
passRsiSh = not swingRsiFilterEnabled or swingRsi[swingCenter] >= sellThr
passRsiSl = not swingRsiFilterEnabled or swingRsi[swingCenter] <= buyThr
passMacdSh = not swingMacdConfirmEnabled or macdBearCross
passMacdSl = not swingMacdConfirmEnabled or macdBullCross
swingEps = syminfo.mintick * 0.1
swingSep = swingMinReactionSepTicks * syminfo.mintick
swingMinSwingRange = swingMinSwingRangeTicks * syminfo.mintick
var float swingLastLowPrice = na
var float swingLastLowRsi = na
var int swingLastLowBarIndex = na
var float swingLastHighPrice = na
var float swingLastHighRsi = na
var int swingLastHighBarIndex = na
var swingDivLines = array.new_line(0)
var float swingLiqLastLowPrice = na
var float swingLiqLastHighPrice = na
var bool swingOppSweptForSH = false
var bool swingOppSweptForSL = false

swingPH = ta.pivothigh(high, swingLbL, swingLbR)
swingPL = ta.pivotlow(low, swingLbL, swingLbR)

var float swingLastSweepLowLevel = na
var float swingLastSweepHighLevel = na
var bool swingAllowSL = true
var bool swingAllowSH = true
var bool swingAsiaSweptH = false
var bool swingAsiaSweptL = false
var bool swingIbSweptH = false
var bool swingIbSweptL = false

if is_0000
    swingLastSweepLowLevel := na
    swingLastSweepHighLevel := na
    swingAllowSL := true
    swingAllowSH := true
    swingLiqLastLowPrice := na
    swingLiqLastHighPrice := na
    swingOppSweptForSH := false
    swingOppSweptForSL := false
    swingAsiaSweptH := false
    swingAsiaSweptL := false
    swingIbSweptH := false
    swingIbSweptL := false

swingInAsiaSweepWin = not na(time(timeframe.period, swingAsiaSweepWindow, tz))
swingInIBSweepWin = not na(time(timeframe.period, swingIBSweepWindow, tz))

if swingInAsiaSweepWin and asiaRangeHas
    if high > asiaHigh
        swingAsiaSweptH := true
    if low < asiaLow
        swingAsiaSweptL := true

if swingInIBSweepWin and not na(ibH) and not na(ibL)
    if high > ibH
        swingIbSweptH := true
    if low < ibL
        swingIbSweptL := true

if (isKill or sweepOutsideKillzone) and not na(orangeL) and low < orangeL
    swingLastSweepLowLevel := orangeL
    swingAllowSL := false

if (isKill or sweepOutsideKillzone) and not na(orangeH) and high > orangeH
    swingLastSweepHighLevel := orangeH
    swingAllowSH := false

if not na(swingLastSweepLowLevel) and ta.crossover(close, swingLastSweepLowLevel)
    swingAllowSL := true

if not na(swingLastSweepHighLevel) and ta.crossunder(close, swingLastSweepHighLevel)
    swingAllowSH := true

swingRangeOk = (high[swingCenter] - low[swingCenter]) >= swingMinSwingRange
swingReactBearOk = close[swingCenter - 1] < open[swingCenter - 1] and high[swingCenter - 1] < (high[swingCenter] - swingSep) and open[swingCenter - 1] < (high[swingCenter] - swingSep) and close[swingCenter - 1] < (high[swingCenter] - swingSep)
swingReactBullOk = close[swingCenter - 1] > open[swingCenter - 1] and low[swingCenter - 1] > (low[swingCenter] + swingSep) and open[swingCenter - 1] > (low[swingCenter] + swingSep) and close[swingCenter - 1] > (low[swingCenter] + swingSep)
swingBosBearOk = not swingConfirmBos or (swingLbR == 1 ? close < low[swingCenter] : close < low[swingCenter - 1])
swingBosBullOk = not swingConfirmBos or (swingLbR == 1 ? close > high[swingCenter] : close > high[swingCenter - 1])

swingHighOkInst = not na(swingPH) and swingRangeOk and swingReactBearOk and swingBosBearOk
swingLowOkInst = not na(swingPL) and swingRangeOk and swingReactBullOk and swingBosBullOk

swingHighOkStrict = hasSwingWindow
if swingHighOkStrict
    for i = 0 to swingWin
        if i != swingCenter and high[i] >= high[swingCenter]
            swingHighOkStrict := false
    for j = swingLbL to 1
        if high[swingCenter + j] >= high[swingCenter + j - 1]
            swingHighOkStrict := false
    for j = 1 to swingLbR
        if high[swingCenter - j + 1] <= high[swingCenter - j]
            swingHighOkStrict := false
    swingHighOkStrict := swingHighOkStrict and swingRangeOk and swingReactBearOk and swingBosBearOk

swingLowOkStrict = hasSwingWindow
if swingLowOkStrict
    for i = 0 to swingWin
        if i != swingCenter and low[i] <= low[swingCenter]
            swingLowOkStrict := false
    for j = swingLbL to 1
        if low[swingCenter + j] <= low[swingCenter + j - 1]
            swingLowOkStrict := false
    for j = 1 to swingLbR
        if low[swingCenter - j + 1] >= low[swingCenter - j]
            swingLowOkStrict := false
    swingLowOkStrict := swingLowOkStrict and swingRangeOk and swingReactBullOk and swingBosBullOk

swingHighOk = swingUseInstitutionalSwings ? swingHighOkInst : swingHighOkStrict
swingLowOk = swingUseInstitutionalSwings ? swingLowOkInst : swingLowOkStrict

swingOppBuf = swingOppositeSwingSweepBufferTicks * syminfo.mintick
swingHighOkBase = swingHighOk and (not swingRequireReclaimAfterSweep or swingAllowSH)
swingLowOkBase = swingLowOk and (not swingRequireReclaimAfterSweep or swingAllowSL)

if swingPatternEnabled and swingLowOkBase
    swingLiqLastLowPrice := low[swingCenter]
    swingOppSweptForSH := false
    if swingRequireOppositeSwingSweep and not na(swingLiqLastLowPrice) and ta.lowest(low, swingCenter) < (swingLiqLastLowPrice - swingOppBuf)
        swingOppSweptForSH := true
if swingPatternEnabled and swingHighOkBase
    swingLiqLastHighPrice := high[swingCenter]
    swingOppSweptForSL := false
    if swingRequireOppositeSwingSweep and not na(swingLiqLastHighPrice) and ta.highest(high, swingCenter) > (swingLiqLastHighPrice + swingOppBuf)
        swingOppSweptForSL := true

if swingPatternEnabled and swingRequireOppositeSwingSweep
    if not na(swingLiqLastLowPrice) and low < (swingLiqLastLowPrice - swingOppBuf)
        swingOppSweptForSH := true
    if not na(swingLiqLastHighPrice) and high > (swingLiqLastHighPrice + swingOppBuf)
        swingOppSweptForSL := true

requireAnySessionSweep = swingRequireH13L13Sweep or swingRequireAsiaSweep or swingRequireIBSweep
passSessionSh = not requireAnySessionSweep or (swingRequireH13L13Sweep and sweptL) or (swingRequireAsiaSweep and swingAsiaSweptH) or (swingRequireIBSweep and swingIbSweptH)
passSessionSl = not requireAnySessionSweep or (swingRequireH13L13Sweep and sweptH) or (swingRequireAsiaSweep and swingAsiaSweptL) or (swingRequireIBSweep and swingIbSweptL)

swingHighOk := swingHighOkBase and (not swingRequireOppositeSwingSweep or (not na(swingLiqLastLowPrice) and swingOppSweptForSH)) and passSessionSh
swingLowOk := swingLowOkBase and (not swingRequireOppositeSwingSweep or (not na(swingLiqLastHighPrice) and swingOppSweptForSL)) and passSessionSl

swingBullDiv = swingPatternEnabled and swingBullDivEnabled and swingLowOk and not na(swingLastLowPrice) and low[swingCenter] < swingLastLowPrice and swingRsi[swingCenter] > (swingLastLowRsi + swingDivMinRsiDelta) and (not swingDivUseRsiThresholds or swingLastLowRsi <= swingDivBullPrevRsiMax)
if onlyShSlMode
    while array.size(swingDivLines) > 0
        line.delete(array.shift(swingDivLines))
if not onlyShSlMode and not onlyQmMode and swingBullDiv and not na(swingLastLowBarIndex)
    newX = bar_index - swingCenter
    newY = low[swingCenter]
    ln = line.new(swingLastLowBarIndex, swingLastLowPrice, newX, newY, color=color.new(color.aqua, 0), width=2)
    array.push(swingDivLines, ln)
    if array.size(swingDivLines) > 10
        line.delete(array.shift(swingDivLines))
if swingPatternEnabled and swingLowOk
    swingLastLowPrice := low[swingCenter]
    swingLastLowRsi := swingRsi[swingCenter]
    swingLastLowBarIndex := bar_index - swingCenter
    swingOppSweptForSH := false

swingBearDiv = swingPatternEnabled and swingBullDivEnabled and swingHighOk and not na(swingLastHighPrice) and high[swingCenter] > swingLastHighPrice and swingRsi[swingCenter] < (swingLastHighRsi - swingDivMinRsiDelta) and (not swingDivUseRsiThresholds or swingLastHighRsi >= swingDivBearPrevRsiMin)
if not onlyShSlMode and not onlyQmMode and swingBearDiv and not na(swingLastHighBarIndex)
    newXh = bar_index - swingCenter
    newYh = high[swingCenter]
    lnh = line.new(swingLastHighBarIndex, swingLastHighPrice, newXh, newYh, color=color.new(color.fuchsia, 0), width=2)
    array.push(swingDivLines, lnh)
    if array.size(swingDivLines) > 10
        line.delete(array.shift(swingDivLines))
if swingPatternEnabled and swingHighOk
    swingLastHighPrice := high[swingCenter]
    swingLastHighRsi := swingRsi[swingCenter]
    swingLastHighBarIndex := bar_index - swingCenter
    swingOppSweptForSL := false

swingDailyBuf = swingDailyExtremeBufferTicks * syminfo.mintick
swingSessBuf = swingSessionExtremeBufferTicks * syminfo.mintick

dHighAtPivot = dHigh[swingCenter]
dLowAtPivot = dLow[swingCenter]
nearDailyHigh = (swingShowDailyExtremeShSl and not na(dHighAtPivot) and math.abs(high[swingCenter] - dHighAtPivot) <= swingDailyBuf)
nearDailyLow = (swingShowDailyExtremeShSl and not na(dLowAtPivot) and math.abs(low[swingCenter] - dLowAtPivot) <= swingDailyBuf)
divDailyBuf = swingDivDailyExtremeBufferTicks * syminfo.mintick
divNearDailyHigh = not na(dHighAtPivot) and math.abs(high[swingCenter] - dHighAtPivot) <= divDailyBuf
divNearDailyLow = not na(dLowAtPivot) and math.abs(low[swingCenter] - dLowAtPivot) <= divDailyBuf

asiaHas = not na(asiaHigh) and not na(asiaLow)
londonHas = not na(londonHighLive) and not na(londonLowLive)
nyHas = not na(nyHighLive) and not na(nyLowLive)

nearSessHigh = swingShowSessionExtremeShSl and (
     (swingSessionUseAsia and asiaHas and math.abs(high[swingCenter] - asiaHigh) <= swingSessBuf) or
     (swingSessionUseLondon and londonHas and math.abs(high[swingCenter] - londonHighLive) <= swingSessBuf) or
     (swingSessionUseNy and nyHas and math.abs(high[swingCenter] - nyHighLive) <= swingSessBuf)
 )
nearSessLow = swingShowSessionExtremeShSl and (
     (swingSessionUseAsia and asiaHas and math.abs(low[swingCenter] - asiaLow) <= swingSessBuf) or
     (swingSessionUseLondon and londonHas and math.abs(low[swingCenter] - londonLowLive) <= swingSessBuf) or
     (swingSessionUseNy and nyHas and math.abs(low[swingCenter] - nyLowLive) <= swingSessBuf)
 )

extremeFilterOn = swingShowDailyExtremeShSl or swingShowSessionExtremeShSl
passExtremeSh = not extremeFilterOn or nearDailyHigh or nearSessHigh
passExtremeSl = not extremeFilterOn or nearDailyLow or nearSessLow

normalShowHigh = swingPatternEnabled and swingHighOk and passExtremeSh and passMacdSh
normalShowLow = swingPatternEnabled and swingLowOk and passExtremeSl and passMacdSl
rsiOverrideHigh = swingRsiFilterEnabled and swingPatternEnabled and swingHighOkBase and passExtremeSh and passRsiSh
rsiOverrideLow = swingRsiFilterEnabled and swingPatternEnabled and swingLowOkBase and passExtremeSl and passRsiSl
swingShowHighFinal = normalShowHigh or rsiOverrideHigh
swingShowLowFinal = normalShowLow or rsiOverrideLow

pivotAfterGreen = open[swingCenter - 1] < close[swingCenter - 1]
pivotAfterRed = open[swingCenter - 1] > close[swingCenter - 1]
pivotHammerOk = hsConfirm ? (hsIsHammer[swingCenter] and pivotAfterGreen) : hsIsHammer[swingCenter]
pivotShootOk = hsConfirm ? (hsIsShoot[swingCenter] and pivotAfterRed) : hsIsShoot[swingCenter]
passHammerSh = not swingRequireHammerShootingForShSl or pivotShootOk
passHammerSl = not swingRequireHammerShootingForShSl or pivotHammerOk
swingShowHighOut = swingShowHighFinal and passHammerSh
swingShowLowOut = swingShowLowFinal and passHammerSl

crtKillOk = not crtUseKillzone or crtInKill
crtRsiOkLong = not crtRequireRsiConfirm or crtRsi <= buyThr
crtRsiOkShort = not crtRequireRsiConfirm or crtRsi >= sellThr
crtTfMin = crtTf == "1" ? 1 : crtTf == "15" ? 15 : crtTf == "60" ? 60 : crtTf == "240" ? 240 : 0
crtMaxAgeMs = crtConfirmShSlMaxBars * crtTfMin * 60 * 1000
crtLastType = f_lastType(crtLastShT, crtLastSlT)
crtShSlOkLong = not crtRequireShSlConfirm or (crtLastType == "SL" and not na(crtLastSlT) and (time_close - crtLastSlT) <= crtMaxAgeMs)
crtShSlOkShort = not crtRequireShSlConfirm or (crtLastType == "SH" and not na(crtLastShT) and (time_close - crtLastShT) <= crtMaxAgeMs)
crtEntryLongOk = crtEntryLongRaw and crtKillOk and crtRsiOkLong and crtShSlOkLong
crtEntryShortOk = crtEntryShortRaw and crtKillOk and crtRsiOkShort and crtShSlOkShort
if crtShowLabels and crtEntryLongOk
    if not na(crtEntryLbl)
        label.delete(crtEntryLbl)
    crtEntryLbl := label.new(bar_index, low, "CRT\nBUY", xloc=xloc.bar_index, style=label.style_label_up, color=color.new(color.aqua, 0), textcolor=color.black, size=size.tiny)
if crtShowLabels and crtEntryShortOk
    if not na(crtEntryLbl)
        label.delete(crtEntryLbl)
    crtEntryLbl := label.new(bar_index, high, "CRT\nSELL", xloc=xloc.bar_index, style=label.style_label_down, color=color.new(color.orange, 0), textcolor=color.black, size=size.tiny)
f_alert(crtEntryLongOk, syminfo.ticker + " CRT BUY")
f_alert(crtEntryShortOk, syminfo.ticker + " CRT SELL")

if (not crtEnabled) or onlyShSlMode or (not crtShowLabels)
    if not na(crtEntryLbl)
        label.delete(crtEntryLbl)
        crtEntryLbl := na

SmtHigh1 = request.security(SmtSymbol1, timeframe.period, high)
SmtLow1 = request.security(SmtSymbol1, timeframe.period, low)
SmtHigh2 = request.security(SmtSymbol2, timeframe.period, high)
SmtLow2 = request.security(SmtSymbol2, timeframe.period, low)
SmtPivot = SmtUseTfPivots ? (timeframe.isminutes and timeframe.multiplier == 1 ? SmtPivotLen_M1 : timeframe.isminutes and timeframe.multiplier == 15 ? SmtPivotLen_M15 : timeframe.isminutes and timeframe.multiplier == 60 ? SmtPivotLen_H1 : timeframe.isminutes and timeframe.multiplier == 240 ? SmtPivotLen_H4 : SmtPivotLen) : SmtPivotLen
mainPh1 = ta.pivothigh(high, SmtPivot, SmtPivot)
mainPl1 = ta.pivotlow(low, SmtPivot, SmtPivot)
inv1 = SmtInverseOn == "Symbol 1"
inv2 = SmtInverseOn == "Symbol 2"
smtPh1_1 = inv1 ? ta.pivotlow(SmtLow1, SmtPivot, SmtPivot) : ta.pivothigh(SmtHigh1, SmtPivot, SmtPivot)
smtPl1_1 = inv1 ? ta.pivothigh(SmtHigh1, SmtPivot, SmtPivot) : ta.pivotlow(SmtLow1, SmtPivot, SmtPivot)
smtPh1_2 = inv2 ? ta.pivotlow(SmtLow2, SmtPivot, SmtPivot) : ta.pivothigh(SmtHigh2, SmtPivot, SmtPivot)
smtPl1_2 = inv2 ? ta.pivothigh(SmtHigh2, SmtPivot, SmtPivot) : ta.pivotlow(SmtLow2, SmtPivot, SmtPivot)
smtDailyBuf = SmtDailyExtremeBufferTicks * syminfo.mintick
dHighAtSmtPivot = dHigh[SmtPivot]
dLowAtSmtPivot = dLow[SmtPivot]
smtNearDailyHigh = SmtShowDailyExtreme and not na(dHighAtSmtPivot) and not na(mainPh1) and math.abs(mainPh1 - dHighAtSmtPivot) <= smtDailyBuf
smtNearDailyLow = SmtShowDailyExtreme and not na(dLowAtSmtPivot) and not na(mainPl1) and math.abs(mainPl1 - dLowAtSmtPivot) <= smtDailyBuf

var float lastMainPh1 = na
var float lastMainPl1 = na
var int lastMainPh1Bar = na
var int lastMainPl1Bar = na
var float lastSmtPh1_1 = na
var float lastSmtPl1_1 = na
var float lastSmtPh1_2 = na
var float lastSmtPl1_2 = na
var int lastSmtBearPivotBar1 = na
var int lastSmtBullPivotBar1 = na
var int lastSmtBearPivotBar2 = na
var int lastSmtBullPivotBar2 = na
var line[] smtDivLines = array.new_line()
f_addSmtLine(_x1, _y1, _x2, _y2, _clr) =>
    if onlyShSlMode
        na
    else
        ln = line.new(_x1, _y1, _x2, _y2, xloc=xloc.bar_index, extend=extend.none, color=_clr, width=2)
        array.push(smtDivLines, ln)
        if array.size(smtDivLines) > 200
            line.delete(array.shift(smtDivLines))
        ln

smtBearSig1 = false
smtBullSig1 = false
smtBearSig2 = false
smtBullSig2 = false
if onlyShSlMode
    while array.size(smtDivLines) > 0
        line.delete(array.shift(smtDivLines))
if SmtEnabled and showUntilNyClose and not onlyShSlMode and not onlyQmMode
    if not na(mainPh1) and not na(smtPh1_1) and not na(lastMainPh1) and not na(lastSmtPh1_1)
        smtBearSig1 := (not SmtShowDailyExtreme or smtNearDailyHigh) and (mainPh1 > lastMainPh1 and smtPh1_1 <= lastSmtPh1_1)
        pivotBar = bar_index - SmtPivot
        if smtBearSig1 and SmtShowLabels and (na(lastSmtBearPivotBar1) or lastSmtBearPivotBar1 != pivotBar)
            label.new(pivotBar, mainPh1, "SMT1", style=label.style_label_down, color=color.new(color.fuchsia, 0), textcolor=color.white, size=size.tiny)
            lastSmtBearPivotBar1 := pivotBar
        if smtBearSig1 and not na(lastMainPh1Bar)
            f_addSmtLine(lastMainPh1Bar, lastMainPh1, pivotBar, mainPh1, color.new(color.fuchsia, 0))
    if not na(mainPl1) and not na(smtPl1_1) and not na(lastMainPl1) and not na(lastSmtPl1_1)
        smtBullSig1 := (not SmtShowDailyExtreme or smtNearDailyLow) and (mainPl1 < lastMainPl1 and smtPl1_1 >= lastSmtPl1_1)
        pivotBar = bar_index - SmtPivot
        if smtBullSig1 and SmtShowLabels and (na(lastSmtBullPivotBar1) or lastSmtBullPivotBar1 != pivotBar)
            label.new(pivotBar, mainPl1, "SMT1", style=label.style_label_up, color=color.new(color.aqua, 0), textcolor=color.black, size=size.tiny)
            lastSmtBullPivotBar1 := pivotBar
        if smtBullSig1 and not na(lastMainPl1Bar)
            f_addSmtLine(lastMainPl1Bar, lastMainPl1, pivotBar, mainPl1, color.new(color.aqua, 0))

    if SmtUseSymbol2
        if not na(mainPh1) and not na(smtPh1_2) and not na(lastMainPh1) and not na(lastSmtPh1_2)
            smtBearSig2 := (not SmtShowDailyExtreme or smtNearDailyHigh) and (mainPh1 > lastMainPh1 and smtPh1_2 <= lastSmtPh1_2)
            pivotBar = bar_index - SmtPivot
            if smtBearSig2 and SmtShowLabels and (na(lastSmtBearPivotBar2) or lastSmtBearPivotBar2 != pivotBar)
                label.new(pivotBar, mainPh1, "SMT2", style=label.style_label_down, color=color.new(color.fuchsia, 0), textcolor=color.white, size=size.tiny)
                lastSmtBearPivotBar2 := pivotBar
            if smtBearSig2 and not na(lastMainPh1Bar)
                f_addSmtLine(lastMainPh1Bar, lastMainPh1, pivotBar, mainPh1, color.new(color.fuchsia, 0))
        if not na(mainPl1) and not na(smtPl1_2) and not na(lastMainPl1) and not na(lastSmtPl1_2)
            smtBullSig2 := (not SmtShowDailyExtreme or smtNearDailyLow) and (mainPl1 < lastMainPl1 and smtPl1_2 >= lastSmtPl1_2)
            pivotBar = bar_index - SmtPivot
            if smtBullSig2 and SmtShowLabels and (na(lastSmtBullPivotBar2) or lastSmtBullPivotBar2 != pivotBar)
                label.new(pivotBar, mainPl1, "SMT2", style=label.style_label_up, color=color.new(color.aqua, 0), textcolor=color.black, size=size.tiny)
                lastSmtBullPivotBar2 := pivotBar
            if smtBullSig2 and not na(lastMainPl1Bar)
                f_addSmtLine(lastMainPl1Bar, lastMainPl1, pivotBar, mainPl1, color.new(color.aqua, 0))
    if not na(mainPh1)
        lastMainPh1 := mainPh1
        lastMainPh1Bar := bar_index - SmtPivot
    if not na(mainPl1)
        lastMainPl1 := mainPl1
        lastMainPl1Bar := bar_index - SmtPivot
    if not na(smtPh1_1)
        lastSmtPh1_1 := smtPh1_1
    if not na(smtPl1_1)
        lastSmtPl1_1 := smtPl1_1
    if SmtUseSymbol2
        if not na(smtPh1_2)
            lastSmtPh1_2 := smtPh1_2
        if not na(smtPl1_2)
            lastSmtPl1_2 := smtPl1_2

rsiCrossPivotBar = bar_index - swingCenter
rsiCrossUpSig = rsiCrossUpAtPivot and rsiCrossUpOkAtPivot and swingShowLowOut
rsiCrossDnSig = rsiCrossDnAtPivot and rsiCrossDnOkAtPivot and swingShowHighOut
if rsiCrossShowLabels and rsiCrossUpSig
    f_addSigLabel(rsiCrossPivotBar, low[swingCenter], "RSI↑", color.new(color.aqua, 0), color.black, label.style_label_up, size.tiny)
if rsiCrossShowLabels and rsiCrossDnSig
    f_addSigLabel(rsiCrossPivotBar, high[swingCenter], "RSI↓", color.new(color.orange, 0), color.black, label.style_label_down, size.tiny)

swingBullDivPlot = not onlyShSlMode and not onlyQmMode and swingBullDiv and (not swingDivShowDailyExtreme or divNearDailyLow)
swingBearDivPlot = not onlyShSlMode and not onlyQmMode and swingBearDiv and (not swingDivShowDailyExtreme or divNearDailyHigh)
swingPivotBar = bar_index - swingCenter
swingStep = labelStackTicks * syminfo.mintick
var int lastShLblBar = na
var int lastSlLblBar = na
var int lastDivBullLblBar = na
var int lastDivBearLblBar = na

if (not onlyQmMode or onlyQmShowShSl) and swingShowHighOut and (na(lastShLblBar) or lastShLblBar != swingPivotBar)
    y = high[swingCenter] + (labelAutoStack ? 3 * swingStep : 0)
    lb = label.new(swingPivotBar, y, "SH", xloc=xloc.bar_index, style=label.style_label_down, color=color.new(color.red, 0), textcolor=color.white, size=size.small)
    array.push(mcSigLabels, lb)
    if array.size(mcSigLabels) > 250
        label.delete(array.shift(mcSigLabels))
    lastShLblBar := swingPivotBar

if (not onlyQmMode or onlyQmShowShSl) and swingShowLowOut and (na(lastSlLblBar) or lastSlLblBar != swingPivotBar)
    y = low[swingCenter] - (labelAutoStack ? 3 * swingStep : 0)
    lb = label.new(swingPivotBar, y, "SL", xloc=xloc.bar_index, style=label.style_label_up, color=color.new(color.lime, 0), textcolor=color.black, size=size.small)
    array.push(mcSigLabels, lb)
    if array.size(mcSigLabels) > 250
        label.delete(array.shift(mcSigLabels))
    lastSlLblBar := swingPivotBar

if swingBullDivPlot and (na(lastDivBullLblBar) or lastDivBullLblBar != swingPivotBar)
    y = low[swingCenter] - (labelAutoStack ? 4 * swingStep : 0)
    lb = label.new(swingPivotBar, y, "DIV", xloc=xloc.bar_index, style=label.style_label_up, color=color.new(color.aqua, 0), textcolor=color.black, size=size.tiny)
    array.push(mcSigLabels, lb)
    if array.size(mcSigLabels) > 250
        label.delete(array.shift(mcSigLabels))
    lastDivBullLblBar := swingPivotBar

if swingBearDivPlot and (na(lastDivBearLblBar) or lastDivBearLblBar != swingPivotBar)
    y = high[swingCenter] + (labelAutoStack ? 4 * swingStep : 0)
    lb = label.new(swingPivotBar, y, "DIV", xloc=xloc.bar_index, style=label.style_label_down, color=color.new(color.fuchsia, 0), textcolor=color.white, size=size.tiny)
    array.push(mcSigLabels, lb)
    if array.size(mcSigLabels) > 250
        label.delete(array.shift(mcSigLabels))
    lastDivBearLblBar := swingPivotBar

leftH1 = swingPatternUseTfBars ? swingPatternLeftBars_H1 : swingPatternLeftBars
rightH1 = swingPatternUseTfBars ? swingPatternRightBars_H1 : swingPatternRightBars
leftH4 = swingPatternUseTfBars ? swingPatternLeftBars_H4 : swingPatternLeftBars
rightH4 = swingPatternUseTfBars ? swingPatternRightBars_H4 : swingPatternRightBars

[dashH1ShT, dashH1ShP, dashH1SlT, dashH1SlP] = request.security(syminfo.tickerid, "60", f_pivotStats(leftH1, rightH1), barmerge.gaps_off, barmerge.lookahead_off)
[dashH4ShT, dashH4ShP, dashH4SlT, dashH4SlP] = request.security(syminfo.tickerid, "240", f_pivotStats(leftH4, rightH4), barmerge.gaps_off, barmerge.lookahead_off)

var table dashTbl = na
var string dashPosPrev = na
if barstate.isfirst or dashPosPrev != dashPos
    if not na(dashTbl)
        table.delete(dashTbl)
    dashTbl := table.new(f_dashPos(dashPos), 4, 3, border_width=1)
    dashPosPrev := dashPos

if barstate.islast and not na(dashTbl)
    sz = f_dashSize(dashTextSize)
    if dashEnabled and not onlyShSlMode and not onlyQmMode
        hdrBg = color.new(color.black, 0)
        hdrTx = color.white
        table.cell(dashTbl, 0, 0, "TF", bgcolor=hdrBg, text_color=hdrTx, text_size=sz)
        table.cell(dashTbl, 1, 0, "LAST", bgcolor=hdrBg, text_color=hdrTx, text_size=sz)
        table.cell(dashTbl, 2, 0, "SH", bgcolor=hdrBg, text_color=hdrTx, text_size=sz)
        table.cell(dashTbl, 3, 0, "SL", bgcolor=hdrBg, text_color=hdrTx, text_size=sz)

        h1Last = f_lastType(dashH1ShT, dashH1SlT)
        h4Last = f_lastType(dashH4ShT, dashH4SlT)
        bg1 = color.new(color.black, 80)
        table.cell(dashTbl, 0, 1, "H1", bgcolor=bg1, text_color=color.white, text_size=sz)
        table.cell(dashTbl, 1, 1, h1Last, bgcolor=bg1, text_color=h1Last == "SH" ? color.red : h1Last == "SL" ? color.lime : color.white, text_size=sz)
        table.cell(dashTbl, 2, 1, f_cellTxt(dashH1ShT, dashH1ShP), bgcolor=bg1, text_color=color.white, text_size=sz)
        table.cell(dashTbl, 3, 1, f_cellTxt(dashH1SlT, dashH1SlP), bgcolor=bg1, text_color=color.white, text_size=sz)

        table.cell(dashTbl, 0, 2, "H4", bgcolor=bg1, text_color=color.white, text_size=sz)
        table.cell(dashTbl, 1, 2, h4Last, bgcolor=bg1, text_color=h4Last == "SH" ? color.red : h4Last == "SL" ? color.lime : color.white, text_size=sz)
        table.cell(dashTbl, 2, 2, f_cellTxt(dashH4ShT, dashH4ShP), bgcolor=bg1, text_color=color.white, text_size=sz)
        table.cell(dashTbl, 3, 2, f_cellTxt(dashH4SlT, dashH4SlP), bgcolor=bg1, text_color=color.white, text_size=sz)
    else
        table.cell(dashTbl, 0, 0, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 1, 0, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 2, 0, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 3, 0, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 0, 1, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 1, 1, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 2, 1, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 3, 1, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 0, 2, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 1, 2, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 2, 2, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)
        table.cell(dashTbl, 3, 2, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sz)

f_bbLast(_len) =>
    h = ta.highest(_len)
    l = ta.lowest(_len)
    sh = high[1] == h[1] and high < h
    sl = low[1] == l[1] and low > l
    shT = ta.valuewhen(sh, time[1], 0)
    slT = ta.valuewhen(sl, time[1], 0)
    shP = ta.valuewhen(sh, high[1], 0)
    slP = ta.valuewhen(sl, low[1], 0)
    tp = na(shT) and na(slT) ? 0 : na(slT) ? 1 : na(shT) ? -1 : (shT > slT ? 1 : -1)
    pr = tp == 1 ? shP : tp == -1 ? slP : na
    tm = tp == 1 ? shT : tp == -1 ? slT : na
    [tp, pr, tm]

bbSz = f_dashSize(bbDashTextSize)
bbTblPos = bbDashLoc == "Bottom Left" ? position.bottom_left : bbDashLoc == "Top Right" ? position.top_right : position.bottom_right
var table bbDashTbl = na
var string bbDashPrev = na
if barstate.isfirst or bbDashPrev != bbDashLoc
    if not na(bbDashTbl)
        table.delete(bbDashTbl)
    bbDashTbl := table.new(bbTblPos, 2, 5, bgcolor=#1e222d, border_color=#373a46, border_width=1, frame_color=#373a46, frame_width=1)
    bbDashPrev := bbDashLoc

bbLenM1Sel = bbPreset != "Custom" ? bbPresetM1 : bbUseTfLen ? bbLen_M1 : bbLen
bbLenM15Sel = bbPreset != "Custom" ? bbPresetM15 : bbUseTfLen ? bbLen_M15 : bbLen
bbLenH1Sel = bbPreset != "Custom" ? bbPresetH1 : bbUseTfLen ? bbLen_H1 : bbLen
bbLenH4Sel = bbPreset != "Custom" ? bbPresetH4 : bbUseTfLen ? bbLen_H4 : bbLen

[bbM1Tp, bbM1Pr, bbM1Tm] = request.security(syminfo.tickerid, "1", f_bbLast(bbLenM1Sel), barmerge.gaps_off, barmerge.lookahead_on)
[bbM15Tp, bbM15Pr, bbM15Tm] = request.security(syminfo.tickerid, "15", f_bbLast(bbLenM15Sel), barmerge.gaps_off, barmerge.lookahead_on)
[bbH1Tp, bbH1Pr, bbH1Tm] = request.security(syminfo.tickerid, "60", f_bbLast(bbLenH1Sel), barmerge.gaps_off, barmerge.lookahead_on)
[bbH4Tp, bbH4Pr, bbH4Tm] = request.security(syminfo.tickerid, "240", f_bbLast(bbLenH4Sel), barmerge.gaps_off, barmerge.lookahead_on)

f_bbTxt(_tp, _pr, _tm) =>
    _tp == 0 or na(_tm) ? "" : str.format("{0} {1} @{2}", str.format_time(_tm, "HH:mm", "Europe/Rome"), _tp == 1 ? "SH" : "SL", str.tostring(_pr, format.mintick))

if barstate.islast and not na(bbDashTbl)
    if bbDashEnabled and not onlyShSlMode
        hdrBg = color.new(color.black, 0)
        hdrTx = color.white
        bg = color.new(color.black, 80)
        table.cell(bbDashTbl, 0, 0, "TF", bgcolor=hdrBg, text_color=hdrTx, text_size=bbSz)
        table.cell(bbDashTbl, 1, 0, "LAST", bgcolor=hdrBg, text_color=hdrTx, text_size=bbSz)

        table.cell(bbDashTbl, 0, 1, "M1", bgcolor=bg, text_color=color.white, text_size=bbSz)
        table.cell(bbDashTbl, 1, 1, f_bbTxt(bbM1Tp, bbM1Pr, bbM1Tm), bgcolor=bg, text_color=bbM1Tp == 1 ? color.red : bbM1Tp == -1 ? color.lime : color.white, text_size=bbSz)

        table.cell(bbDashTbl, 0, 2, "M15", bgcolor=bg, text_color=color.white, text_size=bbSz)
        table.cell(bbDashTbl, 1, 2, f_bbTxt(bbM15Tp, bbM15Pr, bbM15Tm), bgcolor=bg, text_color=bbM15Tp == 1 ? color.red : bbM15Tp == -1 ? color.lime : color.white, text_size=bbSz)

        table.cell(bbDashTbl, 0, 3, "H1", bgcolor=bg, text_color=color.white, text_size=bbSz)
        table.cell(bbDashTbl, 1, 3, f_bbTxt(bbH1Tp, bbH1Pr, bbH1Tm), bgcolor=bg, text_color=bbH1Tp == 1 ? color.red : bbH1Tp == -1 ? color.lime : color.white, text_size=bbSz)

        table.cell(bbDashTbl, 0, 4, "H4", bgcolor=bg, text_color=color.white, text_size=bbSz)
        table.cell(bbDashTbl, 1, 4, f_bbTxt(bbH4Tp, bbH4Pr, bbH4Tm), bgcolor=bg, text_color=bbH4Tp == 1 ? color.red : bbH4Tp == -1 ? color.lime : color.white, text_size=bbSz)

f_alert(not onlyQmMode and swingPatternOnlyAlerts and swingShowHighOut, syminfo.ticker + " Swing High")
f_alert(not onlyQmMode and swingPatternOnlyAlerts and swingShowLowOut, syminfo.ticker + " Swing Low")
f_alert(not onlyQmMode and swingPatternOnlyAlerts and swingBullDivPlot, syminfo.ticker + " Bullish Divergence (RSI)")
f_alert(not onlyQmMode and swingPatternOnlyAlerts and swingBearDivPlot, syminfo.ticker + " Bearish Divergence (RSI)")
f_alert(not onlyShSlMode and not onlyQmMode and rsiCrossUpSig, syminfo.ticker + " RSI cross UP vs RSI-MA")
f_alert(not onlyShSlMode and not onlyQmMode and rsiCrossDnSig, syminfo.ticker + " RSI cross DOWN vs RSI-MA")
f_alert(not onlyShSlMode and not onlyQmMode and rsiPatternEnabled and rsiWSig, syminfo.ticker + " RSI W pattern")
f_alert(not onlyShSlMode and not onlyQmMode and rsiPatternEnabled and rsiMSig, syminfo.ticker + " RSI M pattern")
smtBearAny = smtBearSig1 or smtBearSig2
smtBullAny = smtBullSig1 or smtBullSig2

f_alert(not onlyShSlMode and not onlyQmMode and SmtEnabled and smtBearSig1, syminfo.ticker + " SMT1 Bearish vs SMT Symbol 1")
f_alert(not onlyShSlMode and not onlyQmMode and SmtEnabled and smtBullSig1, syminfo.ticker + " SMT1 Bullish vs SMT Symbol 1")
f_alert(not onlyShSlMode and not onlyQmMode and SmtEnabled and SmtUseSymbol2 and smtBearSig2, syminfo.ticker + " SMT2 Bearish vs SMT Symbol 2")
f_alert(not onlyShSlMode and not onlyQmMode and SmtEnabled and SmtUseSymbol2 and smtBullSig2, syminfo.ticker + " SMT2 Bullish vs SMT Symbol 2")
f_alert(not onlyShSlMode and not onlyQmMode and SmtEnabled and smtBearAny, syminfo.ticker + " SMT Bearish")
f_alert(not onlyShSlMode and not onlyQmMode and SmtEnabled and smtBullAny, syminfo.ticker + " SMT Bullish")

type sfp_piv
    float swing_prc
    int swing_bix
    float oppos_prc
    int oppos_bix
    bool active
    bool confirmed
    line swing_line
    line oppos_line
    line wicky_line
    label wicky_label

type sfp_swing
    int bix
    float prc

method n(float piv) => bool out = not na(piv)

sfpINV = color(na)
sfpValidate = sfpIVal != "None"
sfpValHigher = sfpIVal == "Volume outside swing > Threshold"
sfpValLower = sfpIVal == "Volume outside swing < Threshold"

sfpTablePosition = sfpDashLoc == "Bottom Left" ? position.bottom_left : sfpDashLoc == "Top Right" ? position.top_right : position.bottom_right
sfpTableSize = sfpTextSize == "Tiny" ? size.tiny : sfpTextSize == "Small" ? size.small : size.normal

var table sfpTb = na
var string sfpDashLocPrev = na
if (barstate.isfirst or sfpDashLocPrev != sfpDashLoc)
    if not na(sfpTb)
        table.delete(sfpTb)
    sfpTb := table.new(sfpTablePosition, 2, 3, bgcolor=#1e222d, border_color=#373a46, border_width=1, frame_color=#373a46, frame_width=1)
    sfpDashLocPrev := sfpDashLoc

var sfp_swing sfpSwingH = sfp_swing.new()
var sfp_swing sfpSwingL = sfp_swing.new()
var sfp_piv sfpPivH = sfp_piv.new()
var sfp_piv sfpPivL = sfp_piv.new()

sfpTfS = timeframe.in_seconds(sfpRes)
sfpTfC = timeframe.in_seconds(timeframe.period)
sfpRs = sfpAuto ? sfpTfC / sfpMlt : sfpTfS
if not sfpValidate
    sfpRes := timeframe.period
else
    sfpRs := sfpPrem ? sfpRs : math.max(60, sfpRs)
    sfpRes := timeframe.from_seconds(math.min(sfpTfC, sfpRs))

sfpPh = ta.pivothigh(sfpLen, 1)
sfpPl = ta.pivotlow(sfpLen, 1)

[sfpLtfClose, sfpLtfVolume] = request.security_lower_tf(syminfo.tickerid, sfpRes, [close, volume])
sfpLtfSize = sfpLtfClose.size()

if sfpEnabled and not onlyQmMode
    sfpDailyBuf = sfpDailyExtremeBufferTicks * syminfo.mintick
    sfpMinWick = sfpMinWickTicks * syminfo.mintick
    sfpKillOk = not sfpUseKillzone or isKill

    if sfpValidate
        if sfpLtfSize > 0 and sfpLtfSize[1] == 0
            line.new(bar_index, close, bar_index, close + syminfo.mintick, color=color.silver, style=line.style_dotted, extend=extend.both)

    if sfpBear
        if sfpPh.n()
            sfpSwingH.bix := bar_index - 1
            sfpSwingH.prc := sfpPh

        sw = sfpSwingH.prc
        bx = sfpSwingH.bix
        sfpDailyOkBear = not sfpUseDailyExtreme or (not na(dHigh) and math.abs(high - dHigh) <= sfpDailyBuf)
        sfpWickOkBear = sfpMinWickTicks == 0 or (high - sw) >= sfpMinWick
        if high > sw and open < sw and close < sw and sfpKillOk and sfpDailyOkBear and sfpWickOkBear
            valid = true
            if sfpValidate
                if sfpLtfClose.size() > 0
                    outsideVolume = 0.0
                    totalVolume = sfpLtfVolume.sum()
                    for j = 0 to sfpLtfClose.size() - 1
                        if sfpLtfClose.get(j) > sw
                            outsideVolume += sfpLtfVolume.get(j)
                    if (sfpValHigher ? 100 / totalVolume * outsideVolume < sfpPercent : 100 / totalVolume * outsideVolume > sfpPercent)
                        valid := false

            if valid
                opposL = sw
                opposB = bar_index
                for i = 1 to bar_index - bx - 1
                    if low[i] < opposL
                        opposL := low[i]
                        opposB := bar_index - i

                if not sfpPivH.confirmed
                    sfpPivH.swing_line.delete()
                    sfpPivH.oppos_line.delete()
                    sfpPivH.wicky_line.delete()
                    sfpPivH.wicky_label.delete()

                sfpPivH := sfp_piv.new(sw, bx, opposL, opposB, true, false)

                if sfpSwingLine
                    sfpPivH.swing_line := line.new(bx, sw, bar_index, sw, color=sfpColBr)
                if sfpOpposLine
                    sfpPivH.oppos_line := line.new(opposB, opposL, bar_index, opposL, color=sfpColBr, style=line.style_dotted)
                if sfpShowUnconfirmed and sfpSfpLine
                    sfpPivH.wicky_line := line.new(bar_index, high, bar_index, sw, color=sfpColBr2, width=3)
                if sfpShowUnconfirmed and sfpSfpLabel
                    sfpPivH.wicky_label := label.new(bar_index, high, style=label.style_label_down, text="SFP", textcolor=sfpColBr, color=sfpINV, size=size.normal)

        if sfpPivH.active and not sfpPivH.confirmed
            sfpPivH.swing_line.set_x2(bar_index)
            sfpPivH.oppos_line.set_x2(bar_index)
            if close < sfpPivH.oppos_prc
                sfpPivH.confirmed := true
                if sfpSfpLabel
                    if sfpShowUnconfirmed and sfpPivH.wicky_label.get_x() == bar_index
                        sfpPivH.wicky_label.set_text("SFP\n▼")
                    else
                        label.new(bar_index, high, style=label.style_label_down, text="SFP\n▼", textcolor=sfpColBr, color=sfpINV, size=size.normal)

        if (bar_index - sfpPivH.swing_bix > 500) or close > sfpPivH.swing_prc
            sfpPivH.active := false
            if not sfpPivH.confirmed
                sfpPivH.swing_line.delete()
                sfpPivH.oppos_line.delete()
                sfpPivH.wicky_line.delete()
                sfpPivH.wicky_label.delete()

    if sfpBull
        if sfpPl.n()
            sfpSwingL.bix := bar_index - 1
            sfpSwingL.prc := sfpPl

        sw = sfpSwingL.prc
        bx = sfpSwingL.bix
        sfpDailyOkBull = not sfpUseDailyExtreme or (not na(dLow) and math.abs(low - dLow) <= sfpDailyBuf)
        sfpWickOkBull = sfpMinWickTicks == 0 or (sw - low) >= sfpMinWick
        if low < sw and open > sw and close > sw and sfpKillOk and sfpDailyOkBull and sfpWickOkBull
            valid = true
            if sfpValidate
                if sfpLtfClose.size() > 0
                    outsideVolume = 0.0
                    totalVolume = sfpLtfVolume.sum()
                    for j = 0 to sfpLtfClose.size() - 1
                        if sfpLtfClose.get(j) < sw
                            outsideVolume += sfpLtfVolume.get(j)
                    if (sfpValHigher ? 100 / totalVolume * outsideVolume < sfpPercent : 100 / totalVolume * outsideVolume > sfpPercent)
                        valid := false

            if valid
                opposH = sw
                opposB = bar_index
                for i = 1 to bar_index - bx - 1
                    if high[i] > opposH
                        opposH := high[i]
                        opposB := bar_index - i

                if not sfpPivL.confirmed
                    sfpPivL.swing_line.delete()
                    sfpPivL.oppos_line.delete()
                    sfpPivL.wicky_line.delete()
                    sfpPivL.wicky_label.delete()

                sfpPivL := sfp_piv.new(sw, bx, opposH, opposB, true, false)

                if sfpSwingLine
                    sfpPivL.swing_line := line.new(bx, sw, bar_index, sw, color=sfpColBl)
                if sfpOpposLine
                    sfpPivL.oppos_line := line.new(opposB, opposH, bar_index, opposH, color=sfpColBl, style=line.style_dotted)
                if sfpShowUnconfirmed and sfpSfpLine
                    sfpPivL.wicky_line := line.new(bar_index, low, bar_index, sw, color=sfpColBl2, width=3)
                if sfpShowUnconfirmed and sfpSfpLabel
                    sfpPivL.wicky_label := label.new(bar_index, low, style=label.style_label_up, text="SFP", textcolor=sfpColBl, color=sfpINV, size=size.normal)

        if sfpPivL.active and not sfpPivL.confirmed
            sfpPivL.swing_line.set_x2(bar_index)
            sfpPivL.oppos_line.set_x2(bar_index)
            if close > sfpPivL.oppos_prc
                sfpPivL.confirmed := true
                if sfpSfpLabel
                    if sfpShowUnconfirmed and sfpPivL.wicky_label.get_x() == bar_index
                        sfpPivL.wicky_label.set_text("▲\nSFP")
                    else
                        label.new(bar_index, low, style=label.style_label_up, text="▲\nSFP", textcolor=sfpColBl, color=sfpINV, size=size.normal)

        if (bar_index - sfpPivL.swing_bix > 500) or close < sfpPivL.swing_prc
            sfpPivL.active := false
            if not sfpPivL.confirmed
                sfpPivL.swing_line.delete()
                sfpPivL.oppos_line.delete()
                sfpPivL.wicky_line.delete()
                sfpPivL.wicky_label.delete()

if barstate.islast and sfpEnabled and sfpValidate and sfpShowDash and not na(sfpTb)
    table.cell(sfpTb, 0, 0, str.format("LTF: {0}", sfpRes), text_color=color.white, text_size=sfpTableSize)
else if barstate.islast and not na(sfpTb) and (not sfpEnabled or not sfpShowDash)
    table.cell(sfpTb, 0, 0, "", bgcolor=color.new(color.black, 100), text_color=color.new(color.white, 100), text_size=sfpTableSize)

stAiActive = not onlyShSlMode and not onlyBelugaMode and ((stAiEnabled and not onlyQmMode) or (qmLiveEnabled and qmLiveShowSupertrend))
if stAiEnabled and stAiMinMult > stAiMaxMult
    runtime.error("Minimum factor is greater than maximum factor in the range")

type stAi_supertrend
    float upper = hl2
    float lower = hl2
    float output
    float perf = 0.0
    float factor
    int trend = 0

type stAi_vector
    array<float> out

var stAiHolder = array.new<stAi_supertrend>(0)
var stAiFactors = array.new<float>(0)

if barstate.isfirst and stAiActive
    for i = 0 to int((stAiMaxMult - stAiMinMult) / stAiStep)
        array.push(stAiFactors, stAiMinMult + i * stAiStep)
        array.push(stAiHolder, stAi_supertrend.new())

stAiAtr = stAiActive ? ta.atr(stAiAtrLen) : na

if stAiActive and array.size(stAiFactors) > 0
    stAiK = 0
    for factor in stAiFactors
        stAiGet = array.get(stAiHolder, stAiK)
        stAiUp = hl2 + stAiAtr * factor
        stAiDn = hl2 - stAiAtr * factor
        stAiGet.trend := close > stAiGet.upper ? 1 : close < stAiGet.lower ? 0 : stAiGet.trend
        stAiGet.upper := close[1] < stAiGet.upper ? math.min(stAiUp, stAiGet.upper) : stAiUp
        stAiGet.lower := close[1] > stAiGet.lower ? math.max(stAiDn, stAiGet.lower) : stAiDn
        stAiDiff = nz(math.sign(close[1] - stAiGet.output))
        stAiGet.perf += 2.0 / (stAiPerfAlpha + 1.0) * (nz(close - close[1]) * stAiDiff - stAiGet.perf)
        stAiGet.output := stAiGet.trend == 1 ? stAiGet.lower : stAiGet.upper
        stAiGet.factor := factor
        stAiK += 1

stAiMaxIter = math.max(0, stAiMaxIterIn)
stAiMaxData = math.max(0, stAiMaxDataIn)
stAiCalc = stAiActive and (last_bar_index - bar_index <= stAiMaxData)

stAiFactorArray = array.new<float>(0)
stAiData = array.new<float>(0)
if stAiCalc
    for element in stAiHolder
        array.push(stAiData, element.perf)
        array.push(stAiFactorArray, element.factor)

stAiCentroids = array.new<float>(0)
if stAiCalc and array.size(stAiData) > 0
    array.push(stAiCentroids, stAiData.percentile_linear_interpolation(25))
    array.push(stAiCentroids, stAiData.percentile_linear_interpolation(50))
    array.push(stAiCentroids, stAiData.percentile_linear_interpolation(75))

var array<stAi_vector> stAiFactorsClusters = na
var array<stAi_vector> stAiPerfClusters = na

if stAiCalc and array.size(stAiCentroids) == 3
    for _ = 0 to stAiMaxIter
        stAiFactorsClusters := array.from(stAi_vector.new(array.new<float>(0)), stAi_vector.new(array.new<float>(0)), stAi_vector.new(array.new<float>(0)))
        stAiPerfClusters := array.from(stAi_vector.new(array.new<float>(0)), stAi_vector.new(array.new<float>(0)), stAi_vector.new(array.new<float>(0)))
        stAiI = 0
        for value in stAiData
            stAiDist = array.new<float>(0)
            for centroid in stAiCentroids
                array.push(stAiDist, math.abs(value - centroid))
            stAiIdx = stAiDist.indexof(stAiDist.min())
            array.push(stAiPerfClusters.get(stAiIdx).out, value)
            array.push(stAiFactorsClusters.get(stAiIdx).out, array.get(stAiFactorArray, stAiI))
            stAiI += 1
        stAiNewCentroids = array.new<float>(0)
        for cluster_ in stAiPerfClusters
            array.push(stAiNewCentroids, cluster_.out.avg())
        if stAiNewCentroids.get(0) == stAiCentroids.get(0) and stAiNewCentroids.get(1) == stAiCentroids.get(1) and stAiNewCentroids.get(2) == stAiCentroids.get(2)
            break
        stAiCentroids := stAiNewCentroids

stAiFrom = stAiFromCluster == "Best" ? 2 : stAiFromCluster == "Average" ? 1 : 0
stAiDen = stAiActive ? ta.ema(math.abs(close - close[1]), int(stAiPerfAlpha)) : na

var float stAiTargetFactor = na
var float stAiPerfIdx = na
var float stAiPerfAma = na

if stAiActive and not na(stAiPerfClusters)
    stAiTargetFactor := nz(stAiFactorsClusters.get(stAiFrom).out.avg(), stAiTargetFactor)
    stAiPerfIdx := math.max(nz(stAiPerfClusters.get(stAiFrom).out.avg()), 0) / stAiDen

var float stAiUpper = hl2
var float stAiLower = hl2
var int stAiOs = 0

stAiUp2 = stAiActive ? (hl2 + stAiAtr * stAiTargetFactor) : na
stAiDn2 = stAiActive ? (hl2 - stAiAtr * stAiTargetFactor) : na
if stAiActive and not na(stAiUp2) and not na(stAiDn2)
    stAiUpper := close[1] < stAiUpper ? math.min(stAiUp2, stAiUpper) : stAiUp2
    stAiLower := close[1] > stAiLower ? math.max(stAiDn2, stAiLower) : stAiDn2
    stAiOs := close > stAiUpper ? 1 : close < stAiLower ? 0 : stAiOs

stAiTs = stAiOs == 1 ? stAiLower : stAiUpper
if stAiActive and na(stAiTs[1]) and not na(stAiTs)
    stAiPerfAma := stAiTs
else if stAiActive and not na(stAiPerfIdx)
    stAiPerfAma += stAiPerfIdx * (stAiTs - stAiPerfAma)

stAiCss = stAiOs == 1 ? stAiBullCss : stAiBearCss
stAiPlot = stAiActive

plot(stAiPlot ? stAiTs : na, "SuperTrend AI - Trailing Stop", stAiOs != stAiOs[1] ? na : stAiCss)
plot(stAiPlot ? stAiPerfAma : na, "SuperTrend AI - Trailing Stop AMA", ta.cross(close, stAiPerfAma) ? na : close > stAiPerfAma ? stAiAmaBullCss : stAiAmaBearCss)
barcolor(stAiPlot and stAiEnabled and stAiShowGradient ? color.from_gradient(stAiPerfIdx, 0, 1, color.new(stAiCss, 80), stAiCss) : na)

stAiShowNums = stAiPlot and stAiShowSignals and (stAiEnabled or (qmLiveEnabled and qmLiveShowSupertrend)) and not na(stAiPerfIdx)
if stAiShowNums
    if stAiOs > stAiOs[1]
        label.new(bar_index, stAiTs, str.tostring(int(stAiPerfIdx * 10)), color=stAiBullCss, style=label.style_label_up, textcolor=color.white, size=size.tiny)
    if stAiOs < stAiOs[1]
        label.new(bar_index, stAiTs, str.tostring(int(stAiPerfIdx * 10)), color=stAiBearCss, style=label.style_label_down, textcolor=color.white, size=size.tiny)

bbActive = not onlyShSlMode and (onlyBelugaMode or (qmLiveEnabled and qmLiveShowBelugaSwing))

bbLenSel = bbPreset != "Custom" ? (tfIsM1 ? bbPresetM1 : tfIsM15 ? bbPresetM15 : tfIsH1 ? bbPresetH1 : tfIsH4 ? bbPresetH4 : bbLen) : bbUseTfLen ? (tfIsM1 ? bbLen_M1 : tfIsM15 ? bbLen_M15 : tfIsH1 ? bbLen_H1 : tfIsH4 ? bbLen_H4 : bbLen) : bbLen
bbH = ta.highest(bbLenSel)
bbL = ta.lowest(bbLenSel)

var bool bbTrend = na
var int bbHighIndex = na
var float bbHighVal = na
var int bbLowIndex = na
var float bbLowVal = na

bbSwingHigh = bbActive and high[1] == bbH[1] and high < bbH
bbSwingLow = bbActive and low[1] == bbL[1] and low > bbL
bgcolor(bbSwingHigh ? color.new(bbHvwapCol, 85) : bbSwingLow ? color.new(bbLvwapCol, 85) : na)

if bbSwingHigh
    bbHighIndex := bar_index - 1
    bbHighVal := high[1]

bbHVwap = ta.vwap(high, bbSwingHigh)

if bbSwingLow
    bbLowIndex := bar_index - 1
    bbLowVal := low[1]

bbLVwap = ta.vwap(low, bbSwingLow)

if bbActive and high == bbH
    bbTrend := true
if bbActive and low == bbL
    bbTrend := false

bbDrawActiveVwap(_trend) =>
    src = _trend ? high : low
    idx = _trend ? bbLowIndex : bbHighIndex
    vwapColor = _trend ? bbLvwapCol : bbHvwapCol
    stl = _trend ? label.style_label_up : label.style_label_down

    var polyline poly = na
    var label lbl = na
    var label lbl1 = na
    var line line_ = na

    polyline.delete(poly)
    label.delete(lbl)
    label.delete(lbl1)
    line.delete(line_)

    cp = array.new<chart.point>()

    if not na(idx)
        for i = 0 to bar_index - idx
            vwap_ = _trend ? bbLVwap[i] : bbHVwap[i]
            if i == 0
                line_ := line.new(bar_index, vwap_, bar_index + 5, vwap_, color=vwapColor, width=2, style=line.style_arrow_right)
                lbl1 := label.new(bar_index + 5, vwap_, str.tostring(vwap_, "###,###,###.##"), color=#00000000, style=label.style_label_left, textcolor=chart.fg_color)
            if i == bar_index - idx
                lbl := label.new(bar_index - i, src[i], color=vwapColor, style=stl)
            cp_ = chart.point.from_index(bar_index - i, vwap_)
            array.push(cp, cp_)
        poly := polyline.new(cp, line_color=vwapColor, line_width=2)

if bbActive
    bbDrawActiveVwap(bbTrend)

if bbActive and bbTrend and bbTrend != bbTrend[1] and not na(bbHighIndex)
    cp = array.new<chart.point>()
    for i = 0 to bar_index - bbHighIndex
        if i == bar_index - bbHighIndex
            label.new(bar_index - i, high[i], color=color.new(bbHvwapCol, 40), style=label.style_label_down)
        cp_ = chart.point.from_index(bar_index - i, bbHVwap[i])
        array.push(cp, cp_)
    polyline.new(cp, line_color=color.new(bbHvwapCol, 30), line_width=bbWidth)

if bbActive and not bbTrend and bbTrend != bbTrend[1] and not na(bbLowIndex)
    cp = array.new<chart.point>()
    for i = 0 to bar_index - bbLowIndex
        if i == bar_index - bbLowIndex
            label.new(bar_index - i, low[i], color=color.new(bbLvwapCol, 40), style=label.style_label_up)
        cp_ = chart.point.from_index(bar_index - i, bbLVwap[i])
        array.push(cp, cp_)
    polyline.new(cp, line_color=color.new(bbLvwapCol, 40), line_width=bbWidth)

qmPPsel = qmUseTfPivots ? (tfIsM1 ? qmPp_M1 : tfIsM5 ? qmPp_M5 : tfIsM15 ? qmPp_M15 : tfIsH1 ? qmPp_H1 : tfIsH4 ? qmPp_H4 : qmPp) : qmPp
qmATR = ta.atr(21)
var string[] qmTypes = array.new_string()
var float[] qmVals = array.new_float()
var int[] qmIdxs = array.new_int()
var line[] qmLines = array.new_line()
var label[] qmLabels = array.new_label()
var line[] qmLiveLines = array.new_line()
qmMaxObjs = 250

f_qmPushLine(_ln) =>
    array.push(qmLines, _ln)
    if array.size(qmLines) > qmMaxObjs
        line.delete(array.shift(qmLines))

f_qmPushLabel(_lb) =>
    array.push(qmLabels, _lb)
    if array.size(qmLabels) > qmMaxObjs
        label.delete(array.shift(qmLabels))

qmHighPivot = ta.pivothigh(qmPPsel, qmPPsel)
qmLowPivot = ta.pivotlow(qmPPsel, qmPPsel)
qmHighValue = ta.valuewhen(not na(qmHighPivot), high[qmPPsel], 0)
qmLowValue = ta.valuewhen(not na(qmLowPivot), low[qmPPsel], 0)
qmHighIndex = ta.valuewhen(not na(qmHighPivot), bar_index[qmPPsel], 0)
qmLowIndex = ta.valuewhen(not na(qmLowPivot), bar_index[qmPPsel], 0)

if qmEnabled and (not onlyShSlMode or onlyQmMode)
    if not na(qmHighPivot) and not na(qmLowPivot)
        if array.size(qmTypes) >= 1
            last = array.get(qmTypes, array.size(qmTypes) - 1)
            if (last == "L" or last == "LL")
                if qmLowPivot < array.get(qmVals, array.size(qmTypes) - 1)
                    array.remove(qmTypes, array.size(qmTypes) - 1)
                    array.remove(qmVals, array.size(qmVals) - 1)
                    array.remove(qmIdxs, array.size(qmIdxs) - 1)
                    array.push(qmTypes, array.size(qmTypes) > 2 ? array.get(qmVals, array.size(qmTypes) - 2) < qmLowValue ? "HL" : "LL" : "L")
                    array.push(qmVals, qmLowValue)
                    array.push(qmIdxs, qmLowIndex)
                else
                    array.push(qmTypes, array.size(qmTypes) > 2 ? array.get(qmVals, array.size(qmTypes) - 2) < qmHighValue ? "HH" : "LH" : "H")
                    array.push(qmVals, qmHighValue)
                    array.push(qmIdxs, qmHighIndex)
            else if (last == "H" or last == "HH")
                if qmHighPivot > array.get(qmVals, array.size(qmTypes) - 1)
                    array.remove(qmTypes, array.size(qmTypes) - 1)
                    array.remove(qmVals, array.size(qmVals) - 1)
                    array.remove(qmIdxs, array.size(qmIdxs) - 1)
                    array.push(qmTypes, array.size(qmTypes) > 2 ? array.get(qmVals, array.size(qmTypes) - 2) < qmHighValue ? "HH" : "LH" : "H")
                    array.push(qmVals, qmHighValue)
                    array.push(qmIdxs, qmHighIndex)
                else
                    array.push(qmTypes, array.size(qmTypes) > 2 ? array.get(qmVals, array.size(qmTypes) - 2) < qmLowValue ? "HL" : "LL" : "L")
                    array.push(qmVals, qmLowValue)
                    array.push(qmIdxs, qmLowIndex)
            else if (last == "LH")
                if qmHighPivot < array.get(qmVals, array.size(qmTypes) - 1)
                    array.push(qmTypes, array.size(qmTypes) > 2 ? array.get(qmVals, array.size(qmTypes) - 2) < qmLowValue ? "HL" : "LL" : "L")
                    array.push(qmVals, qmLowValue)
                    array.push(qmIdxs, qmLowIndex)
                else if qmHighPivot > array.get(qmVals, array.size(qmTypes) - 1)
                    if close < array.get(qmVals, array.size(qmTypes) - 1)
                        array.remove(qmTypes, array.size(qmTypes) - 1)
                        array.remove(qmVals, array.size(qmVals) - 1)
                        array.remove(qmIdxs, array.size(qmIdxs) - 1)
                        array.push(qmTypes, array.size(qmTypes) > 2 ? array.get(qmVals, array.size(qmTypes) - 2) < qmHighValue ? "HH" : "LH" : "H")
                        array.push(qmVals, qmHighValue)
                        array.push(qmIdxs, qmHighIndex)
                    else if close > array.get(qmVals, array.size(qmTypes) - 1)
                        array.push(qmTypes, array.size(qmTypes) > 2 ? array.get(qmVals, array.size(qmTypes) - 2) < qmLowValue ? "HL" : "LL" : "L")
                        array.push(qmVals, qmLowValue)
                        array.push(qmIdxs, qmLowIndex)
            else if (last == "HL")
                if qmLowPivot > array.get(qmVals, array.size(qmTypes) - 1)
                    array.push(qmTypes, array.size(qmTypes) > 2 ? array.get(qmVals, array.size(qmTypes) - 2) < qmHighValue ? "HH" : "LH" : "H")
                    array.push(qmVals, qmHighValue)
                    array.push(qmIdxs, qmHighIndex)
                else if qmLowPivot < array.get(qmVals, array.size(qmTypes) - 1)
                    if close > array.get(qmVals, array.size(qmTypes) - 1)
                        array.remove(qmTypes, array.size(qmTypes) - 1)
                        array.remove(qmVals, array.size(qmVals) - 1)
                        array.remove(qmIdxs, array.size(qmIdxs) - 1)
                        array.push(qmTypes, array.size(qmTypes) > 2 ? array.get(qmVals, array.size(qmTypes) - 2) < qmLowValue ? "HL" : "LL" : "L")
                        array.push(qmVals, qmLowValue)
                        array.push(qmIdxs, qmLowIndex)
                    else if close < array.get(qmVals, array.size(qmTypes) - 1)
                        array.push(qmTypes, array.size(qmTypes) > 2 ? array.get(qmVals, array.size(qmTypes) - 2) < qmHighValue ? "HH" : "LH" : "H")
                        array.push(qmVals, qmHighValue)
                        array.push(qmIdxs, qmHighIndex)
    else if not na(qmHighPivot)
        if array.size(qmTypes) == 0
            array.insert(qmTypes, 0, "H")
            array.insert(qmVals, 0, qmHighValue)
            array.insert(qmIdxs, 0, qmHighIndex)
        else
            last = array.get(qmTypes, array.size(qmTypes) - 1)
            if (last == "L" or last == "HL" or last == "LL")
                if qmHighPivot > array.get(qmVals, array.size(qmTypes) - 1)
                    array.push(qmTypes, array.size(qmTypes) > 2 ? array.get(qmVals, array.size(qmTypes) - 2) < qmHighValue ? "HH" : "LH" : "H")
                    array.push(qmVals, qmHighValue)
                    array.push(qmIdxs, qmHighIndex)
                else if qmHighPivot < array.get(qmVals, array.size(qmTypes) - 1)
                    array.remove(qmTypes, array.size(qmTypes) - 1)
                    array.remove(qmVals, array.size(qmVals) - 1)
                    array.remove(qmIdxs, array.size(qmIdxs) - 1)
                    array.push(qmTypes, array.size(qmTypes) > 2 ? array.get(qmVals, array.size(qmTypes) - 2) < qmLowValue ? "HL" : "LL" : "L")
                    array.push(qmVals, qmLowValue)
                    array.push(qmIdxs, qmLowIndex)
            else if (last == "H" or last == "HH" or last == "LH")
                if array.get(qmVals, array.size(qmVals) - 1) < qmHighValue
                    array.remove(qmTypes, array.size(qmTypes) - 1)
                    array.remove(qmVals, array.size(qmVals) - 1)
                    array.remove(qmIdxs, array.size(qmIdxs) - 1)
                    array.push(qmTypes, array.size(qmTypes) > 2 ? array.get(qmVals, array.size(qmTypes) - 2) < qmHighValue ? "HH" : "LH" : "H")
                    array.push(qmVals, qmHighValue)
                    array.push(qmIdxs, qmHighIndex)
    else if not na(qmLowPivot)
        if array.size(qmTypes) == 0
            array.insert(qmTypes, 0, "L")
            array.insert(qmVals, 0, qmLowValue)
            array.insert(qmIdxs, 0, qmLowIndex)
        else
            last = array.get(qmTypes, array.size(qmTypes) - 1)
            if (last == "H" or last == "HH" or last == "LH")
                if qmLowPivot < array.get(qmVals, array.size(qmTypes) - 1)
                    array.push(qmTypes, array.size(qmTypes) > 2 ? array.get(qmVals, array.size(qmTypes) - 2) < qmLowValue ? "HL" : "LL" : "L")
                    array.push(qmVals, qmLowValue)
                    array.push(qmIdxs, qmLowIndex)
                else if qmLowPivot > array.get(qmVals, array.size(qmTypes) - 1)
                    array.remove(qmTypes, array.size(qmTypes) - 1)
                    array.remove(qmVals, array.size(qmVals) - 1)
                    array.remove(qmIdxs, array.size(qmIdxs) - 1)
                    array.push(qmTypes, array.size(qmTypes) > 2 ? array.get(qmVals, array.size(qmTypes) - 2) < qmHighValue ? "HH" : "LH" : "H")
                    array.push(qmVals, qmHighValue)
                    array.push(qmIdxs, qmHighIndex)
            else if (last == "L" or last == "HL" or last == "LL")
                if array.get(qmVals, array.size(qmVals) - 1) > qmLowValue
                    array.remove(qmTypes, array.size(qmTypes) - 1)
                    array.remove(qmVals, array.size(qmVals) - 1)
                    array.remove(qmIdxs, array.size(qmIdxs) - 1)
                    array.push(qmTypes, array.size(qmTypes) > 2 ? array.get(qmVals, array.size(qmTypes) - 2) < qmLowValue ? "HL" : "LL" : "L")
                    array.push(qmVals, qmLowValue)
                    array.push(qmIdxs, qmLowIndex)

if qmEnabled and qmLiveEnabled and (not onlyShSlMode or onlyQmMode)
    qmS = array.size(qmIdxs)
    qmPts = math.min(qmLivePoints, qmS)
    qmNeed = qmPts >= 2 ? ((qmPts - 1) + (qmLiveToCurrent ? 1 : 0)) : 0
    qmLastType = qmS > 0 ? array.get(qmTypes, qmS - 1) : ""
    qmIsW = qmLastType == "L" or qmLastType == "LL" or qmLastType == "HL"
    qmLiveCol = qmIsW ? qmLiveColorW : qmLiveColorM
    while array.size(qmLiveLines) > qmNeed
        line.delete(array.pop(qmLiveLines))
    while array.size(qmLiveLines) < qmNeed
        array.push(qmLiveLines, line.new(bar_index, close, bar_index, close, color=qmLiveCol, width=qmLiveWidth))
    if qmPts >= 2
        qmStart = qmS - qmPts
        for i = 0 to qmPts - 2
            x1 = array.get(qmIdxs, qmStart + i)
            y1 = array.get(qmVals, qmStart + i)
            x2 = array.get(qmIdxs, qmStart + i + 1)
            y2 = array.get(qmVals, qmStart + i + 1)
            ln = array.get(qmLiveLines, i)
            line.set_xy1(ln, x1, y1)
            line.set_xy2(ln, x2, y2)
            line.set_color(ln, qmLiveCol)
            line.set_width(ln, qmLiveWidth)
        if qmLiveToCurrent
            xLast = array.get(qmIdxs, qmS - 1)
            yLast = array.get(qmVals, qmS - 1)
            ln2 = array.get(qmLiveLines, qmNeed - 1)
            line.set_xy1(ln2, xLast, yLast)
            line.set_xy2(ln2, bar_index, close)
            line.set_color(ln2, qmLiveCol)
            line.set_width(ln2, qmLiveWidth)
else
    while array.size(qmLiveLines) > 0
        line.delete(array.pop(qmLiveLines))

var int qmCheckBe = 0
var int qmCheckBu = 0
var float qmBearStart = na
var float qmBullStart = na

if qmEnabled and (not onlyShSlMode or onlyQmMode) and array.size(qmTypes) > 5
    s = array.size(qmTypes)
    th1 = array.get(qmTypes, s - 1)
    th2 = array.get(qmTypes, s - 2)
    th3 = array.get(qmTypes, s - 3)
    th4 = array.get(qmTypes, s - 4)
    th5 = array.get(qmTypes, s - 5)

    ih = array.get(qmIdxs, s - 1)
    ih1 = array.get(qmIdxs, s - 1)
    ih2 = array.get(qmIdxs, s - 2)
    ih3 = array.get(qmIdxs, s - 3)
    ih4 = array.get(qmIdxs, s - 4)
    ih5 = array.get(qmIdxs, s - 5)

    vh1 = array.get(qmVals, s - 1)
    vh2 = array.get(qmVals, s - 2)
    vh3 = array.get(qmVals, s - 3)
    vh4 = array.get(qmVals, s - 4)
    vh5 = array.get(qmVals, s - 5)

    tl1 = array.get(qmTypes, s - 1)
    tl2 = array.get(qmTypes, s - 2)
    tl3 = array.get(qmTypes, s - 3)
    tl4 = array.get(qmTypes, s - 4)
    tl5 = array.get(qmTypes, s - 5)

    il = array.get(qmIdxs, s - 1)
    il1 = array.get(qmIdxs, s - 1)
    il2 = array.get(qmIdxs, s - 2)
    il3 = array.get(qmIdxs, s - 3)
    il4 = array.get(qmIdxs, s - 4)
    il5 = array.get(qmIdxs, s - 5)

    vl1 = array.get(qmVals, s - 1)
    vl2 = array.get(qmVals, s - 2)
    vl3 = array.get(qmVals, s - 3)
    vl4 = array.get(qmVals, s - 4)
    vl5 = array.get(qmVals, s - 5)

    bearQM = th1 == "LL" and th2 == "HH" and th3 == "HL" and th4 == "HH" and vh5 < vh1 and ih == (bar_index - qmPPsel) and qmCheckBe == 0
    if bearQM
        qmBearStart := vh2
        qmCheckBe := 1
        beMove = int((ih2 - ih4) / 2)
        f_qmPushLine(line.new(ih5, vh5, ih4, vh4, color=color.rgb(170, 29, 29), width=2))
        f_qmPushLine(line.new(ih4, vh4, ih3, vh3, color=color.rgb(170, 29, 29), width=2))
        f_qmPushLine(line.new(ih3, vh3, ih2, vh2, color=color.rgb(170, 29, 29), width=2))
        f_qmPushLine(line.new(ih2, vh2, ih1, vh1, color=color.rgb(170, 29, 29), width=2))
        f_qmPushLine(line.new(ih1, vh1, ih1 + beMove - 2, vh4, color=color.rgb(252, 173, 4), width=2, style=line.style_arrow_right))
        f_qmPushLine(line.new(ih4, vh4, ih1 + beMove, vh4, color=color.rgb(0, 0, 0), width=1, style=line.style_dotted))
        f_qmPushLine(line.new(ih2, vh2 + (qmATR / 2), ih1 + beMove, vh2 + (qmATR / 2), color=color.rgb(170, 29, 29), width=1, style=line.style_dotted))
        f_qmPushLine(line.new(ih3, vh3, ih1 + beMove, vh3, color=color.rgb(91, 172, 74), width=1, style=line.style_dotted))
        f_qmPushLine(line.new(ih1, vh1, ih1 + beMove, vh1, color=color.rgb(91, 172, 74), width=1, style=line.style_dotted))
        f_qmPushLabel(label.new(ih1 + beMove + 1, vh4, "Entry", color=color.rgb(255, 255, 255, 100), style=label.style_text_outline))
        f_qmPushLabel(label.new(ih1 + beMove + 1, vh2 + (qmATR / 2), "SL", color=color.rgb(255, 255, 255, 100), style=label.style_text_outline))
        f_qmPushLabel(label.new(ih1 + beMove + 1, vh3, "TP1", color=color.rgb(255, 255, 255, 100), style=label.style_text_outline))
        f_qmPushLabel(label.new(ih1 + beMove + 1, vh1, "TP2", color=color.rgb(255, 255, 255, 100), style=label.style_text_outline))
    if not na(qmBearStart) and qmBearStart != vh2
        qmCheckBe := 0

    bullQM = tl1 == "HH" and tl2 == "LL" and tl3 == "LH" and tl4 == "LL" and vl5 > vl1 and il == bar_index - qmPPsel and qmCheckBu == 0
    if bullQM
        qmBullStart := vl2
        qmCheckBu := 1
        buMove = int((il2 - il4) / 2)
        f_qmPushLine(line.new(il5, vl5, il4, vl4, color=color.rgb(38, 150, 41), width=2))
        f_qmPushLine(line.new(il4, vl4, il3, vl3, color=color.rgb(38, 150, 41), width=2))
        f_qmPushLine(line.new(il3, vl3, il2, vl2, color=color.rgb(38, 150, 41), width=2))
        f_qmPushLine(line.new(il2, vl2, il1, vl1, color=color.rgb(38, 150, 41), width=2))
        f_qmPushLine(line.new(il1, vl1, il1 + buMove - 2, vl4, color=color.rgb(4, 215, 252), width=2, style=line.style_arrow_right))
        f_qmPushLine(line.new(il4, vl4, il1 + buMove, vl4, color=color.rgb(0, 0, 0), width=1, style=line.style_dotted))
        f_qmPushLine(line.new(il2, vl2 - (qmATR / 2), il1 + buMove, vl2 - (qmATR / 2), color=color.rgb(170, 29, 29), width=1, style=line.style_dotted))
        f_qmPushLine(line.new(il3, vl3, il1 + buMove, vl3, color=color.rgb(91, 172, 74), width=1, style=line.style_dotted))
        f_qmPushLine(line.new(il1, vl1, il1 + buMove, vl1, color=color.rgb(91, 172, 74), width=1, style=line.style_dotted))
        f_qmPushLabel(label.new(il1 + buMove + 1, vl4, "Entry", color=color.rgb(255, 255, 255, 100), style=label.style_text_outline))
        f_qmPushLabel(label.new(il1 + buMove + 1, vl2 - (qmATR / 2), "SL", color=color.rgb(255, 255, 255, 100), style=label.style_text_outline))
        f_qmPushLabel(label.new(il1 + buMove + 1, vl3, "TP1", color=color.rgb(255, 255, 255, 100), style=label.style_text_outline))
        f_qmPushLabel(label.new(il1 + buMove + 1, vl1, "TP2", color=color.rgb(255, 255, 255, 100), style=label.style_text_outline))
    if not na(qmBullStart) and qmBullStart != vl2
        qmCheckBu := 0
