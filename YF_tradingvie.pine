                        qmlTlSellTLx1 := lx1
                        qmlTlSellTLy1 := ly1
                        qmlTlSellTLx2 := lx2
                        qmlTlSellTLy2 := ly2
                        if not na(qmlTlSellTLLine)
                            line.delete(qmlTlSellTLLine)
