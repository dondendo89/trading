                        qmlTlSellTLLine := line.new(lx1, ly1, lx2, ly2, xloc=xloc.bar_index, extend=extend.right, color=colTL, width=2)
                        qmlTlSellLevelLine := line.new(array.get(qIndex, sz - 4), lvl, bar_index, lvl, xloc=xloc.bar_index, extend=extend.right, color=colQML, width=1, style=line.style_dotted)
            int idx2 = array.get(qIndex, sz - 2)
            int idx4 = array.get(qIndex, sz - 4)
            int mv = int((idx2 - idx4) / 2.0)
            mv := mv == 0 ? 2 : mv
            if BullQM
                line l1 = line.new(array.get(qIndex, sz - 5), array.get(qValue, sz - 5), array.get(qIndex, sz - 4), array.get(qValue, sz - 4), xloc=xloc.bar_index, color=colQM_W, width=2)
                line l2 = line.new(array.get(qIndex, sz - 4), array.get(qValue, sz - 4), array.get(qIndex, sz - 3), array.get(qValue, sz - 3), xloc=xloc.bar_index, color=colQM_W, width=2)
                line l3 = line.new(array.get(qIndex, sz - 3), array.get(qValue, sz - 3), array.get(qIndex, sz - 2), array.get(qValue, sz - 2), xloc=xloc.bar_index, color=colQM_W, width=2)
                line l4 = line.new(array.get(qIndex, sz - 2), array.get(qValue, sz - 2), array.get(qIndex, sz - 1), array.get(qValue, sz - 1), xloc=xloc.bar_index, color=colQM_W, width=2)
                line l5 = line.new(array.get(qIndex, sz - 1), array.get(qValue, sz - 1), array.get(qIndex, sz - 1) + mv - 2, array.get(qValue, sz - 4), xloc=xloc.bar_index, color=color.rgb(4, 215, 252), width=2, style=line.style_arrow_right)
