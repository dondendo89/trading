rsiCrossSessionUseLondon = input.bool(true, "Usa London", group="RSI Cross")
rsiCrossSessionUseNy = input.bool(true, "Usa NY", group="RSI Cross")
rsiCrossSessionExtremeBufferTicks = input.int(0, "Distanza max da Session High/Low (ticks)", minval=0, group="RSI Cross")

rsiPatternEnabled = input.bool(false, "Pattern RSI M/W", group="RSI Pattern")
rsiPatternPivotLen = input.int(2, "Pivot RSI (candele)", minval=1, group="RSI Pattern")
rsiPatternUseTfPivots = input.bool(false, "Usa pivot per TF (M1/M15/H1/H4)", group="RSI Pattern")
rsiPatternPivotLen_M1 = input.int(2, "M1 - Pivot RSI (candele)", minval=1, group="RSI Pattern")
rsiPatternPivotLen_M15 = input.int(2, "M15 - Pivot RSI (candele)", minval=1, group="RSI Pattern")
