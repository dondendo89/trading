                line sb = line.new(array.get(qIndex, sz - 2), array.get(qValue, sz - 2) + ATR / 2, array.get(qIndex, sz - 1) + mv, array.get(qValue, sz - 2) + ATR / 2, xloc=xloc.bar_index, color=color.rgb(170, 29, 29), width=1, style=line.style_dotted)
