rsiPatternMidDelta = input.float(3.0, "Min delta gamba centrale RSI", minval=0.0, step=0.1, group="RSI Pattern")
rsiPatternShowLabels = input.bool(true, "Mostra etichette", group="RSI Pattern")
rsiPatternUseDailyExtreme = input.bool(false, "Filtro Daily High/Low", group="RSI Pattern")
rsiPatternDailyExtremeBufferTicks = input.int(0, "Distanza max da Daily High/Low (ticks)", minval=0, group="RSI Pattern")

crtEnabled = input.bool(false, "CRT (Candle Range Theory)", group="CRT")
crtTf = input.string("15", "Timeframe CRT", options=["1", "15", "60", "240"], group="CRT")
crtSweepBufferTicks = input.int(0, "Sweep buffer (ticks)", minval=0, group="CRT")
